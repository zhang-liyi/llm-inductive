var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Athletes have stable intrinsic traits (skating, stick handling, reaction speed, strength) that are constant across scrimmages.
  // Scrimmage outcomes on a given day depend on these intrinsic traits plus scrimmage-specific effort and randomness.

  // Intrinsic strength: stable physical strength/power on an arbitrary 0–200 scale (higher = stronger).
  var intrinsic_strength = mem(function({athlete}) {
    // Prior buckets for weak / average / strong strength in ice hockey players.
    var parameter_low_strength_prior = 0.25;
    var parameter_average_strength_prior = 0.5;
    var parameter_high_strength_prior = 0.25;

    // Means for each bucket on a 0–200 scale.
    var low_strength_mean = 80;
    var average_strength_mean = 110;
    var high_strength_mean = 140;
    var parameter_intrinsic_strength_variance = 15; // strength units^2

    var base_strength_mean = categorical({
      ps: [parameter_low_strength_prior,
           parameter_average_strength_prior,
           parameter_high_strength_prior],
      vs: [low_strength_mean,
           average_strength_mean,
           high_strength_mean]
    });

    return Math.max(
      gaussian(base_strength_mean, parameter_intrinsic_strength_variance),
      0
    );
  });

  // Intrinsic skating ability: correlated with strength, same 0–200 scale.
  var intrinsic_skating_ability = mem(function({athlete}) {
    var strength = intrinsic_strength({athlete: athlete});
    // Stronger players tend to skate better on average.
    return Math.max(gaussian(0.7 * strength, 20), 0);
  });

  // Stick handling skill: also positively correlated with strength.
  var stick_handling_skill = mem(function({athlete}) {
    var strength = intrinsic_strength({athlete: athlete});
    return Math.max(gaussian(0.6 * strength, 20), 0);
  });

  // Reaction speed: somewhat correlated with strength but with more noise.
  var reaction_speed = mem(function({athlete}) {
    var strength = intrinsic_strength({athlete: athlete});
    return Math.max(gaussian(0.5 * strength, 25), 0);
  });

  // Overall intrinsic hockey skill on same scale, as a weighted combination of traits.
  var overall_intrinsic_hockey_skill = mem(function({athlete}) {
    var skating = intrinsic_skating_ability({athlete: athlete});
    var stick = stick_handling_skill({athlete: athlete});
    var react = reaction_speed({athlete: athlete});
    var strength = intrinsic_strength({athlete: athlete});

    // Weighted sum of components.
    var raw_skill =
      0.3 * skating +
      0.3 * stick +
      0.2 * react +
      0.2 * strength;

    // Small noise to capture unmodeled intrinsic factors.
    return Math.max(gaussian(raw_skill, 10), 0);
  });

  // An athlete's intrinsic strength ranking out of N athletes is the number of other athletes
  // we would expect them to be stronger than out of N total random athletes.
  var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
    // Generate out_of_n_athletes - 1 other random athlete IDs.
    var random_athlete_ids = mapN(
      function(x) { return uniform(0, 10000); },
      out_of_n_athletes - 1
    );

    var this_strength = intrinsic_strength({athlete: athlete});

    // Count how many random athletes this athlete is stronger than.
    return sum(map(
      function(random_athlete_id) {
        return this_strength >
               intrinsic_strength({athlete: random_athlete_id});
      },
      random_athlete_ids
    ));
  };

  // Scrimmage-specific effort: percentage 0–100% of maximum effort in that scrimmage.
  // Stronger / fitter players are somewhat more likely to sustain high effort.
  var scrimmage_effort = mem(function({athlete, scrimmage}) {
    var strength = intrinsic_strength({athlete: athlete});

    // Prior over low / medium / high effort buckets depends on intrinsic strength.
    var parameter_low_effort_prior =
      strength > 130 ? 0.1 :
      strength < 90  ? 0.3 :
                       0.2;

    var parameter_high_effort_prior =
      strength > 130 ? 0.5 :
      strength < 90  ? 0.2 :
                       0.3;

    var parameter_medium_effort_prior =
      1 - parameter_low_effort_prior - parameter_high_effort_prior;

    // Effort means in percent.
    var low_effort_mean = 40;   // 40% effort
    var medium_effort_mean = 70; // 70% effort
    var high_effort_mean = 95;  // near-maximal effort

    var base_effort_mean = categorical({
      ps: [parameter_low_effort_prior,
           parameter_medium_effort_prior,
           parameter_high_effort_prior],
      vs: [low_effort_mean,
           medium_effort_mean,
           high_effort_mean]
    });

    var effort = gaussian(base_effort_mean, 10); // percentage points
    return Math.min(Math.max(effort, 0), 100);
  });

  // Expose effort as a queryable percentage.
  var effort_percentage_in_scrimmage = function({athlete, scrimmage}) {
    return scrimmage_effort({athlete: athlete, scrimmage: scrimmage});
  };

  // Effective player performance in a given scrimmage:
  // depends on intrinsic skill and that scrimmage's effort.
  // Units: arbitrary performance points; higher = better.
  var effective_player_performance_in_scrimmage = function({athlete, scrimmage}) {
    var skill = overall_intrinsic_hockey_skill({athlete: athlete});
    var effort_pct = scrimmage_effort({athlete: athlete, scrimmage: scrimmage}); // 0–100
    var effort_fraction = effort_pct / 100;

    // Even at low apparent effort, players contribute some baseline due to skill.
    var expected_performance =
      skill * (0.4 + 0.6 * effort_fraction);

    return gaussian(expected_performance, 20);
  };

  // Team effective performance in a scrimmage = sum of member performances.
  var team_effective_performance_in_scrimmage = function({team, scrimmage}) {
    return sum(map(
      function(athlete) {
        return effective_player_performance_in_scrimmage({
          athlete: athlete,
          scrimmage: scrimmage
        });
      },
      team
    ));
  };

  // Team score in a scrimmage: noisy function of team effective performance.
  // Units: arbitrary "score points" roughly proportional to goal-scoring chances.
  var team_score_in_scrimmage = function({team, scrimmage}) {
    var team_perf = team_effective_performance_in_scrimmage({
      team: team,
      scrimmage: scrimmage
    });

    // Add scoring noise (luck, bounces, goalie performance, etc.).
    return gaussian(team_perf, 30);
  };

  // A team beats another team in a scrimmage if their score is greater.
  var beat = function({team1, team2, scrimmage}) {
    return team_score_in_scrimmage({team: team1, scrimmage: scrimmage}) >
           team_score_in_scrimmage({team: team2, scrimmage: scrimmage});
  };

  // A team loses if they do not beat the other team.
  var lost = function({team1, team2, scrimmage}) {
    return !beat({team1: team1, team2: team2, scrimmage: scrimmage});
  };

  // To calculate who would win and by how much, we estimate how often Team 2 wins
  // across many hypothetical future scrimmages with fresh efforts/noise.
  // Return value: fraction of future scrimmages Team 2 wins (0 = Team 1 always wins, 1 = Team 2 always wins).
  var who_would_win_by_how_much = function({team1, team2, scrimmage}) {
    var num_future_scrimmages_to_simulate = 100;
    var random_future_scrimmage_ids = mapN(
      function(x) { return uniform(scrimmage + 1, 1000); },
      num_future_scrimmages_to_simulate
    );

    var simulated_wins_by_team2 = sum(map(
      function(random_scrimmage_id) {
        return lost({
          team1: team1,
          team2: team2,
          scrimmage: random_scrimmage_id
        });
      },
      random_future_scrimmage_ids
    ));

    return simulated_wins_by_team2 / num_future_scrimmages_to_simulate;
  };

  // CONDITIONS

  // In the first scrimmage, Riley beat Sam.
  condition(beat({team1: ['riley'], team2: ['sam'], scrimmage: 1}));

  // In the second scrimmage, Riley and Alex beat Sam and Jamie.
  condition(beat({team1: ['riley', 'alex'], team2: ['sam', 'jamie'], scrimmage: 2}));

  // In the third scrimmage, Jamie and Riley lost to Sam and Casey.
  condition(lost({team1: ['jamie', 'riley'], team2: ['sam', 'casey'], scrimmage: 3}));

  // QUERIES

  // Query 1: Out of 100 random ice hockey athletes, where do you think Riley ranks in terms of intrinsic strength?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Jamie put into the third scrimmage?
  // Query 3: In a new scrimmage later this same day between Riley and Casey (Team 1) and Sam and Alex (Team 2), who would win and by how much?
  // Query 4: In a new scrimmage later this same day between Jamie and Taylor (Team 1) and Sam and Casey (Team 2), who would win and by how much?
  return {
    query1: intrinsic_strength_rank({athlete: 'riley', out_of_n_athletes: 100}),
    query2: effort_percentage_in_scrimmage({athlete: 'jamie', scrimmage: 3}),
    query3: who_would_win_by_how_much({team1: ['riley', 'casey'], team2: ['sam', 'alex'], scrimmage: 4}),
    query4: who_would_win_by_how_much({team1: ['jamie', 'taylor'], team2: ['sam', 'casey'], scrimmage: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: 'MCMC', samples: 10000});
json.write('inference_results/result-12.json', posterior);