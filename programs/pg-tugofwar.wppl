var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Intrinsic strength is a stable attribute (strength units, roughly proportional to maximum horizontal pulling force in Newtons) that does not change over matches on the same day.
  var intrinsic_strength = mem(function({athlete}) {
    // Prior over low / medium / high strength types
    var parameter_low_strength_prior = 0.3;
    var parameter_average_strength_prior = 0.4;
    var parameter_high_strength_prior = 0.3;

    // On an arbitrary scale centered around 100 strength units.
    var low_strength_mean = 70;
    var average_strength_mean = 100;
    var high_strength_mean = 140;
    var parameter_intrinsic_strength_stdev = 15;

    var this_athlete_strength_mean = categorical({
      ps: [parameter_low_strength_prior,
           parameter_average_strength_prior,
           parameter_high_strength_prior],
      vs: [low_strength_mean,
           average_strength_mean,
           high_strength_mean]
    });

    // Strength is non-negative.
    return Math.max(gaussian(this_athlete_strength_mean,
                             parameter_intrinsic_strength_stdev), 0);
  });

  // Intrinsic strength ranking out of n athletes:
  // how many of n-1 random athletes this athlete is stronger than.
  var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
    var random_athlete_ids =
        mapN(function(x) { return uniform(0, 1000); }, out_of_n_athletes - 1);

    return sum(map(function(random_athlete_id) {
      return intrinsic_strength({athlete: athlete}) >
             intrinsic_strength({athlete: random_athlete_id});
    }, random_athlete_ids));
  };

  // Effort in a given match is a fraction between 0 and 1, match-specific.
  // It depends on intrinsic strength (e.g., stronger athletes tend to sustain
  // higher effort in competitive settings, but all can vary).
  var effort_in_match = mem(function({athlete, match}) {
    var strength = intrinsic_strength({athlete: athlete});

    // Prior over low / medium / high effort given strength.
    var parameter_low_effort_prior =
        strength > 120 ? 0.1 :
        strength < 80  ? 0.4 :
                         0.25;
    var parameter_medium_effort_prior =
        strength > 120 ? 0.3 :
        strength < 80  ? 0.4 :
                         0.5;
    var parameter_high_effort_prior =
        strength > 120 ? 0.6 :
        strength < 80  ? 0.2 :
                         0.25;

    var low_effort_mean = 0.4;   // 40% effort
    var medium_effort_mean = 0.7; // 70% effort
    var high_effort_mean = 0.95;  // 95% effort
    var effort_stdev = 0.08;      // effort fraction standard deviation

    var this_match_effort_mean = categorical({
      ps: [parameter_low_effort_prior,
           parameter_medium_effort_prior,
           parameter_high_effort_prior],
      vs: [low_effort_mean,
           medium_effort_mean,
           high_effort_mean]
    });

    // Clamp to [0,1] range.
    return Math.min(Math.max(gaussian(this_match_effort_mean, effort_stdev), 0), 1);
  });

  // Effort percentage on [0,100]% scale.
  var effort_percentage_in_match = function({athlete, match}) {
    return 100 * effort_in_match({athlete: athlete, match: match});
  };

  // Individual pulling force in a match (strength units).
  // Effective pull ≈ intrinsic_strength * effort * (1 + small noise).
  var individual_pull_in_match = function({athlete, match}) {
    var strength = intrinsic_strength({athlete: athlete});
    var effort = effort_in_match({athlete: athlete, match: match});
    var multiplicative_noise = gaussian(1, 0.1); // ~10% noise around mean
    return Math.max(strength * effort * multiplicative_noise, 0);
  };

  // Team total pulling force in a match is the sum of individual pulls.
  var team_pull_force_in_match = function({team, match}) {
    return sum(map(function(athlete) {
      return individual_pull_in_match({athlete: athlete, match: match});
    }, team));
  };

  // Margin of victory: team1_force - team2_force + outcome_noise.
  // Positive => team1 effectively pulls harder and should win.
  var margin_of_victory_in_match = function({team1, team2, match}) {
    var team1_force = team_pull_force_in_match({team: team1, match: match});
    var team2_force = team_pull_force_in_match({team: team2, match: match});
    var outcome_noise = gaussian(0, 5); // strength-unit noise at match level
    return team1_force - team2_force + outcome_noise;
  };

  // Team1 beats team2 in a match if margin_of_victory > 0.
  var beat = function({team1, team2, match}) {
    return margin_of_victory_in_match({team1: team1, team2: team2, match: match}) > 0;
  };

  // Team1 loses to team2 if they do not beat them.
  var lost = function({team1, team2, match}) {
    return !beat({team1: team1, team2: team2, match: match});
  };

  // Predictive query: who would win and by how much (as probability that Team 2 wins).
  // Return value in [0,1]: 0 => Team 1 would certainly win,
  // 1 => Team 2 would certainly win.
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;
    var random_future_match_ids =
        mapN(function(x) { return uniform(match + 1, 1000); },
             num_future_matches_to_simulate);

    var simulated_matches_won_by_team_2 = sum(map(function(random_future_match_id) {
      return lost({team1: team1, team2: team2, match: random_future_match_id});
    }, random_future_match_ids));

    return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
  };

  // CONDITIONS
  // In the first match, Bob and Mary beat Tom and Sue.
  condition(beat({team1:['bob', 'mary'], team2:['tom', 'sue'], match: 1}))

  // In the second match, Sue beat Mary.
  condition(beat({team1:['sue'], team2:['mary'], match: 2}))

  // In the third match, Bob and Sue lost to Tom and Jim. 
  condition(lost({team1:['bob', 'sue'], team2:['tom', 'jim'], match: 3}))

  // In the fourth match, Jim beat Bob.
  condition(beat({team1:['jim'], team2:['bob'], match: 4}))

  // QUERIES
  // Query 1: Out of 100 random athletes, where do you think Bob ranks in terms of intrinsic strength?
  // Query 2: Out of 100 random athletes, where do you think Mary ranks in terms of intrinsic strength?
  // Query 3: On a percentage scale from 0 to 100%, how much effort do you think Jim put into the third match?
  // Query 4: On a percentage scale from 0 to 100%, how much effort do you think Bob put into the first match?
  // Query 5: In a new match later this same day between Bob and Mary (Team 1) and Jim and Sue (Team 2), who would win and by how much?
  // Query 6: In a new match later this same day between Sue and Paul (Team 1) and Jim and Bob (Team 2), who would win and by how much? 
  return {
    query1: intrinsic_strength_rank({athlete: 'bob', out_of_n_athletes: 100}),
    query2: intrinsic_strength_rank({athlete: 'mary', out_of_n_athletes: 100}),
    query3: effort_percentage_in_match({athlete: 'jim', match: 3}),
    query4: effort_percentage_in_match({athlete: 'bob', match: 1}),
    query5: who_would_win_by_how_much({team1:['bob', 'mary'], team2:['jim', 'sue'], match: 5}),
    query6: who_would_win_by_how_much({team1:['sue', 'paul'], team2:['jim', 'bob'], match: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "rejection", samples: 10000});
json.write('inference_results/result-rejection-tugofwar.json', posterior);