var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  //////////////////////////////
  // BACKGROUND KNOWLEDGE
  //////////////////////////////

  // Intrinsic climbing ability is a stable trait of each climber (power/technique/problem-solving).
  // Units: arbitrary ability units on a roughly normal scale.
  var intrinsic_climbing_ability = mem(function({climber}) {
    // Three ability buckets for the general population.
    var low_mean = 0;
    var mid_mean = 1;
    var high_mean = 2;
    var ability_variance = 0.5;

    // Priors over buckets depend on the type of climber.
    var ps =
        climber == 'strong_substitute'
        ? [0.05, 0.25, 0.70]         // much more likely to be strong
        : climber == 'substitute'
          ? [0.30, 0.50, 0.20]      // generic substitute: a bit more average
          : [0.33, 0.34, 0.33];     // default prior for named climbers

    var mean_ability = categorical({
      ps: ps,
      vs: [low_mean, mid_mean, high_mean]
    });

    return gaussian(mean_ability, ability_variance);
  });

  // Simple helper: mean of a list of numbers.
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // Effort in a given round is a proportion between 0 and 1.
  // Units: 0–1 (later converted to 0–100%).
  // Effort is round-specific and can vary even for the same climber.
  var effort_in_round = mem(function({climber, round}) {
    // Baseline effort tendency for this (climber, round).
    // Beta(2,2) is centered at 0.5 with moderate spread.
    var base_effort = beta(2, 2);

    // Slight adjustment: more capable climbers may be able to get away
    // with slightly less or more controlled effort; keep this small.
    var ability = intrinsic_climbing_ability({climber: climber});
    var ability_effect = 0.05 * ability; // small shift

    var raw_effort = base_effort + ability_effect;

    // Clamp to [0,1].
    return Math.min(1, Math.max(0, raw_effort));
  });

  // Effort as a percentage between 0 and 100%.
  // Units: percent of maximal effort.
  var effort_percentage_in_round = function({climber, round}) {
    return 100 * effort_in_round({climber: climber, round: round});
  };

  // Number of completed problems (tops) for an individual in a round.
  // Units: integer count of problems, roughly 0–10.
  var individual_completed_problems_in_round = function({climber, round}) {
    var ability = intrinsic_climbing_ability({climber: climber});
    var effort = effort_in_round({climber: climber, round: round});

    // Expected problems as a function of ability and effort.
    var expected_problems = 2 + 1.5 * ability + 4 * effort;

    // Add noise and clamp/round to a reasonable count.
    var raw = gaussian(expected_problems, 1);
    var clipped = Math.min(10, Math.max(0, raw));
    return Math.round(clipped);
  };

  // Number of attempts taken by an individual in a round.
  // Units: integer count of attempts, at least 1.
  var individual_attempts_in_round = function({climber, round}) {
    var ability = intrinsic_climbing_ability({climber: climber});
    var effort = effort_in_round({climber: climber, round: round});

    // Better ability/effort → fewer attempts on average.
    var expected_attempts = 15 - (3 * ability + 5 * effort);

    var raw = gaussian(expected_attempts, 2);
    var clipped = Math.max(1, raw);
    return Math.round(clipped);
  };

  // Individual score in a round, represented by problems and attempts.
  // Higher problems are better; for equal problems, fewer attempts are better.
  var individual_score_in_round = function({climber, round}) {
    var problems = individual_completed_problems_in_round({
      climber: climber,
      round: round
    });
    var attempts = individual_attempts_in_round({
      climber: climber,
      round: round
    });
    return {problems: problems, attempts: attempts};
  };

  // Team score in a round is based on the combined performance
  // (sum of problems and attempts) of all team members.
  var team_score_in_round = function({team, round}) {
    var member_scores = map(function(c) {
      return individual_score_in_round({climber: c, round: round});
    }, team);

    var total_problems = sum(map(function(s) { return s.problems; }, member_scores));
    var total_attempts = sum(map(function(s) { return s.attempts; }, member_scores));

    return {problems: total_problems, attempts: total_attempts};
  };

  // Beat relation:
  // - For individuals: climber1 beats climber2 if they complete more problems,
  //   or the same number with fewer attempts.
  // - For teams: team1 beats team2 if they complete more total problems,
  //   or the same number with fewer total attempts.
  var beat = function({climber1, climber2, team1, team2, round}) {
    if (team1 != undefined) {
      var s1 = team_score_in_round({team: team1, round: round});
      var s2 = team_score_in_round({team: team2, round: round});
      return (s1.problems > s2.problems) ||
             ((s1.problems == s2.problems) && (s1.attempts < s2.attempts));
    } else {
      var i1 = individual_score_in_round({climber: climber1, round: round});
      var i2 = individual_score_in_round({climber: climber2, round: round});
      return (i1.problems > i2.problems) ||
             ((i1.problems == i2.problems) && (i1.attempts < i2.attempts));
    }
  };

  // Intrinsic climbing ability ranking: number of random other climbers
  // (out of N-1) that this climber is better than, in terms of intrinsic ability.
  var intrinsic_climbing_ability_rank = function({climber, out_of_n_climbers}) {
    var random_climber_ids = mapN(
      function(x) { return uniform(0, 1000000); },
      out_of_n_climbers - 1
    );

    return sum(map(function(random_id) {
      return intrinsic_climbing_ability({climber: climber}) >
             intrinsic_climbing_ability({climber: random_id});
    }, random_climber_ids));
  };

  // For hypothetical future rounds between two teams, compute how often
  // Team 2 would win in a batch of simulated future rounds.
  // Return value: probability on 0–1 scale that Team 2 wins.
  // (0 = Team 1 would almost surely win, 1 = Team 2 would almost surely win.)
  var who_would_win_by_how_much = function({team1, team2, round}) {
    var num_future_rounds_to_simulate = 100;

    // Use fresh round IDs beyond the observed ones.
    var random_future_round_ids = mapN(
      function(x) { return uniform(round + 1, 1000); },
      num_future_rounds_to_simulate
    );

    var wins_by_team2 = sum(map(function(random_round_id) {
      // If team1 does NOT beat team2, we treat it as a win for team2
      // (ties in this model are essentially measure-zero).
      return beat({team1: team1, team2: team2, round: random_round_id}) ? 0 : 1;
    }, random_future_round_ids));

    return wins_by_team2 / num_future_rounds_to_simulate;
  };

  //////////////////////////////
  // CONDITIONS
  //////////////////////////////

  // In the first round, Kai beat Rowan.
  condition(beat({climber1: 'kai', climber2: 'rowan', round: 1}))

  // In the second round, Rowan beat Tessa.
  condition(beat({climber1: 'rowan', climber2: 'tessa', round: 2}))

  // In the third round, Kai, Tessa, and Uma beat Rowan, Vince, and a substitute.
  condition(beat({team1: ['kai', 'tessa', 'uma'], team2: ['rowan', 'vince', 'substitute'], round: 3}))

  // In the fourth round, Vince beat Uma.
  condition(beat({climber1: 'vince', climber2: 'uma', round: 4}))

  //////////////////////////////
  // QUERIES
  //////////////////////////////

  // Query 1: Out of 100 random boulderers, where do you think Kai ranks in terms of intrinsic climbing ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Rowan put into the second round?
  // Query 3: In a new round later this same day between Kai, Uma, and a substitute (Team 1)
  //          and Rowan, Tessa, and Vince (Team 2), who would win and by how much?
  // Query 4: In a new round later this same day between Tessa and Uma (Team 1)
  //          and Rowan and a strong substitute (Team 2), who would win and by how much?

  return {
    query1: intrinsic_climbing_ability_rank({climber: 'kai', out_of_n_climbers: 100}),
    query2: effort_percentage_in_round({climber: 'rowan', round: 2}),
    query3: who_would_win_by_how_much({team1: ['kai', 'uma', 'substitute'], team2: ['rowan', 'tessa', 'vince'], round: 5}),
    query4: who_would_win_by_how_much({team1: ['tessa', 'uma'], team2: ['rowan', 'strong_substitute'], round: 6})
  };
};

// Run the model and collect an estimate of the posterior over the queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-49.json', posterior);