var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  /////////////////////////////
  // BACKGROUND KNOWLEDGE
  /////////////////////////////

  // Intrinsic striking ability and skill is a stable, boxer-specific trait for the day.
  // Units: "skill points" on an arbitrary scale centered around ~100.
  var intrinsic_striking_ability_and_skill = mem(function({boxer}) {
    // Three broad skill buckets: low, average, high.
    var p_low = 0.33;
    var p_avg = 0.33;
    var p_high = 0.34;

    var low_mean = 80;
    var avg_mean = 100;
    var high_mean = 140;
    var skill_sd = 10;

    var bucket_mean = categorical({
      ps: [p_low, p_avg, p_high],
      vs: [low_mean, avg_mean, high_mean]
    });

    // Truncate at 0 to avoid negative skill.
    return Math.max(gaussian(bucket_mean, skill_sd), 0);
  });

  // Typical effort tendency for a boxer across bouts (on 0–1 scale).
  // Depends on intrinsic skill: stronger boxers tend (slightly) to work harder in meaningful events.
  var typical_effort_tendency = mem(function({boxer}) {
    var skill = intrinsic_striking_ability_and_skill({boxer: boxer});
    // Map skill (~[60,160]) to a Beta distribution's mean.
    var base_mean = 0.6 + 0.001 * (skill - 100); // around 0.6; more skilled => slightly higher.
    var mean_clamped = Math.min(Math.max(base_mean, 0.3), 0.9);
    // Convert mean, with fixed concentration, into alpha/beta.
    var concentration = 8; // higher => less variable across bouts.
    var alpha = mean_clamped * concentration;
    var betaParam = (1 - mean_clamped) * concentration;
    return beta(alpha, betaParam); // returns typical effort level in [0,1].
  });

  // Fatigue level for the day (0–1, higher means more resistant to fatigue).
  // Depends on typical effort tendency: boxers who train hard often have better stamina.
  var fatigue_level_on_day = mem(function({boxer}) {
    var tendency = typical_effort_tendency({boxer: boxer});
    // Center around tendency, but allow variation.
    var raw = gaussian(tendency, 0.1);
    return Math.min(Math.max(raw, 0), 1);
  });

  // Effort put into a specific bout (0–1).
  // Depends on typical effort tendency and fatigue (later bouts can see slightly reduced effort).
  var effort_in_bout = mem(function({boxer, bout}) {
    var tendency = typical_effort_tendency({boxer: boxer});
    var stamina = fatigue_level_on_day({boxer: boxer});

    // Simple fatigue model: effective baseline effort decays with bout index.
    // bout is 1-based. Each additional bout reduces effective baseline by up to ~10% * (1 - stamina).
    var decay_factor = 1 - (bout - 1) * 0.1 * (1 - stamina);
    var adjusted_baseline = tendency * decay_factor;
    var baseline = Math.min(Math.max(adjusted_baseline, 0.1), 0.99);

    var raw_effort = gaussian(baseline, 0.1);
    return Math.min(Math.max(raw_effort, 0), 1);
  });

  // Effort as a percentage (0–100%).
  var effort_percentage_in_bout = function({boxer, bout}) {
    return 100 * effort_in_bout({boxer: boxer, bout: bout});
  };

  // Bout-level components, each on a "performance points" scale (arbitrary, comparable across components).

  var punching_power_in_bout = mem(function({boxer, bout}) {
    var skill = intrinsic_striking_ability_and_skill({boxer: boxer});
    var effort = effort_in_bout({boxer: boxer, bout: bout});
    var mean = skill * effort;
    return Math.max(gaussian(mean, 10), 0);
  });

  var speed_in_bout = mem(function({boxer, bout}) {
    var skill = intrinsic_striking_ability_and_skill({boxer: boxer});
    var effort = effort_in_bout({boxer: boxer, bout: bout});
    var mean = skill * effort;
    return Math.max(gaussian(mean, 10), 0);
  });

  var defensive_skill_in_bout = mem(function({boxer, bout}) {
    var skill = intrinsic_striking_ability_and_skill({boxer: boxer});
    var effort = effort_in_bout({boxer: boxer, bout: bout});
    var mean = skill * effort;
    return Math.max(gaussian(mean, 10), 0);
  });

  var ring_control_in_bout = mem(function({boxer, bout}) {
    var skill = intrinsic_striking_ability_and_skill({boxer: boxer});
    var effort = effort_in_bout({boxer: boxer, bout: bout});
    var mean = skill * effort;
    return Math.max(gaussian(mean, 10), 0);
  });

  // Overall performance for an individual boxer in a bout.
  // Units: overall performance points; approximate scale similar to component scales (~0–150).
  var boxer_overall_performance_in_bout = function({boxer, bout}) {
    var components = [
      punching_power_in_bout({boxer: boxer, bout: bout}),
      speed_in_bout({boxer: boxer, bout: bout}),
      defensive_skill_in_bout({boxer: boxer, bout: bout}),
      ring_control_in_bout({boxer: boxer, bout: bout})
    ];
    var base = listMean(components);
    // Add judging / random luck noise.
    return Math.max(gaussian(base, 5), 0);
  };

  // Team performance in a bout: aggregate members' overall performance.
  // Units: same overall performance points, averaged across teammates plus small team-level noise.
  var team_overall_performance_in_bout = function({team, bout}) {
    var member_scores = map(
      function(boxer) {
        return boxer_overall_performance_in_bout({boxer: boxer, bout: bout});
      },
      team
    );
    var team_base = listMean(member_scores);
    return Math.max(gaussian(team_base, 3), 0);
  };

  // Margin of victory: team1 score minus team2 score.
  // Units: performance points.
  var win_margin_in_bout = function({team1, team2, bout}) {
    var score1 = team_overall_performance_in_bout({team: team1, bout: bout});
    var score2 = team_overall_performance_in_bout({team: team2, bout: bout});
    return score1 - score2;
  };

  // A team beats another if its team performance is higher.
  var beat = function({team1, team2, bout}) {
    return team_overall_performance_in_bout({team: team1, bout: bout}) >
           team_overall_performance_in_bout({team: team2, bout: bout});
  };

  // Rank of a boxer in intrinsic striking ability and skill among N boxers
  // (expected number of random boxers they are stronger than).
  var intrinsic_striking_ability_and_skill_rank = function({boxer, out_of_n_boxers}) {
    // Generate out_of_n_boxers - 1 random reference boxer IDs.
    var random_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_boxers - 1
    );

    return sum(map(
      function(random_id) {
        return intrinsic_striking_ability_and_skill({boxer: boxer}) >
               intrinsic_striking_ability_and_skill({boxer: random_id});
      },
      random_ids
    ));
  };

  // Predictive function: who would win and by how much (interpreted as probability that Team 2 wins).
  // Returns a number between 0 and 1: fraction of simulated future bouts where Team 2 wins.
  var who_would_win_by_how_much = function({team1, team2, bout}) {
    var num_future_bouts_to_simulate = 100;
    // Use new bout IDs beyond the given bout to avoid reusing specific bout-effort latents.
    var future_bout_ids = mapN(
      function(x) { return uniform(bout + 1, 1000); },
      num_future_bouts_to_simulate
    );

    var team2_wins = sum(map(
      function(sim_bout_id) {
        // Team 2 wins if Team 1 does not beat Team 2 in that simulated bout.
        return !beat({team1: team1, team2: team2, bout: sim_bout_id});
      },
      future_bout_ids
    ));

    return team2_wins / num_future_bouts_to_simulate;
  };

  /////////////////////////////
  // CONDITIONS
  /////////////////////////////

  // In the first bout, Jake beat Ryan.
  condition(beat({team1: ['jake'], team2: ['ryan'], bout: 1}));

  // In the second bout, Leo beat Jake.
  condition(beat({team1: ['leo'], team2: ['jake'], bout: 2}));

  // In the third bout, Jake and Zara beat Ryan and Omar.
  condition(beat({team1: ['jake', 'zara'], team2: ['ryan', 'omar'], bout: 3}));

  // In the fourth bout, Leo and Omar beat Ryan and Zara.
  condition(beat({team1: ['leo', 'omar'], team2: ['ryan', 'zara'], bout: 4}));

  /////////////////////////////
  // QUERIES
  /////////////////////////////

  // Query 1: Out of 100 random boxers, where do you think Leo ranks in terms of intrinsic striking ability and skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Jake put into the third bout?
  // Query 3: In a new bout later this same day between Jake and Leo (Team 1) and Ryan and Omar (Team 2), who would win and by how much?
  // Query 4: In a new bout later this same day between Zara (Team 1) and Ryan (Team 2), who would win and by how much?
  return {
    query1: intrinsic_striking_ability_and_skill_rank({boxer: 'leo', out_of_n_boxers: 100}),
    query2: effort_percentage_in_bout({boxer: 'jake', bout: 3}),
    query3: who_would_win_by_how_much({team1: ['jake', 'leo'], team2: ['ryan', 'omar'], bout: 5}),
    query4: who_would_win_by_how_much({team1: ['zara'], team2: ['ryan'], bout: 6})
  };
};

// Run inference on the model.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-36.json', posterior);