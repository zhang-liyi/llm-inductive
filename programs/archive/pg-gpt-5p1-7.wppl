var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic pitching ability is an attribute of a given pitcher that varies widely. Let's imagine that pitchers generally fall into unskilled, skilled, or particularly skilled categories.
    var intrinsic_pitching_ability = mem(function ({pitcher}) {
      var parameter_low_skill_prior = 0.33;
      var parameter_average_prior = 0.33;
      var parameter_high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var parameter_intrinsic_skill_variance = 10;

      var this_pitcher_skill_average = categorical({ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(this_pitcher_skill_average ,  parameter_intrinsic_skill_variance), 0);
    })

    // A pitcher's intrinsic pitching ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_pitching_ability_rank = function({pitcher, out_of_n_players}) {
        // Generate out_of_n_players - 1 other random player IDs
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        // Total number of random other players this pitcher is more skilled than.
        return sum(map(
            function(random_player_id) {
              return intrinsic_pitching_ability({pitcher: pitcher}) > intrinsic_pitching_ability({pitcher: random_player_id})}, random_player_ids))
    }
    
    // Effort in a game can vary and is influenced by the pitcher's intrinsic ability.
    var effort_in_game = mem(function({pitcher, game}) {
      var base_effort = 50; // Base effort level on a 0-100 scale.
      var effort_variance = 20;
      
      return Math.min(Math.max(gaussian(base_effort, effort_variance), 0), 100);
    })

    // Overall team performance is determined by the combination of the pitcher's intrinsic ability and the effort they exert.
    var overall_team_performance = function({team, pitcher, game}) {
      var pitching_ability = intrinsic_pitching_ability({pitcher: pitcher});
      var effort = effort_in_game({pitcher: pitcher, game: game});
      
      return pitching_ability + effort;
    }

    // A team beats another team in a game if their overall team performance is greater than the other team's overall team performance in that game. 
    var beat = function({team1, pitcher1, team2, pitcher2, game}){
      return overall_team_performance({team: team1, pitcher: pitcher1, game: game}) > overall_team_performance({team: team2, pitcher: pitcher2, game: game});
    }
    
    // A team loses to another team in a given game if they did not beat the team in that game.
    var lost = function({team1, pitcher1, team2, pitcher2, game}){ 
      return !beat({team1: team1, pitcher1: pitcher1, team2: team2, pitcher2: pitcher2, game: game});
    }

    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another. 
    var who_would_win_by_how_much = function({team1, pitcher1, team2, pitcher2, game}) {
      var num_future_games_to_simulate = 100;
      var random_future_game_ids = mapN(function(x) {return uniform(game+1, 1000)}, num_future_games_to_simulate);

      var simulated_games_won_by_team_2 = sum(map(
            function(random_future_game_id) {
              return lost({team1: team1, pitcher1: pitcher1, team2: team2, pitcher2: pitcher2, game: random_future_game_id})}, random_future_game_ids));

      return simulated_games_won_by_team_2 / num_future_games_to_simulate;
    }

  // CONDITIONS
  // In the first game, with Jake pitching for the Falcons and Ryan pitching for the Wolves, the Falcons beat the Wolves.
  condition(beat({team1: 'falcons', pitcher1: 'jake', team2: 'wolves', pitcher2: 'ryan', game: 1}))
  // In the second game, Ryan did not pitch; Jake pitched again for the Falcons, and the Falcons lost to the Bears.
  condition(lost({team1: 'falcons', pitcher1: 'jake', team2: 'bears', pitcher2: null, game: 2}))
  // In the third game, Ryan pitched for the Wolves against the Bears, and the Wolves beat the Bears.
  condition(beat({team1: 'wolves', pitcher1: 'ryan', team2: 'bears', pitcher2: null, game: 3}))

  // QUERIES
  // Query 1: Out of 100 random baseball players in similar roles, where do you think Jake ranks in terms of intrinsic pitching ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Ryan put into the first game?
  // Query 3: In a new game later this same day where Jake starts for the Falcons against Ryan starting for the Bears, who would win and by how much?
  // Query 4: In a new game later this same day where Ryan starts for the Wolves against a Falcons team that does not use Jake, who would win and by how much?
  return {
    query1: intrinsic_pitching_ability_rank({pitcher: 'jake', out_of_n_players: 100}),
    query2: effort_in_game({pitcher: 'ryan', game: 1}),
    query3: who_would_win_by_how_much({team1: 'falcons', pitcher1: 'jake', team2: 'bears', pitcher2: 'ryan', game: 4}),
    query4: who_would_win_by_how_much({team1: 'wolves', pitcher1: 'ryan', team2: 'falcons', pitcher2: null, game: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10000-gpt-5p1-7.json', posterior);