var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  ////////////////////////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////////////////////////////////////////////////

  // Helper: clamp a value between min and max.
  var clamp = function(x, minVal, maxVal) {
    return Math.min(Math.max(x, minVal), maxVal);
  };

  // Helper: mean of a list of numbers.
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // Intrinsic surfing ability is a stable attribute of a given surfer that
  // combines wave-reading, balance, and maneuver skill. It does not change
  // between heats on the same day.
  //
  // We'll model the population as having three broad levels of intrinsic
  // ability (low, average, high), each with its own mean, and then add
  // Gaussian variation within each level.
  //
  // Units: arbitrary ability points on a 0–100 scale.
  var intrinsic_surfing_ability = mem(function({surfer}) {
    var parameter_low_ability_prior = 0.3;
    var parameter_average_ability_prior = 0.4;
    var parameter_high_ability_prior = 0.3;

    var low_ability_mean = 40;     // weaker surfers
    var average_ability_mean = 60; // typical surfers
    var high_ability_mean = 80;    // very good surfers
    var parameter_ability_variance = 10;

    var this_surfer_ability_mean = categorical({
      ps: [parameter_low_ability_prior,
           parameter_average_ability_prior,
           parameter_high_ability_prior],
      vs: [low_ability_mean,
           average_ability_mean,
           high_ability_mean]
    });

    // Add within-level variation and clamp to [0, 100].
    var raw_ability = gaussian(this_surfer_ability_mean, parameter_ability_variance);
    return clamp(raw_ability, 0, 100);
  });

  // Each surfer also has a baseline tendency to put in effort across heats.
  // This baseline effort tendency is stable for the day and may correlate
  // with intrinsic ability.
  //
  // Units: proportion from 0–1 (later converted to 0–100%).
  var baseline_effort_tendency = mem(function({surfer}) {
    var ability = intrinsic_surfing_ability({surfer: surfer});

    // Categorize surfers by ability to set priors on baseline effort.
    // Here we assume more skilled surfers tend to have somewhat higher
    // effective baseline effort on average (confidence, focus, etc.),
    // but lower-ability surfers still sometimes try quite hard.
    var effort;
    if (ability < 45) {
      // Lower-ability: somewhat lower average effort.
      effort = beta(3, 4); // mean ~0.43
    } else if (ability > 75) {
      // High-ability: tends to put in strong effort.
      effort = beta(5, 2); // mean ~0.71
    } else {
      // Medium-ability: moderate effort.
      effort = beta(4, 3); // mean ~0.57
    }
    return effort;
  });

  // Effort in a specific heat is drawn around baseline effort for that surfer,
  // with extra noise to represent situational factors (motivation, nerves, etc.).
  //
  // Units: proportion from 0–1 (later converted to 0–100%).
  var surfer_effort_in_heat = mem(function({surfer, heat}) {
    var baseline = baseline_effort_tendency({surfer: surfer});
    // Add Gaussian noise around the baseline and clamp to [0,1].
    var noisy_effort = gaussian(baseline, 0.15);
    return clamp(noisy_effort, 0, 1);
  });

  // Effort percentage in a specific heat on a 0–100% scale.
  var effort_percentage_in_heat = function({surfer, heat}) {
    return 100 * surfer_effort_in_heat({surfer: surfer, heat: heat});
  };

  // Wave conditions for a given heat are shared across all surfers in that heat.
  // These capture wave size/quality/consistency that affect everyone.
  //
  // Units: multiplicative factor on performance (~0.8 poor, 1.0 average, 1.2 good).
  var heat_wave_conditions = mem(function({heat}) {
    var ps = [0.3, 0.4, 0.3];      // poor, average, good
    var vs = [0.8, 1.0, 1.2];      // effect on scoring
    return categorical({ps: ps, vs: vs});
  });

  // Surfer performance in a heat depends on intrinsic ability, effort in that
  // heat, and the wave conditions, plus some noise (luck, judging idiosyncrasies).
  //
  // We model:
  //   performance ≈ ability * (0.5 + 0.5*effort) * wave_factor + noise
  //
  // Even with low effort, ability still contributes (0.5 factor),
  // but high effort (near 1) nearly doubles that contribution.
  //
  // Units: arbitrary performance points, roughly comparable across heats.
  var surfer_performance_in_heat = function({surfer, heat}) {
    var ability = intrinsic_surfing_ability({surfer: surfer});         // 0–100
    var effort = surfer_effort_in_heat({surfer: surfer, heat: heat});  // 0–1
    var wave_factor = heat_wave_conditions({heat: heat});              // ~0.8–1.2

    var deterministic_part = ability * (0.5 + 0.5 * effort) * wave_factor;
    var noisy_performance = gaussian(deterministic_part, 5); // performance noise
    return Math.max(noisy_performance, 0); // no negative performance
  };

  // Judges translate latent performance into a heat score for each surfer.
  // We'll treat the heat score as a noisy observation of performance itself.
  //
  // Units: arbitrary score points (higher is better).
  var surfer_heat_score = function({surfer, heat}) {
    var performance = surfer_performance_in_heat({surfer: surfer, heat: heat});
    // Judges add some random noise.
    var raw_score = gaussian(performance, 5);
    return Math.max(raw_score, 0);
  };

  // Team heat score is the sum of heat scores of all surfers on the team.
  // Works for individuals (team size 1) and multi-surfer teams.
  //
  // Units: score points, sum across team members.
  var team_heat_score = function({team, heat}) {
    return sum(map(function(surfer) {
      return surfer_heat_score({surfer: surfer, heat: heat});
    }, team));
  };

  // A team beats another team in a heat if its team heat score is higher.
  var beat = function({team1, team2, heat}) {
    return team_heat_score({team: team1, heat: heat}) >
           team_heat_score({team: team2, heat: heat});
  };

  // A team loses if it does not beat the other team.
  var lost = function({team1, team2, heat}) {
    return !beat({team1: team1, team2: team2, heat: heat});
  };

  // Intrinsic surfing ability ranking out of N random surfers:
  // number of random surfers whose ability this surfer exceeds.
  var intrinsic_surfing_ability_rank = function({surfer, out_of_n_surfers}) {
    // Generate out_of_n_surfers - 1 other random surfer IDs.
    var random_surfer_ids = mapN(function(x) { return uniform(0, 10000); },
                                 out_of_n_surfers - 1);

    var this_surfer_ability = intrinsic_surfing_ability({surfer: surfer});

    // Count how many random surfers have lower intrinsic ability.
    return sum(map(function(random_id) {
      return this_surfer_ability >
             intrinsic_surfing_ability({surfer: random_id});
    }, random_surfer_ids));
  };

  // To calculate who would win and by how much, we estimate the probability
  // that Team 2 would win a series of hypothetical future heats with these
  // two teams, using the current posterior over abilities and effort.
  //
  // Return value:
  //   0   => Team 1 would definitely win
  //   1   => Team 2 would definitely win
  //   (in-between) => probability Team 2 wins (how much advantage they have)
  var who_would_win_by_how_much = function({team1, team2, heat}) {
    var num_future_heats_to_simulate = 100;
    // Use new heat IDs beyond the current one so that new efforts and wave
    // conditions are drawn (mem keyed by heat).
    var random_future_heat_ids = mapN(function(x) {
      return uniform(heat + 1, 10000);
    }, num_future_heats_to_simulate);

    // Count how many of these future heats Team 2 wins (i.e., Team 1 loses).
    var heats_won_by_team2 = sum(map(function(random_heat_id) {
      return lost({team1: team1, team2: team2, heat: random_heat_id});
    }, random_future_heat_ids));

    return heats_won_by_team2 / num_future_heats_to_simulate;
  };

  ////////////////////////////////////////////////////////////////////////////
  // CONDITIONS (observed heats)
  ////////////////////////////////////////////////////////////////////////////

  // In the first heat, Isla beat Bruno.
  condition(beat({team1: ['isla'], team2: ['bruno'], heat: 1}))

  // In the second heat, Bruno beat Talia.
  condition(beat({team1: ['bruno'], team2: ['talia'], heat: 2}))

  // In the third heat, Isla, Talia, and Noah beat Bruno, Sera, and Max.
  condition(beat({team1: ['isla', 'talia', 'noah'], team2: ['bruno', 'sera', 'max'], heat: 3}))

  ////////////////////////////////////////////////////////////////////////////
  // QUERIES
  ////////////////////////////////////////////////////////////////////////////

  // Query 1: Out of 100 random surfers, where do you think Isla ranks
  // in terms of intrinsic surfing ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you
  // think Bruno put into the second heat?
  // Query 3: In a new heat later this same day between Isla and Noah
  // (Team 1) and Bruno and Sera (Team 2), who would win and by how much?
  // Query 4: In a new heat later this same day between Talia (Team 1)
  // and Max and Bruno (Team 2), who would win and by how much?
  return {
    query1: intrinsic_surfing_ability_rank({surfer: 'isla', out_of_n_surfers: 100}),
    query2: effort_percentage_in_heat({surfer: 'bruno', heat: 2}),
    query3: who_would_win_by_how_much({team1: ['isla', 'noah'], team2: ['bruno', 'sera'], heat: 4}),
    query4: who_would_win_by_how_much({team1: ['talia'], team2: ['max', 'bruno'], heat: 5})
  };
};

// Run inference to approximate the posterior over the queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-28.json', posterior);