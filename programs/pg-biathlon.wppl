var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  //////////////////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE / LATENT ABILITIES
  //////////////////////////////////////////////////////////////////////

  // Intrinsic strength is a stable athlete-level attribute (endurance/power)
  // on a 0–100 "strength index" scale. Higher = stronger/faster.
  var intrinsic_strength = mem(function({athlete}) {
    // Three broad strength buckets.
    var p_low = 0.3;
    var p_avg = 0.4;
    var p_high = 0.3;

    var low_mean = 40;   // low-strength typical index
    var avg_mean = 60;   // average-strength typical index
    var high_mean = 80;  // high-strength typical index
    var strength_sd = 10; // standard deviation on strength index units

    var bucket_mean = categorical({
      ps: [p_low, p_avg, p_high],
      vs: [low_mean, avg_mean, high_mean]
    });

    var s = gaussian(bucket_mean, strength_sd);
    return Math.min(Math.max(s, 0), 100);
  });

  // Baseline shooting skill is a stable athlete-level attribute (0–100%).
  // Higher = typically more accurate.
  var baseline_shooting_skill = mem(function({athlete}) {
    var base_mean = 70; // typical good competitive biathlete accuracy (%)
    var base_sd = 12;   // standard deviation in percentage points

    var skill = gaussian(base_mean, base_sd);
    // Clamp to a reasonable range of baseline abilities.
    return Math.min(Math.max(skill, 30), 100);
  });

  //////////////////////////////////////////////////////////////////////
  // ROUND-SPECIFIC INDIVIDUAL PERFORMANCE
  //////////////////////////////////////////////////////////////////////

  // Athlete skiing speed in a given round (0–100 speed index, higher = faster).
  // Causally depends on intrinsic_strength plus round-specific noise.
  var athlete_ski_speed_in_round = mem(function({athlete, round}) {
    var base_speed = intrinsic_strength({athlete: athlete});
    var speed_sd = 8; // round-to-round variation in speed index

    var speed = gaussian(base_speed, speed_sd);
    return Math.min(Math.max(speed, 0), 100);
  });

  // Athlete shooting accuracy in a given round (0–100%).
  // Depends on baseline_shooting_skill, with a small modulation by intrinsic_strength,
  // plus round-specific noise.
  var athlete_shooting_accuracy_in_round = mem(function({athlete, round}) {
    var base = baseline_shooting_skill({athlete: athlete});
    var strength = intrinsic_strength({athlete: athlete});

    // Slight effect: stronger athletes are a bit less fatigued when shooting.
    var fatigue_adjustment = 0.1 * (strength - 50); // about -5 to +5 percentage points

    var round_mean = base + fatigue_adjustment;
    var acc_sd = 10; // round-to-round variation in percentage points

    var acc = gaussian(round_mean, acc_sd);
    return Math.min(Math.max(acc, 0), 100);
  });

  // Report shooting accuracy as a percentage (0–100%) in a given round.
  var shooting_accuracy_percentage_in_round = function({athlete, round}) {
    return athlete_shooting_accuracy_in_round({athlete: athlete, round: round});
  };

  //////////////////////////////////////////////////////////////////////
  // TEAM-LEVEL PERFORMANCE IN A ROUND
  //////////////////////////////////////////////////////////////////////

  // Team skiing speed in a round: average of members' speed indices.
  var team_ski_speed_in_round = function({team, round}) {
    return listMean(map(function(athlete) {
      return athlete_ski_speed_in_round({athlete: athlete, round: round});
    }, team));
  };

  // Team shooting accuracy in a round: average of members' shooting accuracies (%).
  var team_shooting_accuracy_in_round = function({team, round}) {
    return listMean(map(function(athlete) {
      return athlete_shooting_accuracy_in_round({athlete: athlete, round: round});
    }, team));
  };

  // Overall team performance score in a round (arbitrary units).
  // Combine ski speed (0–100 index) and shooting accuracy (0–100%) with equal-ish weights.
  // Higher = better performance, more likely to win.
  var overall_team_performance = function({team, round}) {
    var ski = team_ski_speed_in_round({team: team, round: round});
    var shoot = team_shooting_accuracy_in_round({team: team, round: round});

    var weight_ski = 0.6;
    var weight_shoot = 0.4;

    return weight_ski * ski + weight_shoot * shoot;
  };

  //////////////////////////////////////////////////////////////////////
  // OUTCOME RELATIONS
  //////////////////////////////////////////////////////////////////////

  // Team1 beats Team2 in a round if its overall performance score is higher.
  var beat = function({team1, team2, round}) {
    return overall_team_performance({team: team1, round: round}) >
           overall_team_performance({team: team2, round: round});
  };

  // Team1 loses to Team2 in a round if it does not beat Team2.
  var lost = function({team1, team2, round}) {
    return !beat({team1: team1, team2: team2, round: round});
  };

  //////////////////////////////////////////////////////////////////////
  // INTRINSIC STRENGTH RANKING
  //////////////////////////////////////////////////////////////////////

  // Rank of an athlete's intrinsic strength out of N random athletes:
  // how many others they are stronger than (in expectation).
  var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
    var num_others = out_of_n_athletes - 1;

    // Generate num_others random "other athlete" IDs.
    var random_athlete_ids = mapN(function(x) { return uniform(0, 1000); },
                                  num_others);

    // Count how many of these others this athlete is stronger than.
    return sum(map(function(random_id) {
      return intrinsic_strength({athlete: athlete}) >
             intrinsic_strength({athlete: random_id});
    }, random_athlete_ids));
  };

  //////////////////////////////////////////////////////////////////////
  // PREDICTIVE MATCHUP: WHO WOULD WIN AND BY HOW MUCH
  //////////////////////////////////////////////////////////////////////

  // We approximate "who would win and by how much" by the probability that Team 2
  // would win in many simulated future rounds.
  // Return: fraction in [0,1], where 0 = Team 1 almost surely wins,
  // 1 = Team 2 almost surely wins.
  var who_would_win_by_how_much = function({team1, team2, round}) {
    var num_future_rounds_to_simulate = 100;

    // Use unseen round IDs > current round.
    var random_future_round_ids = mapN(function(x) {
      return uniform(round + 1, 1000);
    }, num_future_rounds_to_simulate);

    // Count how many future rounds Team 2 wins (i.e., Team 1 loses).
    var simulated_rounds_won_by_team_2 = sum(map(function(random_future_round_id) {
      return lost({team1: team1, team2: team2, round: random_future_round_id});
    }, random_future_round_ids));

    return simulated_rounds_won_by_team_2 / num_future_rounds_to_simulate;
  };

  //////////////////////////////////////////////////////////////////////
  // CONDITIONS FROM THE SCENARIO (EVIDENCE)
  //////////////////////////////////////////////////////////////////////

  // In the first round, Billy and Emery beat Alice and Sam.
  condition(beat({team1:['billy', 'emery'], team2:['alice', 'sam'], round: 1}));

  // In the second round, Billy and Drew beat Alice and Lou.
  condition(beat({team1:['billy', 'drew'], team2:['alice', 'lou'], round: 2}));

  // In the third round, Billy and Ness beat Alice and Casey.
  condition(beat({team1:['billy', 'ness'], team2:['alice', 'casey'], round: 3}));

  // In the fourth round, Billy and Emery lost to Alice and Sam.
  condition(lost({team1:['billy', 'emery'], team2:['alice', 'sam'], round: 4}));

  //////////////////////////////////////////////////////////////////////
  // QUERIES
  //////////////////////////////////////////////////////////////////////

  // Query 1: Out of 100 random athletes, where do you think Billy ranks in terms of intrinsic strength?
  var q1 = intrinsic_strength_rank({athlete: 'billy', out_of_n_athletes: 100});

  // Query 2: Out of 100 random athletes, where do you think Emery ranks in terms of intrinsic strength?
  var q2 = intrinsic_strength_rank({athlete: 'emery', out_of_n_athletes: 100});

  // Query 3: Out of 100 random athletes, where do you think Alice ranks in terms of intrinsic strength?
  var q3 = intrinsic_strength_rank({athlete: 'alice', out_of_n_athletes: 100});

  // Query 4: On a percentage scale from 0 to 100%, how accurate do you think Billy was at shooting in the fourth round?
  var q4 = shooting_accuracy_percentage_in_round({athlete: 'billy', round: 4});

  // Query 5: On a percentage scale from 0 to 100%, how accurate do you think Emery was at shooting in the fourth round?
  var q5 = shooting_accuracy_percentage_in_round({athlete: 'emery', round: 4});

  // Query 6: On a percentage scale from 0 to 100%, how accurate do you think Alice was at shooting in the fourth round?
  var q6 = shooting_accuracy_percentage_in_round({athlete: 'alice', round: 4});

  // Query 7: In a new round later this same day between Billy and Emery (Team 1) and Drew and Casey (Team 2), who would win and by how much?
  var q7 = who_would_win_by_how_much({team1:['billy', 'emery'], team2:['drew', 'casey'], round: 5});

  // Query 8: In a new round later this same day between Billy and Alice (Team 1) and Emery and Sam (Team 2), who would win and by how much?
  var q8 = who_would_win_by_how_much({team1:['billy', 'alice'], team2:['emery', 'sam'], round: 6});

  return {
    query1: q1,
    query2: q2,
    query3: q3,
    query4: q4,
    query5: q5,
    query6: q6,
    query7: q7,
    query8: q8
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "rejection", samples: 10000});
json.write('inference_results/result-rejection-biathlon.json', posterior);