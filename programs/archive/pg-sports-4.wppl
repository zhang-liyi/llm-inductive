var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic ability is an attribute of a given player that varies widely. Players generally fall into unskilled, skilled, or particularly skilled categories.
    var intrinsic_ability = mem(function ({player}) {
      var parameter_low_ability_prior = 0.33;
      var parameter_average_ability_prior = 0.33;
      var parameter_high_ability_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_ability_mean = 80; 
      var average_ability_mean = 100;
      var high_ability_mean = 140;
      var parameter_intrinsic_ability_variance = 10;

      var this_player_ability_average = categorical({ps: [parameter_low_ability_prior, parameter_average_ability_prior, parameter_high_ability_prior], 
      vs: [low_ability_mean, average_ability_mean, high_ability_mean]});

      return Math.max(gaussian(this_player_ability_average ,  parameter_intrinsic_ability_variance), 0);
    })

    // A player's intrinsic ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_ability_rank = function({player, out_of_n_players}) {
        // Generate out_of_n_players - 1 other random player IDs
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        // Total number of random other players this player is more skilled than.
        return sum(map(
            function(random_player_id) {
              return intrinsic_ability({player: player}) > intrinsic_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a match can vary. We'll assume that players with higher intrinsic ability tend to put in more effort, but this can vary.
    var effort_in_match = mem(function({player, match}) {
      var player_ability = intrinsic_ability({player: player})

      // Prior for effort levels: low, medium, high
      var parameter_low_effort_prior = 
          player_ability > 120 ? 0.1 : // Skilled players rarely put in low effort.
               player_ability < 80 ?  0.6 : // Less skilled players often put in low effort.
                                                     0.3;  // Otherwise, sometimes put in low effort.
      var parameter_medium_effort_prior = player_ability > 120 ? 0.2 : // Skilled players sometimes put in medium effort.
               player_ability < 80 ?  0.3 : // Less skilled players sometimes put in medium effort.
                                                        0.5; // Otherwise, often put in medium effort.
      var parameter_high_effort_prior = player_ability > 120 ? 0.7 :  // Skilled players often put in high effort.
               player_ability < 80 ?  0.1 : // Less skilled players rarely put in high effort.
                                                        0.2; // Otherwise, sometimes put in high effort.

      // Effort level on a 0-100 scale.
      var low_effort_average = 30; 
      var medium_effort_average = 60;
      var high_effort_average = 90;
      var effort_variance = 10;
      
      // Effort level for this player in this match.
      var this_player_effort_average = categorical({ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior], 
      vs: [low_effort_average, medium_effort_average, high_effort_average]});

      return Math.min(Math.max(gaussian(this_player_effort_average, effort_variance), 0), 100)
    })

    // Performance in a match is based on intrinsic ability and effort.
    var performance_in_match = function({player, match}) {
      var player_ability = intrinsic_ability({player: player})
      var player_effort = effort_in_match({player: player, match: match})

      return player_ability + player_effort;
    }
    
    // A team or player beats another in a match if their performance is greater.
    var beat = function({team1, team2, match}){
      var team1_performance = sum(map(function(player) { return performance_in_match({player: player, match: match}) }, team1))
      var team2_performance = sum(map(function(player) { return performance_in_match({player: player, match: match}) }, team2))
      
      return team1_performance > team2_performance;
    }

    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another.
    var who_would_win_by_how_much = function({team1, team2, match}) {
      var num_future_matches_to_simulate = 100;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
              return !beat({team1: team1, team2: team2, match: random_future_match_id})}, random_future_match_ids))

      return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    }

  // CONDITIONS
  // In the first match, Arun beat Ben.
  condition(beat({team1: ['arun'], team2: ['ben'], match: 1}))
  // In the second match, Arun and Dia beat Ben and Cara.
  condition(beat({team1: ['arun', 'dia'], team2: ['ben', 'cara'], match: 2}))
  // In the third match, Ben and Eva beat Arun and Farid.
  condition(beat({team1: ['ben', 'eva'], team2: ['arun', 'farid'], match: 3}))
  // In the fourth match, Cara beat Dia.
  condition(beat({team1: ['cara'], team2: ['dia'], match: 4}))

  // QUERIES
  // Query 1: Out of 100 random badminton players, where do you think Arun ranks in terms of intrinsic badminton ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Ben put into the third match?
  // Query 3: In a new match later this same day between Arun and Cara (Team 1) and Ben and Dia (Team 2), who would win and by how much?
  // Query 4: In a new match later this same day between Arun and Eva (Team 1) and Ben and Farid (Team 2), who would win and by how much?
  return {
    query1: intrinsic_ability_rank({player: 'arun', out_of_n_players: 100}),
    query2: effort_in_match({player: 'ben', match: 3}),
    query3: who_would_win_by_how_much({team1: ['arun', 'cara'], team2: ['ben', 'dia'], match: 5}),
    query4: who_would_win_by_how_much({team1: ['arun', 'eva'], team2: ['ben', 'farid'], match: 6})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-sports-4.json', posterior);