var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Intrinsic playing ability is a stable trait for each player (same for all matches on this day).
  // We'll model a population with low / average / high tiers.
  // Units: arbitrary "skill points" on a scale roughly centered around 100.
  var intrinsic_playing_ability = mem(function({player}) {
    var parameter_low_ability_prior = 0.3;
    var parameter_average_ability_prior = 0.4;
    var parameter_high_ability_prior = 0.3;

    var low_ability_mean = 80;
    var average_ability_mean = 100;
    var high_ability_mean = 120;
    var ability_sd = 10;

    var tier_mean = categorical({
      ps: [parameter_low_ability_prior,
           parameter_average_ability_prior,
           parameter_high_ability_prior],
      vs: [low_ability_mean,
           average_ability_mean,
           high_ability_mean]
    });

    // Intrinsic ability is non-negative.
    return Math.max(gaussian(tier_mean, ability_sd), 0);
  });

  // Effort is match-specific and expressed as a percentage between 0 and 100.
  // Higher-ability players are a bit more likely to put in high effort in competitive matches.
  // Units: effort percentage (0–100%).
  var effort_in_match = mem(function({player, match}) {
    var ability = intrinsic_playing_ability({player: player});

    // Ability-dependent priors over low / medium / high effort.
    var low_effort_prior =
        ability > 120 ? 0.1 :
        ability < 80  ? 0.5 :
                        0.3;
    var medium_effort_prior =
        ability > 120 ? 0.3 :
        ability < 80  ? 0.3 :
                        0.5;
    var high_effort_prior =
        ability > 120 ? 0.6 :
        ability < 80  ? 0.2 :
                        0.2;

    var low_effort_mean = 40;   // 40% typical low effort
    var medium_effort_mean = 65; // 65% typical medium effort
    var high_effort_mean = 90;  // 90% typical high effort
    var effort_sd = 10;

    var effort_mean = categorical({
      ps: [low_effort_prior,
           medium_effort_prior,
           high_effort_prior],
      vs: [low_effort_mean,
           medium_effort_mean,
           high_effort_mean]
    });

    return Math.min(Math.max(gaussian(effort_mean, effort_sd), 0), 100);
  });

  // Movement performance in a match depends on intrinsic ability and effort.
  // Units: performance points on a similar 0–200-ish scale.
  var movement_in_match = function({player, match}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = effort_in_match({player: player, match: match});

    // Give roughly equal weight to ability and effort.
    var base = 0.6 * ability + 0.4 * effort;
    var movement_sd = 10;
    return gaussian(base, movement_sd);
  };

  // Shot precision depends strongly on intrinsic ability, and also on effort (focus).
  var shot_precision_in_match = function({player, match}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = effort_in_match({player: player, match: match});

    var base = 0.7 * ability + 0.3 * effort;
    var precision_sd = 10;
    return gaussian(base, precision_sd);
  };

  // Tactical choices depend on tactical understanding (part of intrinsic ability) and how engaged the player is (effort).
  var tactical_choices_in_match = function({player, match}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = effort_in_match({player: player, match: match});

    var base = 0.65 * ability + 0.35 * effort;
    var tactics_sd = 10;
    return gaussian(base, tactics_sd);
  };

  // Overall match performance is a weighted combination of movement, precision, and tactics.
  // Units: overall performance points.
  var overall_match_performance = function({player, match}) {
    var movement = movement_in_match({player: player, match: match});
    var precision = shot_precision_in_match({player: player, match: match});
    var tactics = tactical_choices_in_match({player: player, match: match});

    // Roughly equal weighting, with slight extra weight on precision and tactics.
    return 0.3 * movement + 0.35 * precision + 0.35 * tactics;
  };

  // Player1 beats Player2 in a given match if their realized performance (plus outcome noise) is higher.
  var beat = function({player1, player2, match}) {
    var perf1 = overall_match_performance({player: player1, match: match});
    var perf2 = overall_match_performance({player: player2, match: match});

    // Extra symmetric outcome noise to capture luck in key points.
    var outcome_noise = gaussian(0, 5);

    return perf1 + outcome_noise > perf2;
  };

  // Intrinsic ability rank out of N players:
  // the number of random other players this player is more skilled than, out of N total.
  var intrinsic_playing_ability_rank = function({player, out_of_n_players}) {
    var focal_ability = intrinsic_playing_ability({player: player});

    // Generate out_of_n_players - 1 other random player IDs.
    var random_player_ids = mapN(function(i) { return uniform(0, 1000000); },
                                 out_of_n_players - 1);

    // Count how many sampled players have lower intrinsic ability.
    return sum(map(
      function(other_id) {
        return focal_ability > intrinsic_playing_ability({player: other_id});
      },
      random_player_ids));
  };

  // Effort percentage in a given match: just expose the latent effort (0–100%).
  var effort_percentage_in_match = function({player, match}) {
    return effort_in_match({player: player, match: match});
  };

  // Hypothetical future match: estimate how likely player2 would win.
  // Return value: fraction between 0 and 1 where 0 = player1 always wins, 1 = player2 always wins.
  var who_would_win_by_how_much = function({player1, player2, match}) {
    var num_future_matches_to_simulate = 100;
    // Use synthetic match IDs beyond the given match index to avoid reusing observed matches.
    var random_future_match_ids = mapN(
      function(i) { return uniform(match + 1, 1000); },
      num_future_matches_to_simulate
    );

    // Count how many simulated matches are wins for player2.
    var simulated_wins_player2 = sum(map(
      function(future_match_id) {
        // player2 beats player1 in this simulated match?
        return beat({player1: player2, player2: player1, match: future_match_id});
      },
      random_future_match_ids));

    return simulated_wins_player2 / num_future_matches_to_simulate;
  };

  // CONDITIONS
  // In the first match, Lina beat Noor.
  condition(beat({player1: 'lina', player2: 'noor', match: 1}))
  // In the second match, Noor beat Priya.
  condition(beat({player1: 'noor', player2: 'priya', match: 2}))
  // In the third match, Samir beat Lina.
  condition(beat({player1: 'samir', player2: 'lina', match: 3}))
  // In the fourth match, Priya beat Samir.
  condition(beat({player1: 'priya', player2: 'samir', match: 4}))

  // QUERIES
  // Query 1: Out of 100 random squash players, where do you think Lina ranks in terms of intrinsic playing ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Samir put into the fourth match?
  // Query 3: In a new match later this same day between Lina and Priya, who would win and by how much?
  // Query 4: In a new match later this same day between Noor and Samir, who would win and by how much?
  return {
    query1: intrinsic_playing_ability_rank({player: 'lina', out_of_n_players: 100}),
    query2: effort_percentage_in_match({player: 'samir', match: 4}),
    query3: who_would_win_by_how_much({player1: 'lina', player2: 'priya', match: 5}),
    query4: who_would_win_by_how_much({player1: 'noor', player2: 'samir', match: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: 'MCMC', samples: 10000});
</START_WEBPPL_MODEL>
json.write('inference_results/result-47.json', posterior);