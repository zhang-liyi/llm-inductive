var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Each skier has a stable intrinsic endurance and strength across all races on this day.
  // Units: arbitrary "endurance-strength performance units" (higher = better).
  var intrinsic_endurance_and_strength = mem(function({skier}) {
    // Three broad ability buckets in the competitive field.
    var parameter_low_ability_prior = 0.33;
    var parameter_average_ability_prior = 0.33;
    var parameter_high_ability_prior = 0.34;

    // Means for each bucket (arbitrary units, centered around ~100).
    var low_ability_mean = 80;
    var average_ability_mean = 100;
    var high_ability_mean = 140;

    // Within-bucket variation (standard deviation in performance units).
    var parameter_ability_sd = 10;

    // Sample which bucket this skier falls in, then a specific ability.
    var this_skier_ability_mean = categorical({
      ps: [parameter_low_ability_prior,
           parameter_average_ability_prior,
           parameter_high_ability_prior],
      vs: [low_ability_mean,
           average_ability_mean,
           high_ability_mean]
    });

    // Ability is positive; truncate at >= 0.
    return Math.max(gaussian(this_skier_ability_mean, parameter_ability_sd), 0);
  });

  // Helper: mean of a list of numbers.
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // Effort in a given race for a skier.
  // Units: fraction of maximum sustainable race effort, in [0,1].
  var effort_in_race = mem(function({skier, race}) {
    // Most competitive racers try fairly hard; center around ~0.75.
    // Use a Beta-like shape via a transformed Gaussian (clamped to [0,1]).
    var base_effort_mean = 0.75;
    var effort_sd = 0.15; // reasonable variation race-to-race

    // Allow a tiny dependence on ability: stronger skiers slightly more likely
    // to sustain higher effective effort.
    var ability = intrinsic_endurance_and_strength({skier: skier});
    var ability_adjustment = (ability - 100) / 400; // small shift, usually in [-0.1,0.1]

    var raw_effort = gaussian(base_effort_mean + ability_adjustment, effort_sd);
    // Clamp to [0,1].
    return Math.min(Math.max(raw_effort, 0), 1);
  });

  // Individual race performance for a skier in a particular race.
  // Units: same arbitrary performance units as intrinsic_endurance_and_strength.
  // Higher performance means faster/stronger in that race.
  var individual_race_performance = mem(function({skier, race}) {
    var ability = intrinsic_endurance_and_strength({skier: skier});
    var effort = effort_in_race({skier: skier, race: race});

    // Base performance: ability scaled by effort.
    var deterministic_part = ability * effort;

    // Random race-day noise: waxing, pacing, micro-conditions, etc.
    var noise_sd = 8; // smaller than between-ability differences
    var noise = gaussian(0, noise_sd);

    return Math.max(deterministic_part + noise, 0);
  });

  // Team race performance aggregates the performances of all team members.
  // For a relay or team race, we take the mean of member performances.
  // Units: same performance units as individual_race_performance.
  var team_race_performance = function({team, race}) {
    var member_performances = map(
      function(skier) {
        return individual_race_performance({skier: skier, race: race});
      },
      team
    );
    return listMean(member_performances);
  };

  // Intrinsic endurance and strength ranking out of N skiers.
  // Returns: expected number of random skiers this skier is better than (0..N-1).
  var intrinsic_endurance_and_strength_rank = function({skier, out_of_n_skiers}) {
    // Generate out_of_n_skiers - 1 random "other skier" IDs.
    var random_skier_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_skiers - 1
    );

    var this_skier_ability = intrinsic_endurance_and_strength({skier: skier});

    // Count how many of these random skiers have lower intrinsic ability.
    return sum(map(
      function(random_skier_id) {
        return this_skier_ability >
               intrinsic_endurance_and_strength({skier: random_skier_id});
      },
      random_skier_ids
    ));
  };

  // Effort percentage in a given race for a skier.
  // Returns: effort as a percentage from 0 to 100.
  var effort_percentage_in_race = function({skier, race}) {
    return 100 * effort_in_race({skier: skier, race: race});
  };

  // Team 1 beats Team 2 in a race if its team race performance is higher.
  var beat = function({team1, team2, race}) {
    return team_race_performance({team: team1, race: race}) >
           team_race_performance({team: team2, race: race});
  };

  // For hypothetical future races, compute how often Team 2 would win.
  // Return value: probability (0 to 1) that Team 2 would win.
  // 0   => Team 1 almost certainly wins
  // 0.5 => roughly even
  // 1   => Team 2 almost certainly wins
  var who_would_win_by_how_much = function({team1, team2, race}) {
    var num_future_races_to_simulate = 100;

    // Simulate new race IDs to avoid clashing with observed races.
    var random_future_race_ids = mapN(
      function(x) { return uniform(race + 1, 1000); },
      num_future_races_to_simulate
    );

    // Count in how many of these simulated races Team 2 beats Team 1.
    var simulated_races_won_by_team2 = sum(map(
      function(random_future_race_id) {
        // Flip team roles so beat() returns "Team 2 beats Team 1".
        return beat({
          team1: team2,
          team2: team1,
          race: random_future_race_id
        });
      },
      random_future_race_ids
    ));

    return simulated_races_won_by_team2 / num_future_races_to_simulate;
  };

  // CONDITIONS
  // In the first race, Anja beat Felix.  
  condition(beat({team1: ['anja'], team2: ['felix'], race: 1}));

  // In the second race, Leo and Anja beat Felix and Nora.  
  condition(beat({team1: ['leo', 'anja'], team2: ['felix', 'nora'], race: 2}));

  // In the third race, Nora beat Leo.  
  condition(beat({team1: ['nora'], team2: ['leo'], race: 3}));

  // In the fourth race, Felix and Nora beat Anja and Mila.
  condition(beat({team1: ['felix', 'nora'], team2: ['anja', 'mila'], race: 4}));

  // QUERIES
  // Query 1: Out of 100 random cross-country skiers, where do you think Felix ranks in terms of intrinsic endurance and strength?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Nora put into the fourth race?  
  // Query 3: In a new race later this same day between Anja and Leo (Team 1) and Felix and Mila (Team 2), who would win and by how much?  
  // Query 4: In a new race later this same day between Nora (Team 1) and Leo and Felix (Team 2, relay), who would win and by how much?
  return {
    query1: intrinsic_endurance_and_strength_rank({skier: 'felix', out_of_n_skiers: 100}),
    query2: effort_percentage_in_race({skier: 'nora', race: 4}),
    query3: who_would_win_by_how_much({team1: ['anja', 'leo'], team2: ['felix', 'mila'], race: 5}),
    query4: who_would_win_by_how_much({team1: ['nora'], team2: ['leo', 'felix'], race: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: 'MCMC', samples: 10000});
json.write('inference_results/result-26.json', posterior);