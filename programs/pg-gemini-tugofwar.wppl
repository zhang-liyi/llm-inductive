var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND
    // In this event, the athletes are competing in matches of tug-of-war.
    // Intrinsic strength is a latent property of an athlete. We assume it follows a distribution similar to skill in the example.
    var intrinsic_strength = mem(function ({athlete}) {
      var parameter_low_strength_prior = 0.33;
      var parameter_average_prior = 0.33;
      var parameter_high_strength_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_strength_mean = 80; 
      var average_strength_mean = 100;
      var high_strength_mean = 140;
      var parameter_intrinsic_strength_variance = 10;

      var this_athlete_strength_average = categorical({ps: [parameter_low_strength_prior, parameter_average_prior, parameter_high_strength_prior], 
      vs: [low_strength_mean, average_strength_mean, high_strength_mean]});

      return Math.max(gaussian(this_athlete_strength_average ,  parameter_intrinsic_strength_variance), 0);
    })

    // Query 1 & 2 ask for rank.
    var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
        // Generate out_of_n_athletes - 1 other random athlete IDs
        var random_athlete_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_athletes - 1)
        
        // Total number of random other athletes this athlete is stronger than.
        return sum(map(
            function(random_athlete_id) {
              return intrinsic_strength({athlete: athlete}) > intrinsic_strength({athlete: random_athlete_id})}, random_athlete_ids))
    }

    // In each round, the team that wins the round depends on how hard the athletes collectively pull, based on their intrinsic strength modulated by other factors including how much effort they put in to that round.
    // Effort is a percentage (0-100).
    // We assume effort depends on intrinsic strength, similar to how dive difficulty depended on skill in the example.
    // Stronger athletes are more likely to put in high effort (competitive), weaker athletes might put in low effort (discouraged).
    var effort_percentage_in_match = mem(function({athlete, match}) {
      var strength = intrinsic_strength({athlete: athlete});

      // Prior that an athlete puts in low, medium, or high effort given their strength.
      var parameter_low_effort_prior = 
          strength > 120 ? 0.05 : // Strong athletes rarely slack off.
               strength < 80 ?  0.8 : // Weak athletes often put in low effort.
                                0.2;  // Average athletes sometimes put in low effort.
      var parameter_medium_effort_prior = 
          strength > 120 ? 0.15 : 
               strength < 80 ?  0.15 : 
                                0.6; // Average athletes usually put in medium effort.
      var parameter_high_effort_prior = 
          strength > 120 ? 0.8 :  // Strong athletes usually put in high effort.
               strength < 80 ?  0.05 : // Weak athletes rarely put in high effort.
                                0.2; 

      // Effort on a 0-100 scale.
      var low_effort_mean = 30; 
      var medium_effort_mean = 60;
      var high_effort_mean = 90;
      var effort_variance = 10;
      
      var this_athlete_effort_mean = categorical({ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior], 
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]});

      return Math.min(Math.max(gaussian(this_athlete_effort_mean, effort_variance), 0), 100)
    })

    // Individual pulling power is intrinsic strength modulated by effort.
    var individual_pulling_power = function({athlete, match}) {
        // Effort is a percentage, so we divide by 100 to get a factor 0-1.
        return intrinsic_strength({athlete: athlete}) * (effort_percentage_in_match({athlete: athlete, match: match}) / 100);
    }

    // Team pulling power is the sum of individual pulling powers.
    var team_pulling_power = function({team, match}) {
        return sum(map(function(athlete) { return individual_pulling_power({athlete: athlete, match: match}) }, team));
    }

    // A team beats another if their total pulling power is greater.
    var beat = function({team1, team2, match}){
      return team_pulling_power({team: team1, match: match} ) > team_pulling_power({team: team2, match: match})
    }
    
    // A team loses if they do not beat the other team.
    var lost = function({team1, team2, match}){ 
      return !beat({team1: team1, team2: team2, match: match})
    }

    // Predict who would win and by how much (likelihood of Team 2 winning).
    var who_would_win_by_how_much = function({team1, team2, match}) {
      // Simulate random possible future matches.
      var num_future_matches_to_simulate = 100;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      // Calculate how many matches Team 2 would have won.
      var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
              return lost({team1: team1, team2: team2, match: random_future_match_id})}, random_future_match_ids))

      // Return the likelihood that team 2 won.
      return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    }

    // CONDITIONS
    // In the first match, Bob and Mary beat Tom and Sue.
    condition(beat({team1:['bob', 'mary'], team2:['tom', 'sue'], match: 1}))
    // In the second match, Sue beat Mary.
    condition(beat({team1:['sue'], team2:['mary'], match: 2}))
    // In the third match, Bob and Sue lost to Tom and Jim. 
    condition(lost({team1:['bob', 'sue'], team2:['tom', 'jim'], match: 3}))
    // In the fourth match, Jim beat Bob.
    condition(beat({team1:['jim'], team2:['bob'], match: 4}))

    // QUERIES
    // Query 1: Out of 100 random athletes, where do you think Bob ranks in terms of intrinsic strength?
    // Query 2: Out of 100 random athletes, where do you think Mary ranks in terms of intrinsic strength?
    // Query 3: On a percentage scale from 0 to 100%, how much effort do you think Jim put into the third match?
    // Query 4: On a percentage scale from 0 to 100%, how much effort do you think Bob put into the first match?
    // Query 5: In a new match later this same day between Bob and Mary (Team 1) and Jim and Sue (Team 2), who would win and by how much?
    // Query 6: In a new match later this same day between Sue and Paul (Team 1) and Jim and Bob (Team 2), who would win and by how much? 
    return {
        query1: intrinsic_strength_rank({athlete: 'bob', out_of_n_athletes: 100}),
        query2: intrinsic_strength_rank({athlete: 'mary', out_of_n_athletes: 100}),
        query3: effort_percentage_in_match({athlete: 'jim', match: 3}),
        query4: effort_percentage_in_match({athlete: 'bob', match: 1}),
        query5: who_would_win_by_how_much({team1:['bob', 'mary'], team2:['jim', 'sue'], match: 5}),
        query6: who_would_win_by_how_much({team1:['sue', 'paul'], team2:['jim', 'bob'], match: 6})
    }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "rejection", samples: 10000});