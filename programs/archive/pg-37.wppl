var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  ////////////////////////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////////////////////////////////////////////////

  // Each fighter has an intrinsic overall fighting skill (0–100 scale).
  // This captures long-run ability in striking, grappling, and endurance.
  var intrinsic_overall_fighting_skill = mem(function({fighter}) {
    var low_mean = 35;    // clearly below-average pro, on 0–100 skill scale
    var mid_mean = 55;    // average pro
    var high_mean = 75;   // clearly above-average pro
    var sd_skill = 8;     // spread within each bucket

    var bucket_mean = categorical({
      ps: [0.25, 0.5, 0.25],  // prior: most are medium, some low/high
      vs: [low_mean, mid_mean, high_mean]
    });

    // Intrinsic skill cannot be negative.
    return Math.max(gaussian(bucket_mean, sd_skill), 0);
  });

  // Helper: mean of a list of numbers.
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // Contest-day effort/intensity for a specific fighter in a specific contest.
  // Effort is on a 0–1 scale here; we convert to 0–100% for reporting.
  //
  // Professional fighters usually try hard (say 60–100%), so we start with a
  // Beta prior concentrated toward higher effort and add a small contest-index
  // fatigue factor (later contests in the day -> slightly less effective effort).
  var effort_in_contest = mem(function({fighter, contest}) {
    // Baseline effort level (0–1).
    var baseEffort = beta({a: 8, b: 2});  // mean ≈ 0.8

    // Simple fatigue factor based on contest index (same for all fighters):
    // contest 1: factor 1.0, contest 4: 0.85, contest 6: 0.75, lower-bounded at 0.6
    var fatigueFactor = Math.max(0.6, 1 - 0.05 * (contest - 1));

    var rawEffort = baseEffort * fatigueFactor;

    // Clamp to [0,1].
    return Math.min(Math.max(rawEffort, 0), 1);
  });

  // Effective fighting ability for a single fighter in a given contest.
  // Units: "effective ability points" on the same 0–100-ish internal scale.
  // Roughly: intrinsic skill × effort (0–1) plus small noise.
  var fighter_effective_fighting_ability_in_contest = function({fighter, contest}) {
    var skill = intrinsic_overall_fighting_skill({fighter: fighter}); // 0–100
    var effort01 = effort_in_contest({fighter: fighter, contest: contest}); // 0–1

    var baseEffect = skill * effort01;

    // Idiosyncratic bout-level randomness (lucky shots, refs, etc.).
    var noise_sd = 5;
    var noisyEffect = baseEffect + gaussian(0, noise_sd);

    // Cannot be negative.
    return Math.max(noisyEffect, 0);
  };

  // Team effective fighting ability in a contest = sum of members' abilities.
  // Units: effective ability points.
  var team_effective_fighting_ability_in_contest = function({team, contest}) {
    return sum(map(
      function(fighter) {
        return fighter_effective_fighting_ability_in_contest({fighter: fighter, contest: contest});
      },
      team
    ));
  };

  // Team performance in contest: team effective ability + small additional noise.
  // Still in "effective ability points".
  var team_performance_in_contest = function({team, contest}) {
    var eff = team_effective_fighting_ability_in_contest({team: team, contest: contest});
    var team_noise_sd = 3;
    return eff + gaussian(0, team_noise_sd);
  };

  // Margin of victory: Team 1 performance − Team 2 performance.
  // Positive margin => Team 1 stronger; negative => Team 2 stronger.
  var margin_of_victory = function({team1, team2, contest}) {
    var perf1 = team_performance_in_contest({team: team1, contest: contest});
    var perf2 = team_performance_in_contest({team: team2, contest: contest});
    return perf1 - perf2;
  };

  // Team 1 beats Team 2 in a contest if margin_of_victory > 0.
  var beat = function({team1, team2, contest}) {
    return margin_of_victory({team1: team1, team2: team2, contest: contest}) > 0;
  };

  // Rank of a fighter's intrinsic overall fighting skill among N fighters.
  // Returns how many of (N-1) random population fighters this fighter is better than.
  var intrinsic_overall_fighting_skill_rank = function({fighter, out_of_n_fighters}) {
    // Generate out_of_n_fighters - 1 other random fighter IDs
    var random_fighter_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_fighters - 1
    );

    return sum(map(
      function(random_id) {
        return intrinsic_overall_fighting_skill({fighter: fighter}) >
               intrinsic_overall_fighting_skill({fighter: random_id});
      },
      random_fighter_ids
    ));
  };

  // Report effort as a percentage (0–100%).
  var effort_percentage_in_contest = function({fighter, contest}) {
    return effort_in_contest({fighter: fighter, contest: contest}) * 100;
  };

  // Predict who would win and by how much (interpreted as probability that
  // Team 2 would win, between 0 and 1).
  //
  // 0   => Team 1 would definitely win
  // 0.5 => essentially a coin flip
  // 1   => Team 2 would definitely win
  //
  // We approximate this by simulating many hypothetical future contests with
  // the same teams but different contest IDs later in the day.
  var who_would_win_by_how_much = function({team1, team2, contest}) {
    var num_future_contests_to_simulate = 100;

    // Simulate contests with random future IDs to avoid overlap with observed ones.
    var random_future_contest_ids = mapN(
      function(x) { return uniform(contest + 1, 1000); },
      num_future_contests_to_simulate
    );

    // Count how many of those hypothetical contests Team 2 wins.
    var simulated_contests_won_by_team2 = sum(map(
      function(random_future_id) {
        // Team 2 wins if Team 1 does NOT beat Team 2 in that hypothetical contest.
        return !beat({team1: team1, team2: team2, contest: random_future_id});
      },
      random_future_contest_ids
    ));

    return simulated_contests_won_by_team2 / num_future_contests_to_simulate;
  };

  ////////////////////////////////////////////////////////////////////////////
  // CONDITIONS (FROM SCENARIO)
  ////////////////////////////////////////////////////////////////////////////

  // In the first contest, Harper beat Blake.  
  condition(beat({team1: ['harper'], team2: ['blake'], contest: 1}));

  // In the second contest, Blake beat Riley.  
  condition(beat({team1: ['blake'], team2: ['riley'], contest: 2}));

  // In the third contest, Riley and Quinn beat Harper and Jordan.  
  condition(beat({team1: ['riley', 'quinn'], team2: ['harper', 'jordan'], contest: 3}));

  // In the fourth contest, Harper beat Riley.
  condition(beat({team1: ['harper'], team2: ['riley'], contest: 4}));

  ////////////////////////////////////////////////////////////////////////////
  // QUERIES
  ////////////////////////////////////////////////////////////////////////////

  // Query 1: Out of 100 random MMA fighters, where do you think Harper ranks
  // in terms of intrinsic overall fighting skill?  
  var q1 = intrinsic_overall_fighting_skill_rank({fighter: 'harper', out_of_n_fighters: 100});

  // Query 2: On a percentage scale from 0 to 100%, how much effort do you
  // think Riley put into the second contest?  
  var q2 = effort_percentage_in_contest({fighter: 'riley', contest: 2});

  // Query 3: In a new contest later this same day between Harper and Quinn
  // (Team 1) and Blake and Riley (Team 2), who would win and by how much?  
  var q3 = who_would_win_by_how_much({team1: ['harper', 'quinn'], team2: ['blake', 'riley'], contest: 5});

  // Query 4: In a new contest later this same day between Jordan (Team 1) and
  // Blake (Team 2), who would win and by how much?
  var q4 = who_would_win_by_how_much({team1: ['jordan'], team2: ['blake'], contest: 6});

  return {
    query1: q1,
    query2: q2,
    query3: q3,
    query4: q4
  };
};

// Now we run the model and collect an estimate of the posterior over queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-37.json', posterior);