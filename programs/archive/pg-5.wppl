var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // Helper: mean of a list of numbers
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // INTRINSIC SKILL
  // Intrinsic volleyball skill (serving, passing, setting, hitting, blocking) for an athlete.
  // Units: arbitrary "skill points", roughly centered around 100, higher = better.
  // Constant across all matches on this day.
  var intrinsic_volleyball_skill = mem(function({athlete}) {
    var parameter_low_skill_prior = 0.3;
    var parameter_average_skill_prior = 0.4;
    var parameter_high_skill_prior = 0.3;

    var low_skill_mean = 70;   // clearly below-average player
    var average_skill_mean = 100; // typical player
    var high_skill_mean = 130; // strong player
    var parameter_intrinsic_skill_sd = 10;

    var skill_bucket_mean = categorical({
      ps: [parameter_low_skill_prior, parameter_average_skill_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    var raw_skill = gaussian(skill_bucket_mean, parameter_intrinsic_skill_sd);

    // Skill cannot be negative.
    return Math.max(raw_skill, 0);
  });

  // MATCH-SPECIFIC EFFORT
  // Effort an athlete puts into a specific match, on 0–100% scale.
  // Varies by match; slightly influenced by intrinsic skill (better players
  // are a bit more likely to sustain high effort).
  var effort_in_match = mem(function({athlete, match}) {
    var base_effort_mean = 70; // 70% typical effort
    var base_effort_sd = 15;   // variation across matches and players

    var skill = intrinsic_volleyball_skill({athlete: athlete});

    // Simple adjustment: high-skill players slightly higher effort on average,
    // low-skill slightly lower, mid-skill near baseline.
    var skill_adjustment =
      skill > 120 ? 10 :
      skill < 80  ? -10 :
                    0;

    var effort_mean = base_effort_mean + skill_adjustment;

    var raw_effort = gaussian(effort_mean, base_effort_sd);
    var clipped_low = Math.max(raw_effort, 0);
    var clipped_effort = Math.min(clipped_low, 100);

    return clipped_effort; // percentage 0–100
  });

  // RANK OF INTRINSIC VOLLEYBALL SKILL
  // Out of N random players from the broader population,
  // how many would this athlete be more skilled than?
  var intrinsic_volleyball_skill_rank = function({athlete, out_of_n_players}) {
    // Generate out_of_n_players - 1 other random athlete IDs
    var random_player_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_players - 1
    );

    var this_skill = intrinsic_volleyball_skill({athlete: athlete});

    // Count how many of these random athletes this athlete beats in intrinsic skill.
    return sum(map(
      function(random_id) {
        return this_skill > intrinsic_volleyball_skill({athlete: random_id});
      },
      random_player_ids
    ));
  };

  // EFFORT PERCENTAGE QUERY (just returns the inferred effort_in_match)
  var effort_percentage_in_match = function({athlete, match}) {
    return effort_in_match({athlete: athlete, match: match}); // already 0–100%
  };

  // TEAM-LEVEL LATENTS

  // Team intrinsic skill in a given match: average of members' intrinsic skills.
  var team_intrinsic_skill_in_match = function({team, match}) {
    var skills = map(function(a) {
      return intrinsic_volleyball_skill({athlete: a});
    }, team);
    return listMean(skills);
  };

  // Team total effort in a given match: average of members' efforts that match.
  // Units: percentage 0–100.
  var team_total_effort_in_match = function({team, match}) {
    var efforts = map(function(a) {
      return effort_in_match({athlete: a, match: match});
    }, team);
    return listMean(efforts);
  };

  // TEAM PERFORMANCE IN A MATCH
  // Overall latent performance, combining intrinsic skill and effort with noise.
  // Units: "performance points" (arbitrary).
  var team_performance_in_match = function({team, match}) {
    var team_skill = team_intrinsic_skill_in_match({team: team, match: match});
    var team_effort = team_total_effort_in_match({team: team, match: match});

    var weight_skill = 0.7;
    var weight_effort = 0.3;
    var noise_sd = 10;

    var mean_performance = weight_skill * team_skill + weight_effort * team_effort;

    return gaussian(mean_performance, noise_sd);
  };

  // MATCH SCORE DIFFERENCE
  // Positive value means team1 outperformed team2 in that match.
  var match_score_difference = function({team1, team2, match}) {
    var perf1 = team_performance_in_match({team: team1, match: match});
    var perf2 = team_performance_in_match({team: team2, match: match});
    return perf1 - perf2;
  };

  // OUTCOME: DID TEAM1 BEAT TEAM2 IN THIS MATCH?
  var beat = function({team1, team2, match}) {
    return team_performance_in_match({team: team1, match: match}) >
           team_performance_in_match({team: team2, match: match});
  };

  // FUTURE MATCH PREDICTION
  // Returns the fraction of simulated future matches (later that same day)
  // in which Team 2 beats Team 1. Interpreted on 0–1 scale (0%–100%):
  //   0   = Team 1 would definitely win
  //   1   = Team 2 would definitely win
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;

    // Simulate matches with new match IDs beyond the given one,
    // so they are not constrained by observed conditions.
    var random_future_match_ids = mapN(
      function(x) { return uniform(match + 1, 1000); },
      num_future_matches_to_simulate
    );

    // For each simulated future match, compute score difference
    // and record whether Team 2 wins (difference < 0).
    var team2_wins_indicators = map(
      function(future_match_id) {
        var diff = match_score_difference({
          team1: team1,
          team2: team2,
          match: future_match_id
        });
        return diff < 0 ? 1 : 0;
      },
      random_future_match_ids
    );

    var team2_win_fraction = sum(team2_wins_indicators) / num_future_matches_to_simulate;

    return team2_win_fraction;
  };

  // CONDITIONS
  // In the first match, Lena, Mia, and Jordan beat Chris, Taylor, and Sam.
  condition(beat({team1: ['lena', 'mia', 'jordan'], team2: ['chris', 'taylor', 'sam'], match: 1}))

  // In the second match, Lena and Chris beat Mia and Taylor.
  condition(beat({team1: ['lena', 'chris'], team2: ['mia', 'taylor'], match: 2}))

  // In the third match, Sam and Taylor beat Jordan and Chris.
  condition(beat({team1: ['sam', 'taylor'], team2: ['jordan', 'chris'], match: 3}))

  // In the fourth match, Mia and Sam beat Lena and Jordan.
  condition(beat({team1: ['mia', 'sam'], team2: ['lena', 'jordan'], match: 4}))

  // QUERIES
  return {
    // Query 1: Out of 100 random volleyball players, where do you think Lena ranks in terms of intrinsic volleyball skill?
    query1: intrinsic_volleyball_skill_rank({athlete: 'lena', out_of_n_players: 100}),

    // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Chris put into the second match?
    query2: effort_percentage_in_match({athlete: 'chris', match: 2}),

    // Query 3: In a new match later this same day between Mia and Jordan (Team 1) and Sam and Chris (Team 2), who would win and by how much?
    // Returns the probability (0–1) that Team 2 (Sam, Chris) would win.
    query3: who_would_win_by_how_much({team1: ['mia', 'jordan'], team2: ['sam', 'chris'], match: 5}),

    // Query 4: In a new match later this same day between Lena, Taylor, and Sam (Team 1) and Jordan, Mia, and Riley (Team 2), who would win and by how much?
    // Returns the probability (0–1) that Team 2 (Jordan, Mia, Riley) would win.
    query4: who_would_win_by_how_much({team1: ['lena', 'taylor', 'sam'], team2: ['jordan', 'mia', 'riley'], match: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-5.json', posterior);