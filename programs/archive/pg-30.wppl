var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Each athlete has a stable intrinsic paddling skill for the whole day.
  // Intrinsic skill: arbitrary scale centered near 100 (higher = better).
  var intrinsic_skill = mem(function({athlete}) {
    var parameter_low_skill_prior = 0.3;
    var parameter_average_prior = 0.5;
    var parameter_high_skill_prior = 0.2;

    var low_skill_mean = 80;   // arbitrary skill units
    var average_skill_mean = 100;
    var high_skill_mean = 125;
    var parameter_intrinsic_skill_sd = 15;  // spread of skill within each bucket

    var cluster_mean = categorical({
      ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    var skill_sample = gaussian(cluster_mean, parameter_intrinsic_skill_sd);
    return Math.max(skill_sample, 40); // avoid extremely low/unrealistic skill
  });

  // Effort is run-specific, on a 0–1 scale (0 = no effort, 1 = maximal effort).
  // It can depend weakly on intrinsic skill (better paddlers may pace differently).
  var effort_in_run = mem(function({athlete, run}) {
    var skill = intrinsic_skill({athlete: athlete});

    // Prior over low / medium / high effort categories.
    // Higher skill → slightly more likely to choose medium/high effort.
    var low_center = 0.4;
    var medium_center = 0.7;
    var high_center = 0.9;

    var p_low = skill > 120 ? 0.2 :
                skill < 80  ? 0.5 :
                              0.3;

    var p_medium = skill > 120 ? 0.4 :
                   skill < 80  ? 0.3 :
                                 0.4;

    var p_high = 1 - p_low - p_medium;

    var effort_category_mean = categorical({
      ps: [p_low, p_medium, p_high],
      vs: [low_center, medium_center, high_center]
    });

    var effort_sample = gaussian(effort_category_mean, 0.07); // effort SD ~ 7 percentage points
    return Math.min(Math.max(effort_sample, 0.1), 1.0); // constrain to [0.1, 1.0]
  });

  // Effort percentage in a run: 0–100%
  var effort_percentage_in_run = function({athlete, run}) {
    return 100 * effort_in_run({athlete: athlete, run: run});
  };

  // Team intrinsic skill: mean of members' intrinsic skills.
  var team_intrinsic_skill = function({team}) {
    return listMean(map(function(a) {
      return intrinsic_skill({athlete: a});
    }, team));
  };

  // Team effort in a run: mean of members' efforts.
  // Effort is dimensionless (0–1).
  var team_effort_in_run = function({team, run}) {
    return listMean(map(function(a) {
      return effort_in_run({athlete: a, run: run});
    }, team));
  };

  // Raw run time in seconds (lower is better).
  // Depends on team intrinsic skill and team effort.
  // Course baseline time for average team (skill ~100, effort ~0.6) is ~110s.
  var raw_run_time = function({team, run}) {
    var skill = team_intrinsic_skill({team: team});
    var effort = team_effort_in_run({team: team, run: run});

    var base_time = 110;       // seconds
    var skill_coef = 0.25;     // seconds faster per point of skill above 100
    var effort_coef = 35;      // seconds faster when going from effort 0 to 1 relative to baseline 0.6

    var mean_time = base_time
                    - skill_coef * (skill - 100)
                    - effort_coef * (effort - 0.6);

    var noisy_time = gaussian(mean_time, 5); // SD 5s due to random factors in whitewater
    return Math.max(noisy_time, 50); // clamp to at least 50s
  };

  // Penalty time in seconds (non-negative, added to raw time).
  // Higher skill → fewer penalties.
  // Very low or very high effort (relative to an "optimal" control level) can increase penalties.
  var penalty_time_in_run = function({team, run}) {
    var skill = team_intrinsic_skill({team: team});
    var effort = team_effort_in_run({team: team, run: run});

    var base_penalty = 18;           // seconds
    var skill_penalty_coef = 0.2;    // seconds less penalty per point of skill above 100
    var optimal_effort = 0.7;        // effort level where penalties tend to be minimized
    var effort_deviation = effort - optimal_effort;

    var mean_penalty = base_penalty
                       - skill_penalty_coef * (skill - 100)
                       + 40 * effort_deviation * effort_deviation; // U-shaped effect of effort

    var noisy_penalty = gaussian(mean_penalty, 5); // SD 5s in penalty variation
    return Math.max(noisy_penalty, 0); // penalties cannot be negative
  };

  // Team run score in seconds = raw time + penalties (lower is better).
  var team_run_score = function({team, run}) {
    return raw_run_time({team: team, run: run}) +
           penalty_time_in_run({team: team, run: run});
  };

  // Team1 beats Team2 in a run if Team1's run score is strictly lower.
  var beat = function({team1, team2, run}) {
    return team_run_score({team: team1, run: run}) <
           team_run_score({team: team2, run: run});
  };

  // Losing is simply not beating.
  var lost = function({team1, team2, run}) {
    return !beat({team1: team1, team2: team2, run: run});
  };

  // Intrinsic skill rank: among out_of_n_athletes random paddlers from the same population,
  // how many would this athlete be more skilled than?
  var intrinsic_skill_rank = function({athlete, out_of_n_athletes}) {
    // Generate out_of_n_athletes - 1 other random athlete IDs
    var random_athlete_ids = mapN(function(x) {
      return uniform(0, 1000);
    }, out_of_n_athletes - 1);

    // Count how many random athletes have lower intrinsic skill than the target athlete.
    var target_skill = intrinsic_skill({athlete: athlete});
    return sum(map(function(other_id) {
      return target_skill > intrinsic_skill({athlete: other_id});
    }, random_athlete_ids));
  };

  // Predict who would win and by how much (interpreted as probability Team 2 wins).
  // 0   → Team 1 would definitely win
  // 1.0 → Team 2 would definitely win
  var who_would_win_by_how_much = function({team1, team2, run}) {
    var num_future_runs_to_simulate = 100;
    // Use future run IDs so we don't collide with already-observed runs (1–4).
    var random_future_run_ids = mapN(function(x) {
      return uniform(run + 1, 1000);
    }, num_future_runs_to_simulate);

    // Count in how many simulated future runs Team 2 wins (Team 1 loses).
    var simulated_runs_won_by_team_2 = sum(map(function(future_run_id) {
      return lost({team1: team1, team2: team2, run: future_run_id});
    }, random_future_run_ids));

    // Return the estimated probability that Team 2 would win.
    return simulated_runs_won_by_team_2 / num_future_runs_to_simulate;
  };

  // CONDITIONS
  // In the first run, Lina beat Boris.
  condition(beat({team1:['lina'], team2:['boris'], run: 1}))

  // In the second run, Lina and Maya beat Boris and Daniel.
  condition(beat({team1:['lina', 'maya'], team2:['boris', 'daniel'], run: 2}))

  // In the third run, Daniel beat Maya.
  condition(beat({team1:['daniel'], team2:['maya'], run: 3}))

  // In the fourth run, Boris and Maya beat Lina and Daniel.
  condition(beat({team1:['boris', 'maya'], team2:['lina', 'daniel'], run: 4}))

  // QUERIES
  // Query 1: Out of 100 random slalom paddlers, where do you think Lina ranks in terms of intrinsic skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Boris put into the fourth run?
  // Query 3: In a new run later this same day between Lina and Daniel (Team 1) and Boris and Maya (Team 2), who would win and by how much?
  // Query 4: In a new run later this same day between Lina (Team 1) and Maya (Team 2), who would win and by how much?
  return {
    query1: intrinsic_skill_rank({athlete: 'lina', out_of_n_athletes: 100}),
    query2: effort_percentage_in_run({athlete: 'boris', run: 4}),
    query3: who_would_win_by_how_much({team1:['lina', 'daniel'], team2:['boris', 'maya'], run: 5}),
    query4: who_would_win_by_how_much({team1:['lina'], team2:['maya'], run: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-30.json', posterior);