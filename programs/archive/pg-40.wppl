var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Fencers compete individually. Each fencer has:
  //  - intrinsic_fencing_skill: stable across all bouts that day (arbitrary "skill points")
  //  - baseline_effort_tendency: typical effort level that day (0–1)
  //  - effort_in_bout: actual effort in a specific bout (0–1), varying around baseline
  // Effective performance in a bout depends on intrinsic skill, bout-specific effort, and noise.
  // The winner is the fencer with higher effective performance (more valid touches / better defense).

  // Intrinsic fencing skill is a stable attribute for each fencer.
  // We'll model a population with three rough skill buckets: low, medium, high.
  // Units: "skill points" on an arbitrary scale centered around ~60.
  var intrinsic_fencing_skill = mem(function({fencer}) {
    var parameter_low_skill_prior = 0.3;
    var parameter_average_skill_prior = 0.4;
    var parameter_high_skill_prior = 0.3;

    // On an arbitrary scale.
    var low_skill_mean = 45;    // weaker local competitors
    var average_skill_mean = 60; // typical club fencer
    var high_skill_mean = 80;   // particularly strong fencers
    var parameter_intrinsic_skill_variance = 12;

    var this_fencer_skill_average = categorical({
      ps: [parameter_low_skill_prior, parameter_average_skill_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    // Skill is non-negative.
    return Math.max(gaussian(this_fencer_skill_average, parameter_intrinsic_skill_variance), 0);
  });

  // Baseline effort tendency: typical effort / focus this fencer puts into bouts that day.
  // Scale: 0–1 (unitless fraction of their maximum effort).
  // We allow it to depend weakly on intrinsic skill:
  //  - lower-skill fencers tend to try harder (higher baseline effort)
  //  - higher-skill fencers are more likely to slack a bit
  var baseline_effort_tendency = mem(function({fencer}) {
    var skill = intrinsic_fencing_skill({fencer: fencer});

    // Classify skill coarsely to set priors over effort levels.
    var is_high_skill = skill > 75;
    var is_low_skill = skill < 50;

    var parameter_low_effort_prior =
      is_high_skill ? 0.5 :
      is_low_skill ? 0.1 :
                     0.2;

    var parameter_medium_effort_prior =
      is_high_skill ? 0.4 :
      is_low_skill ? 0.3 :
                     0.5;

    var parameter_high_effort_prior =
      is_high_skill ? 0.1 :
      is_low_skill ? 0.6 :
                     0.3;

    // Effort levels in 0–1 units.
    var low_effort_mean = 0.3;
    var medium_effort_mean = 0.6;
    var high_effort_mean = 0.9;
    var effort_variance = 0.1;

    var baseline_effort_center = categorical({
      ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior],
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]
    });

    // Truncate to [0, 1].
    return Math.min(Math.max(gaussian(baseline_effort_center, effort_variance), 0), 1);
  });

  // Bout-specific effort for a fencer.
  // Depends on their baseline tendency; fluctuates from bout to bout.
  // Scale: 0–1 (unitless fraction of max effort).
  var effort_in_bout = mem(function({fencer, bout}) {
    var baseline = baseline_effort_tendency({fencer: fencer});
    var bout_effort_sd = 0.15;
    return Math.min(Math.max(gaussian(baseline, bout_effort_sd), 0), 1);
  });

  // Effective fencing performance in a bout.
  // Units: "performance points" roughly corresponding to touch-equivalent strength that bout.
  // performance = intrinsic_skill + alpha * effort + noise
  var effective_fencing_performance_in_bout = function({fencer, bout}) {
    var skill = intrinsic_fencing_skill({fencer: fencer});
    var effort = effort_in_bout({fencer: fencer, bout: bout});

    var alpha_effort_to_performance = 30; // how strongly effort (0–1) translates to performance points
    var noise_sd = 5; // unmodeled randomness (luck, small tactical factors, etc.)

    return skill + alpha_effort_to_performance * effort + gaussian(0, noise_sd);
  };

  // Margin of victory for a bout: fencer1 performance minus fencer2 performance.
  // Units: "touch-equivalent performance points" (positive => fencer1 favored).
  var bout_margin_of_victory = function({fencer1, fencer2, bout}) {
    return effective_fencing_performance_in_bout({fencer: fencer1, bout: bout}) -
           effective_fencing_performance_in_bout({fencer: fencer2, bout: bout});
  };

  // A fencer beats another if their margin_of_victory is positive.
  var beat = function({fencer1, fencer2, bout}) {
    return bout_margin_of_victory({fencer1: fencer1, fencer2: fencer2, bout: bout}) > 0;
  };

  // Losing is simply not beating in that bout.
  var lost = function({fencer1, fencer2, bout}) {
    return !beat({fencer1: fencer1, fencer2: fencer2, bout: bout});
  };

  // Rank a fencer's intrinsic fencing skill among a sample of out_of_n_fencers random fencers.
  // Returns: how many of the other (out_of_n_fencers - 1) sampled fencers they are better than.
  var intrinsic_fencing_skill_rank = function({fencer, out_of_n_fencers}) {
    // Generate out_of_n_fencers - 1 other random fencer IDs
    var random_fencer_ids = mapN(function(x) { return uniform(0, 10000); }, out_of_n_fencers - 1);

    // Count how many random fencers this fencer's intrinsic skill exceeds.
    return sum(map(
      function(random_fencer_id) {
        return intrinsic_fencing_skill({fencer: fencer}) >
               intrinsic_fencing_skill({fencer: random_fencer_id});
      },
      random_fencer_ids));
  };

  // Convert bout-specific effort to a 0–100% scale.
  var effort_percentage_in_bout = function({fencer, bout}) {
    return 100 * effort_in_bout({fencer: fencer, bout: bout});
  };

  // Predict who would win in a (possibly hypothetical) future bout and by how much,
  // represented as the probability that fencer2 wins.
  // Return value: fraction between 0 and 1
  //   0   -> fencer1 would almost certainly win
  //   0.5 -> bout is a toss-up
  //   1   -> fencer2 would almost certainly win
  var who_would_win_by_how_much = function({fencer1, fencer2, bout}) {
    var num_future_bouts_to_simulate = 100;
    var random_future_bout_ids = mapN(function(x) { return uniform(bout + 1, 1000); },
                                      num_future_bouts_to_simulate);

    // Count how many simulated future bouts fencer2 wins (i.e., fencer1 loses).
    var simulated_bouts_won_by_fencer2 = sum(map(
      function(random_future_bout_id) {
        return lost({fencer1: fencer1, fencer2: fencer2, bout: random_future_bout_id});
      },
      random_future_bout_ids));

    return simulated_bouts_won_by_fencer2 / num_future_bouts_to_simulate;
  };

  // CONDITIONS
  // In the first bout, Mara beat Liam.
  condition(beat({fencer1: 'mara', fencer2: 'liam', bout: 1}))

  // In the second bout, Liam beat Noah.
  condition(beat({fencer1: 'liam', fencer2: 'noah', bout: 2}))

  // In the third bout, Mara beat Noah.
  condition(beat({fencer1: 'mara', fencer2: 'noah', bout: 3}))

  // QUERIES
  // Query 1: Out of 100 random fencers, where do you think Mara ranks in terms of intrinsic fencing skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Liam put into the second bout?
  // Query 3: In a new bout later this same day between Mara and Liam, who would win and by how much?
  // Query 4: In a new bout later this same day between Noah and Liam, who would win and by how much?
  return {
    query1: intrinsic_fencing_skill_rank({fencer: 'mara', out_of_n_fencers: 100}),
    query2: effort_percentage_in_bout({fencer: 'liam', bout: 2}),
    query3: who_would_win_by_how_much({fencer1: 'mara', fencer2: 'liam', bout: 4}),
    query4: who_would_win_by_how_much({fencer1: 'noah', fencer2: 'liam', bout: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-40.json', posterior);