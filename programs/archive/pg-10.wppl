var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Each athlete has intrinsic strength, speed, and decision-making that are constant over the day.
  // These are measured on an arbitrary positive scale (roughly centered around 100 units, sd ~ 10–15 units).
  // Athletes also have match-specific effort (0–100%) that modulates how much of their intrinsic ability they realize in that match.

  // Overall skill tier for each athlete (shared across strength, speed, decision-making).
  var overall_skill_tier = mem(function({athlete}) {
    // 3 buckets: low, average, high.
    return categorical({
      ps: [0.3, 0.4, 0.3],
      vs: ['low', 'average', 'high']
    });
  });

  // Helper: map skill tier to mean ability on a 0–200 scale.
  var tier_mean = function(tier) {
    return tier === 'low' ? 85
         : tier === 'average' ? 100
         : 115; // 'high'
  };

  // Intrinsic strength (contact power etc.), in arbitrary units.
  var intrinsic_strength = mem(function({athlete}) {
    var tier = overall_skill_tier({athlete: athlete});
    var mean_strength = tier_mean(tier);
    var strength_sd = 10;
    return Math.max(gaussian(mean_strength, strength_sd), 0);
  });

  // Intrinsic speed (acceleration, open-field pace), in same units.
  var intrinsic_speed = mem(function({athlete}) {
    var tier = overall_skill_tier({athlete: athlete});
    var mean_speed = tier_mean(tier);
    var speed_sd = 10;
    return Math.max(gaussian(mean_speed, speed_sd), 0);
  });

  // Intrinsic decision-making (tactical choices under pressure), in same units.
  var intrinsic_decision_making = mem(function({athlete}) {
    var tier = overall_skill_tier({athlete: athlete});
    var mean_decision = tier_mean(tier);
    var decision_sd = 10;
    return Math.max(gaussian(mean_decision, decision_sd), 0);
  });

  // Combined intrinsic ability (weighted sum of traits).
  var base_ability = function({athlete}) {
    var s = intrinsic_strength({athlete: athlete});
    var v = intrinsic_speed({athlete: athlete});
    var d = intrinsic_decision_making({athlete: athlete});
    // Weights: strength 40%, speed 30%, decision-making 30%.
    return 0.4 * s + 0.3 * v + 0.3 * d;
  };

  // Intrinsic strength ranking out of N random athletes.
  var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
    // Generate out_of_n_athletes - 1 other random athlete IDs.
    var random_athlete_ids = mapN(function(x) { return uniform(0, 1000); }, out_of_n_athletes - 1);

    // Count how many of these others this athlete is stronger than.
    return sum(map(
      function(random_athlete_id) {
        return intrinsic_strength({athlete: athlete}) >
               intrinsic_strength({athlete: random_athlete_id});
      },
      random_athlete_ids));
  };

  // Effort in a given match, in percent [0, 100].
  var effort_in_match = mem(function({athlete, match}) {
    var ability = base_ability({athlete: athlete});

    // Better players are (slightly) more likely to put in high effort,
    // worse players slightly more likely to put in low effort.
    var p_low =
      ability > 115 ? 0.15 :
      ability < 90  ? 0.45 :
                      0.30;
    var p_high =
      ability > 115 ? 0.45 :
      ability < 90  ? 0.20 :
                      0.30;
    var p_med = 1 - p_low - p_high;

    var low_effort_mean = 40;   // 40% effort
    var med_effort_mean = 70;   // 70% effort
    var high_effort_mean = 95;  // 95% effort
    var effort_sd = 10;

    var effort_mean = categorical({
      ps: [p_low, p_med, p_high],
      vs: [low_effort_mean, med_effort_mean, high_effort_mean]
    });

    return Math.min(Math.max(gaussian(effort_mean, effort_sd), 0), 100);
  });

  // Effort percentage in a given match (0–100%).
  var effort_percentage_in_match = function({athlete, match}) {
    return effort_in_match({athlete: athlete, match: match});
  };

  // Player performance score in a specific match (arbitrary units).
  // Depends on intrinsic traits, modulated by effort, plus some randomness.
  var player_performance_in_match = function({athlete, match}) {
    var ability = base_ability({athlete: athlete});
    var effort_pct = effort_in_match({athlete: athlete, match: match}) / 100.0;
    var noise_sd = 10;
    // Performance is ability scaled by effort, plus zero-mean noise.
    return ability * effort_pct + gaussian(0, noise_sd);
  };

  // Team performance in a match is the average of its players' performances.
  var team_performance_in_match = function({team, match}) {
    var performances = map(
      function(athlete) {
        return player_performance_in_match({athlete: athlete, match: match});
      },
      team);
    return listMean(performances);
  };

  // Match performance difference: Team 1 score minus Team 2 score, plus some match-level luck.
  var match_performance_difference = function({team1, team2, match}) {
    var perf1 = team_performance_in_match({team: team1, match: match});
    var perf2 = team_performance_in_match({team: team2, match: match});
    var match_luck_sd = 5;
    return (perf1 - perf2) + gaussian(0, match_luck_sd);
  };

  // Team 1 beats Team 2 in a match if their (luck-adjusted) performance is higher.
  var beat = function({team1, team2, match}) {
    return match_performance_difference({team1: team1, team2: team2, match: match}) > 0;
  };

  // Team 1 loses to Team 2 in a match if they did not beat them.
  var lost = function({team1, team2, match}) {
    return !beat({team1: team1, team2: team2, match: match});
  };

  // Predict who would win and by how much (as probability Team 2 wins, 0–1).
  // 0 => Team 1 almost surely wins, 1 => Team 2 almost surely wins.
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;
    var random_future_match_ids = mapN(
      function(x) { return uniform(match + 1, 1000); },
      num_future_matches_to_simulate);

    // Count how many simulated future matches Team 2 wins.
    var simulated_matches_won_by_team2 = sum(map(
      function(random_future_match_id) {
        return lost({team1: team1, team2: team2, match: random_future_match_id});
      },
      random_future_match_ids));

    return simulated_matches_won_by_team2 / num_future_matches_to_simulate;
  };

  // CONDITIONS
  // In the first match, Dana beat Leo.  
  condition(beat({team1: ['dana'], team2: ['leo'], match: 1}));

  // In the second match, Dana and Morgan beat Leo and Priya.  
  condition(beat({team1: ['dana', 'morgan'], team2: ['leo', 'priya'], match: 2}));

  // In the third match, Morgan lost to Priya.
  condition(lost({team1: ['morgan'], team2: ['priya'], match: 3}));

  // QUERIES
  // Query 1: Out of 100 random rugby athletes, where do you think Dana ranks in terms of intrinsic strength?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Morgan put into the third match?  
  // Query 3: In a new match later this same day between Dana and Morgan (Team 1) and Priya and Taylor (Team 2), who would win and by how much?  
  // Query 4: In a new match later this same day between Leo and Priya (Team 1) and Morgan and Casey (Team 2), who would win and by how much?

  return {
    query1: intrinsic_strength_rank({athlete: 'dana', out_of_n_athletes: 100}),
    query2: effort_percentage_in_match({athlete: 'morgan', match: 3}),
    query3: who_would_win_by_how_much({team1: ['dana', 'morgan'], team2: ['priya', 'taylor'], match: 4}),
    query4: who_would_win_by_how_much({team1: ['leo', 'priya'], team2: ['morgan', 'casey'], match: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10.json', posterior);