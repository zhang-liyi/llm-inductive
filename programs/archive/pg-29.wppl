var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  
  ////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////
  
  // Intrinsic sailing skill is a stable trait for each sailor across all races on this day.
  // Units: "skill points" on an arbitrary scale centered around ~100.
  var intrinsic_sailing_skill = mem(function({sailor}) {
    // Three broad skill buckets in the general fleet.
    var p_low   = 0.3;
    var p_mid   = 0.4;
    var p_high  = 0.3;
    
    var low_mean    = 80;   // weaker club-level sailor
    var mid_mean    = 100;  // solid club/regatta sailor
    var high_mean   = 130;  // very strong racer
    var skill_sd    = 10;
    
    var bucket_mean = categorical({
      ps: [p_low, p_mid, p_high],
      vs: [low_mean, mid_mean, high_mean]
    });
    
    return Math.max(gaussian(bucket_mean, skill_sd), 0);
  });
  
  // Each sailor also has a typical effort tendency (how hard they usually work).
  // Units: percentage effort from 0–100%.
  // More skilled sailors tend to have somewhat higher typical effort.
  var intrinsic_effort_tendency = mem(function({sailor}) {
    var skill = intrinsic_sailing_skill({sailor: sailor});
    
    // Base around 70%, adjusted slightly by skill.
    var raw_mean = 70 + 0.1 * (skill - 100);
    var mean_effort = Math.max(Math.min(raw_mean, 95), 40);
    var sd_effort = 10;
    
    return Math.min(Math.max(gaussian(mean_effort, sd_effort), 0), 100);
  });
  
  // Race conditions (same for all boats in a given race), capturing wind strength,
  // steadiness, and overall difficulty/complexity.
  // Units: "conditions difficulty" on a 0–100 scale (50 ~ typical conditions).
  var race_conditions = mem(function({race}) {
    var mean_conditions = 50;
    var sd_conditions = 15;
    return Math.min(Math.max(gaussian(mean_conditions, sd_conditions), 0), 100);
  });
  
  // Effort a given sailor puts into a specific race.
  // Units: percentage effort from 0–100%.
  var effort_in_race = mem(function({sailor, race}) {
    var tendency = intrinsic_effort_tendency({sailor: sailor});
    var cond = race_conditions({race: race});
    
    // In tougher conditions, sailors may exert slightly more effort on average.
    var adj_mean = tendency + 0.2 * (cond - 50); // small modulation
    var mean_effort = Math.max(Math.min(adj_mean, 100), 0);
    var sd_effort = 8;
    
    return Math.min(Math.max(gaussian(mean_effort, sd_effort), 0), 100);
  });
  
  // Boat coordination in a race: how well the crew works together.
  // Units: "coordination points" on an arbitrary positive scale.
  var boat_coordination_in_race = function({boat, race}) {
    var skills = map(function(sailor) {
      return intrinsic_sailing_skill({sailor: sailor});
    }, boat);
    
    var efforts = map(function(sailor) {
      return effort_in_race({sailor: sailor, race: race});
    }, boat);
    
    var avg_skill = listMean(skills);
    var avg_effort = listMean(efforts);
    var crew_size = boat.length;
    
    // Slight penalty for larger crews (more complex to coordinate),
    // but also more capacity, so penalty is modest.
    var size_penalty = crew_size === 2 ? 0 : 5;
    
    var mean_coord = 0.5 * avg_skill + 0.5 * avg_effort - size_penalty;
    var sd_coord = 10;
    
    return Math.max(gaussian(mean_coord, sd_coord), 0);
  };
  
  // Boat handling performance in a race: execution of maneuvers, trim, steering.
  // Units: "handling performance points".
  var boat_handling_in_race = function({boat, race}) {
    var skills = map(function(sailor) {
      return intrinsic_sailing_skill({sailor: sailor});
    }, boat);
    
    var efforts = map(function(sailor) {
      return effort_in_race({sailor: sailor, race: race});
    }, boat);
    
    var avg_skill = listMean(skills);
    var avg_effort = listMean(efforts);
    var coord = boat_coordination_in_race({boat: boat, race: race});
    var cond = race_conditions({race: race});
    
    // Tougher conditions amplify the importance of skill and coordination.
    var mean_handling =
        0.4 * avg_skill +
        0.3 * avg_effort +
        0.2 * coord +
        0.1 * cond;
    var sd_handling = 10;
    
    return Math.max(gaussian(mean_handling, sd_handling), 0);
  };
  
  // Boat tactical performance in a race: choices of where/when to sail.
  // Units: "tactical performance points".
  var boat_tactics_in_race = function({boat, race}) {
    var skills = map(function(sailor) {
      return intrinsic_sailing_skill({sailor: sailor});
    }, boat);
    
    var efforts = map(function(sailor) {
      return effort_in_race({sailor: sailor, race: race});
    }, boat);
    
    var avg_skill = listMean(skills);
    var avg_effort = listMean(efforts);
    var cond = race_conditions({race: race});
    
    // Tactics lean more on skill and conditions.
    var mean_tactics =
        0.5 * avg_skill +
        0.2 * avg_effort +
        0.3 * cond;
    var sd_tactics = 10;
    
    return Math.max(gaussian(mean_tactics, sd_tactics), 0);
  };
  
  // Overall boat performance in a race: combines handling and tactics.
  // Higher performance => more likely to finish ahead.
  // Units: "overall performance points".
  var overall_boat_performance_in_race = function({boat, race}) {
    var handling = boat_handling_in_race({boat: boat, race: race});
    var tactics = boat_tactics_in_race({boat: boat, race: race});
    
    var mean_perf = 0.6 * handling + 0.4 * tactics;
    var sd_perf = 8;
    
    return Math.max(gaussian(mean_perf, sd_perf), 0);
  };
  
  // Boat1 beats Boat2 in a race if its overall performance is higher.
  var beat = function({boat1, boat2, race}) {
    return overall_boat_performance_in_race({boat: boat1, race: race}) >
           overall_boat_performance_in_race({boat: boat2, race: race});
  };
  
  // Convenience: boat1 loses to boat2 if it does not beat boat2.
  var lost = function({boat1, boat2, race}) {
    return !beat({boat1: boat1, boat2: boat2, race: race});
  };
  
  // Intrinsic sailing skill ranking out of N sailors.
  // Returns expected number of random sailors that this sailor is better than.
  var intrinsic_sailing_skill_rank = function({sailor, out_of_n_sailors}) {
    var random_ids = mapN(function(x) { return uniform(0, 1000); },
                          out_of_n_sailors - 1);
    
    return sum(map(function(random_id) {
      return intrinsic_sailing_skill({sailor: sailor}) >
             intrinsic_sailing_skill({sailor: random_id});
    }, random_ids));
  };
  
  // Effort percentage for a given sailor in a given race.
  // Units: percentage from 0–100%.
  var effort_percentage_in_race = function({sailor, race}) {
    return effort_in_race({sailor: sailor, race: race});
  };
  
  // Predict who would win between two boats in a (hypothetical) future race
  // and by how much, represented as the probability that Boat 2 wins.
  // 0   => Boat 1 would almost certainly win
  // 0.5 => roughly even
  // 1   => Boat 2 would almost certainly win
  var who_would_win_by_how_much = function({boat1, boat2, race}) {
    var num_future_races = 100;
    
    // Simulate future races with new race IDs so they get new conditions, efforts, etc.
    var future_race_ids = mapN(function(x) {
      return uniform(race + 1, 1000);
    }, num_future_races);
    
    var wins_for_boat2 = sum(map(function(fr) {
      return lost({boat1: boat1, boat2: boat2, race: fr});
    }, future_race_ids));
    
    return wins_for_boat2 / num_future_races;
  };
  
  
  ////////////////////////////////
  // CONDITIONS
  ////////////////////////////////
  
  // In the first race, Ava and Finn beat Chloe and Ethan.
  condition(beat({boat1: ['ava', 'finn'], boat2: ['chloe', 'ethan'], race: 1}));
  
  // In the second race, Chloe, Ethan, and Lucas beat Ava, Finn, and Maya.
  condition(beat({boat1: ['chloe', 'ethan', 'lucas'], boat2: ['ava', 'finn', 'maya'], race: 2}));
  
  // In the third race, Maya and Finn beat Lucas and Noah.
  condition(beat({boat1: ['maya', 'finn'], boat2: ['lucas', 'noah'], race: 3}));
  
  // In the fourth race, Noah and Chloe beat Ava and Lucas.
  condition(beat({boat1: ['noah', 'chloe'], boat2: ['ava', 'lucas'], race: 4}));
  
  
  ////////////////////////////////
  // QUERIES
  ////////////////////////////////
  
  // Query 1: Out of 100 random sailors, where do you think Ava ranks in terms of intrinsic sailing skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Lucas put into the second race?
  // Query 3: In a new race later this same day between Ava, Finn, and Maya (Boat 1) and Chloe, Ethan, and Noah (Boat 2), who would win and by how much?
  // Query 4: In a new race later this same day between Lucas and Noah (Boat 1) and Ava and Chloe (Boat 2), who would win and by how much?
  return {
    query1: intrinsic_sailing_skill_rank({sailor: 'ava', out_of_n_sailors: 100}),
    query2: effort_percentage_in_race({sailor: 'lucas', race: 2}),
    query3: who_would_win_by_how_much({boat1: ['ava', 'finn', 'maya'], boat2: ['chloe', 'ethan', 'noah'], race: 5}),
    query4: who_would_win_by_how_much({boat1: ['lucas', 'noah'], boat2: ['ava', 'chloe'], race: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: 'MCMC', samples: 10000});
json.write('inference_results/result-29.json', posterior);