var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Half-court basketball games played on a single day.
  // Each player has:
  //   - intrinsic_basketball_ability: stable across all games that day [ability units]
  //   - effort_in_game: varies by player and game [percent, 0–100]
  // Game outcome depends on team performance, which depends on individual performances
  // (ability * effort + noise). Higher team performance => higher chance to win.

  // Intrinsic basketball ability for each player (fixed across games).
  // Mixture of low / average / high skill, on an arbitrary scale centered near 100.
  var intrinsic_basketball_ability = mem(function({player}) {
    var parameter_low_skill_prior = 0.33;
    var parameter_average_prior = 0.33;
    var parameter_high_skill_prior = 0.34;

    // Ability units (arbitrary):
    var low_skill_mean = 80;
    var average_skill_mean = 100;
    var high_skill_mean = 130;
    var parameter_intrinsic_ability_sd = 10;

    var this_player_ability_mean = categorical({
      ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    // Ensure non-negative ability.
    return Math.max(gaussian(this_player_ability_mean, parameter_intrinsic_ability_sd), 0);
  });

  // Rank a player's intrinsic ability among N random players from the wider population.
  var intrinsic_basketball_ability_rank = function({player, out_of_n_players}) {
    // Generate out_of_n_players - 1 other random player IDs
    var random_player_ids = mapN(function(x) { return uniform(0, 1000); }, out_of_n_players - 1);

    // Count how many of these random players have lower intrinsic ability than `player`.
    return sum(map(
      function(random_player_id) {
        return intrinsic_basketball_ability({player: player}) >
               intrinsic_basketball_ability({player: random_player_id});
      },
      random_player_ids
    ));
  };

  // Effort in a given game for a given player.
  // Effort is a percentage [0–100] and can vary from game to game.
  var effort_in_game = mem(function({player, game}) {
    // Prior over low / medium / high effort in a game.
    var low_effort_mean = 25;   // 25%
    var medium_effort_mean = 60; // 60%
    var high_effort_mean = 90;   // 90%
    var effort_sd = 10;

    var parameter_low_effort_prior = 0.3;
    var parameter_medium_effort_prior = 0.5;
    var parameter_high_effort_prior = 0.2;

    var effort_mean = categorical({
      ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior],
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]
    });

    // Clamp to [0, 100] percent.
    return Math.min(Math.max(gaussian(effort_mean, effort_sd), 0), 100);
  });

  // Effort percentage in a game is just the effort_in_game latent (already 0–100%).
  var effort_percentage_in_game = function({player, game}) {
    return effort_in_game({player: player, game: game});
  };

  // Individual performance in a given game [performance points].
  // Depends on intrinsic ability, effort in that game, and random noise.
  var individual_performance_in_game = mem(function({player, game}) {
    var ability = intrinsic_basketball_ability({player: player}); // ability units
    var effort_percent = effort_in_game({player: player, game: game}); // 0–100
    var effort_fraction = effort_percent / 100;

    // Expected performance increases with both ability and effort.
    // We give everyone at least 50% "baseline" effort even if effort_fraction is low,
    // and scale up to 100% when effort_fraction is high.
    var effective_effort_multiplier = 0.5 + 0.5 * effort_fraction; // in [0.5, 1.0]

    var expected_performance = ability * effective_effort_multiplier;

    // Game-to-game noise (hot/cold streaks, luck, etc.)
    var performance_noise_sd = 15;

    return gaussian(expected_performance, performance_noise_sd);
  });

  // Team performance in a given game is the sum of individual performances of team members.
  var team_performance_in_game = mem(function({team, game}) {
    return sum(map(
      function(player) {
        return individual_performance_in_game({player: player, game: game});
      },
      team
    ));
  });

  // A team beats another if its team performance in that game is higher.
  var beat = function({team1, team2, game}) {
    return team_performance_in_game({team: team1, game: game}) >
           team_performance_in_game({team: team2, game: game});
  };

  // A team loses to another if it does not beat them in that game.
  var lost = function({team1, team2, game}) {
    return !beat({team1: team1, team2: team2, game: game});
  };

  // To answer "who would win and by how much" we approximate the probability
  // that Team 2 would win in a set of hypothetical games with new game IDs.
  // We return the fraction of simulations where Team 2 wins:
  //   0   => Team 1 almost certainly wins
  //   0.5 => roughly even
  //   1   => Team 2 almost certainly wins
  var who_would_win_by_how_much = function({team1, team2, game}) {
    var num_future_games_to_simulate = 100;
    var random_future_game_ids = mapN(
      function(x) { return uniform(game + 1, 1000); },
      num_future_games_to_simulate
    );

    var simulated_games_won_by_team2 = sum(map(
      function(random_future_game_id) {
        return lost({team1: team1, team2: team2, game: random_future_game_id});
      },
      random_future_game_ids
    ));

    return simulated_games_won_by_team2 / num_future_games_to_simulate;
  };

  // CONDITIONS
  // In the first game, Jordan, Riley, and Sam beat Taylor, Casey, and Devon.
  condition(beat({team1: ['jordan', 'riley', 'sam'], team2: ['taylor', 'casey', 'devon'], game: 1}));

  // In the second game, Jordan, Taylor, and Riley beat Sam, Casey, and Devon.
  condition(beat({team1: ['jordan', 'taylor', 'riley'], team2: ['sam', 'casey', 'devon'], game: 2}));

  // In the third game, Devon beat Riley.
  condition(beat({team1: ['devon'], team2: ['riley'], game: 3}));

  // QUERIES
  // Query 1: Out of 100 random basketball players, where do you think Jordan ranks in terms of intrinsic basketball ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Taylor put into the second game?
  // Query 3: In a new game later this same day between Jordan, Sam, and Casey (Team 1) and Taylor, Riley, and Devon (Team 2), who would win and by how much?
  // Query 4: In a new 1-on-1 game later this same day between Jordan (Player 1) and Devon (Player 2), who would win and by how much?
  return {
    query1: intrinsic_basketball_ability_rank({player: 'jordan', out_of_n_players: 100}),
    query2: effort_percentage_in_game({player: 'taylor', game: 2}),
    query3: who_would_win_by_how_much({team1: ['jordan', 'sam', 'casey'], team2: ['taylor', 'riley', 'devon'], game: 4}),
    query4: who_would_win_by_how_much({team1: ['jordan'], team2: ['devon'], game: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-0.json', posterior);