var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic ability is an attribute of a given player that varies widely from player to player. Let's imagine that players generally fall into unskilled, skilled, or particularly skilled buckets.
    var intrinsic_ability = mem(function ({player}) {
      var parameter_low_skill_prior = 0.33;
      var parameter_average_prior = 0.33;
      var parameter_high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var parameter_intrinsic_ability_variance = 10;

      var this_player_skill_average = categorical({ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(this_player_skill_average ,  parameter_intrinsic_ability_variance), 0);
    })

    // A player's intrinsic ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_ability_rank = function({player, out_of_n_players}) {
        // Generate out_of_n_players - 1 other random player IDs
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        // Total number of random other players this player is more skilled than.
        return sum(map(
            function(random_player_id) {
              return intrinsic_ability({player: player}) > intrinsic_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a match can vary and is influenced by the player's intrinsic ability.
    var effort_in_match = mem(function({player, match}) {
      var base_effort = 50; // Base effort level on a 0-100 scale.
      var effort_variance = 20;
      
      return Math.min(Math.max(gaussian(base_effort, effort_variance), 0), 100);
    })

    // A team's performance in a match is determined by the combined intrinsic abilities and efforts of both players.
    var team_performance_in_match = function({team, match}) {
      var average_team_ability = listMean(map(function(player) { return intrinsic_ability({player: player}) }, team))
      var average_team_effort = listMean(map(function(player) { return effort_in_match({player: player, match: match}) }, team))

      return average_team_ability + average_team_effort;
    }
    
    // A team beats another team in a match if their overall team performance is greater than the other team's performance in that match. 
    var beat = function({team1, team2, match}){
      return team_performance_in_match({team: team1, match: match}) > team_performance_in_match({team: team2, match: match})
    }

    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another. 
    var who_would_win_by_how_much = function({team1, team2, match}) {
      var num_future_matches_to_simulate = 300;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
              return !beat({team1: team1, team2: team2, match: random_future_match_id})}, random_future_match_ids))

      return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    }

  // CONDITIONS
  // In the first match, Aria beat Dylan.
  condition(beat({team1: ['aria'], team2: ['dylan'], match: 1}))
  // In the second match, Aria and Felix beat Dylan and Hana.
  condition(beat({team1: ['aria', 'felix'], team2: ['dylan', 'hana'], match: 2}))
  // In the third match, Hana and Dylan beat Felix and Ivy.
  condition(beat({team1: ['hana', 'dylan'], team2: ['felix', 'ivy'], match: 3}))

  // QUERIES
  // Query 1: Out of 100 random badminton players, where do you think Aria ranks in terms of intrinsic badminton ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Hana put into the third match?
  // Query 3: In a new doubles match later this same day between Aria and Hana (Team 1) and Dylan and Felix (Team 2), who would win and by how much?
  // Query 4: In a new doubles match later this same day between Aria and Ivy (Team 1) and Dylan and Hana (Team 2), who would win and by how much?
  return {
    query1: intrinsic_ability_rank({player: 'aria', out_of_n_players: 100}),
    query2: effort_in_match({player: 'hana', match: 3}),
    query3: who_would_win_by_how_much({team1: ['aria', 'hana'], team2: ['dylan', 'felix'], match: 4}),
    query4: who_would_win_by_how_much({team1: ['aria', 'ivy'], team2: ['dylan', 'hana'], match: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 12000, burn: 2000});
json.write('inference_results/result-10000-gpt-5p1-4.json', posterior);