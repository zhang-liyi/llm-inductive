var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic ability is an attribute of a given player that varies widely. Players generally fall into unskilled, skilled, or particularly skilled categories.
    var intrinsic_ability = mem(function ({player}) {
      var low_skill_prior = 0.33;
      var average_skill_prior = 0.33;
      var high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var intrinsic_ability_variance = 10;

      var player_skill_average = categorical({ps: [low_skill_prior, average_skill_prior, high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(player_skill_average, intrinsic_ability_variance), 0);
    })

    // A player's intrinsic ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_ability_rank = function({player, out_of_n_players}) {
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        return sum(map(
            function(random_player_id) {
              return intrinsic_ability({player: player}) > intrinsic_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort a player puts into a match can vary. We'll assume that players with higher intrinsic ability tend to put in more effort.
    var effort_in_match = mem(function({player, match}) {
      var player_skill = intrinsic_ability({player: player})

      var low_effort_prior = player_skill > 120 ? 0.1 : player_skill < 80 ? 0.6 : 0.3;
      var medium_effort_prior = player_skill > 120 ? 0.2 : player_skill < 80 ? 0.3 : 0.5;
      var high_effort_prior = player_skill > 120 ? 0.7 : player_skill < 80 ? 0.1 : 0.2;

      var low_effort_mean = 30; 
      var medium_effort_mean = 60;
      var high_effort_mean = 90;
      var effort_variance = 10;
      
      var effort_average = categorical({ps: [low_effort_prior, medium_effort_prior, high_effort_prior], 
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]});

      return Math.min(Math.max(gaussian(effort_average, effort_variance), 0), 100)
    })

    // Effort percentage in a match
    var effort_percentage_in_match = function({player, match}) {
      return effort_in_match({player: player, match: match});
    }

    // Player performance in a match depends on intrinsic ability and effort.
    var player_performance = function({player, match}) {
      return intrinsic_ability({player: player}) + effort_in_match({player: player, match: match});
    }

    // Team performance in a match depends on the combined performance of both players.
    var team_performance = function({team, match}) {
      return sum(map(function(player) { return player_performance({player: player, match: match}) }, team));
    }

    // A player or team beats another if their performance is greater.
    var beat = function({player1, player2, team1, team2, match}){
      if (player1 && player2) {
        return player_performance({player: player1, match: match}) > player_performance({player: player2, match: match});
      } else {
        return team_performance({team: team1, match: match}) > team_performance({team: team2, match: match});
      }
    }

    // Calculate who would win and by how much.
    var who_would_win_by_how_much = function({team1, team2, match}) {
      var num_future_matches_to_simulate = 100;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
              return !beat({team1: team1, team2: team2, match: random_future_match_id})}, random_future_match_ids))

      return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    }

  // CONDITIONS
  // In the first match, Serena beat Lila.
  condition(beat({player1: 'serena', player2: 'lila', match: 1}))
  // In the second match, Serena and Max beat Lila and Tom.
  condition(beat({team1: ['serena', 'max'], team2: ['lila', 'tom'], match: 2}))
  // In the third match, Tom beat Max.
  condition(beat({player1: 'tom', player2: 'max', match: 3}))
  // In the fourth match, Lila and Nora beat Serena and Tom.
  condition(beat({team1: ['lila', 'nora'], team2: ['serena', 'tom'], match: 4}))

  // QUERIES
  // Query 1: Out of 100 random tennis players, where do you think Serena ranks in terms of intrinsic tennis ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Tom put into the third match?
  // Query 3: In a new match later this same day between Serena and Tom (Team 1) and Lila and Max (Team 2), who would win and by how much?
  // Query 4: In a new match later this same day between Serena and Nora (Team 1) and Max and Tom (Team 2), who would win and by how much?
  return {
    query1: intrinsic_ability_rank({player: 'serena', out_of_n_players: 100}),
    query2: effort_percentage_in_match({player: 'tom', match: 3}),
    query3: who_would_win_by_how_much({team1: ['serena', 'tom'], team2: ['lila', 'max'], match: 5}),
    query4: who_would_win_by_how_much({team1: ['serena', 'nora'], team2: ['max', 'tom'], match: 6})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-sports-2.json', posterior);