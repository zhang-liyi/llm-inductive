var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  // ---------- Utility functions ----------
  // Mean of a list of numbers (unit: same as elements)
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // ---------- Stable individual properties (for this day) ----------
  // Intrinsic strength of a skater (arbitrary strength units, centered ~100)
  // Captures power, technique, and endurance; fixed across races on the same day.
  var intrinsic_strength = mem(function({skater}) {
    // Prior mixture over low / medium / high intrinsic strength
    var p_low = 0.25;
    var p_med = 0.5;
    var p_high = 0.25;

    var low_mean = 80;
    var med_mean = 100;
    var high_mean = 130;
    var strength_sd = 10;

    var class_mean = categorical({
      ps: [p_low, p_med, p_high],
      vs: [low_mean, med_mean, high_mean]
    });

    // Truncate to be non-negative
    return Math.max(gaussian(class_mean, strength_sd), 0);
  });

  // Baseline effort tendency of a skater (% of maximum effort, 0–100)
  // Skaters with higher intrinsic strength tend to have somewhat higher
  // sustainable/baseline competitive efforts.
  var baseline_effort_tendency = mem(function({skater}) {
    var strength = intrinsic_strength({skater: skater});
    // Center baseline around 70–90%, slightly increasing with strength.
    var mean_baseline = 75 + 0.1 * (strength - 100); // roughly 60–90 over range
    var baseline = gaussian(mean_baseline, 8);
    return Math.min(Math.max(baseline, 40), 100); // clamp to [40, 100] %
  });

  // ---------- Race-specific quantities ----------

  // Effort a skater exerts in a specific race (% of maximum effort, 0–100)
  // Depends on their baseline tendency, plus race-to-race variability and a
  // small trend toward lower efforts in later races as they pace themselves.
  var effort_in_race = mem(function({skater, race}) {
    var baseline = baseline_effort_tendency({skater: skater});

    // Small systematic drop in planned effort with race index (pacing),
    // plus random noise.
    var planned_mean = baseline - 2 * Math.max(race - 1, 0);
    var effort = gaussian(planned_mean, 5); // race-to-race variability

    // Clamp to [30, 100] %
    return Math.min(Math.max(effort, 30), 100);
  });

  // Convenience wrapper to return effort percentage directly for queries.
  var effort_percentage_in_race = function({skater, race}) {
    return effort_in_race({skater: skater, race: race});
  };

  // Fatigue level for a skater before a given race (arbitrary fatigue units, 0+)
  // Increases with cumulative effort in earlier races, decreases with between-race recovery.
  var fatigue_level_in_race = mem(function({skater, race}) {
    if (race <= 1) {
      // No prior races on this day
      return 0;
    } else {
      // Recursive accumulation from previous race
      var prev_fatigue = fatigue_level_in_race({skater: skater, race: race - 1});
      var prev_effort = effort_in_race({skater: skater, race: race - 1});

      // Each race adds a fraction of its effort to fatigue, then some recovery happens.
      var fatigue_from_effort = 0.15 * prev_effort;  // how strongly effort creates fatigue
      var recovery = 15;                             // between-race recovery

      var new_fatigue = prev_fatigue + fatigue_from_effort - recovery;
      return Math.max(new_fatigue, 0);
    }
  });

  // Effective skating speed in a race (arbitrary speed units; larger = faster)
  // Depends on intrinsic strength, race effort, and accumulated fatigue.
  var effective_speed_in_race = mem(function({skater, race}) {
    var strength = intrinsic_strength({skater: skater});
    var effort = effort_in_race({skater: skater, race: race});          // 0–100 %
    var fatigue = fatigue_level_in_race({skater: skater, race: race});  // 0+ units

    // Base potential speed increases with both strength and effort.
    var base_speed = strength * (effort / 100);

    // Fatigue reduces effective speed.
    var fatigue_penalty = 0.5 * fatigue;

    var mean_speed = base_speed - fatigue_penalty;

    // Add performance noise (ice, tactics, small errors).
    var speed = gaussian(mean_speed, 5);

    // Ensure some minimum speed
    return Math.max(speed, 10);
  });

  // Individual race time over fixed distance (seconds; smaller = better)
  var individual_race_time = function({skater, race}) {
    var speed = effective_speed_in_race({skater: skater, race: race});
    // Time inversely related to speed; choose scale so typical times are reasonable.
    var base_factor = 1000; // (distance * scaling) in (speed-units * seconds)
    var deterministic_time = base_factor / speed;

    // Small additional timing noise (e.g., start reaction, line timing) in seconds.
    return deterministic_time + gaussian(0, 0.1);
  };

  // Team effective speed in a race (team pursuit: slowest skater often limits time)
  var team_effective_speed_in_race = function({team, race}) {
    var speeds = map(function(skater) {
      return effective_speed_in_race({skater: skater, race: race});
    }, team);

    // Approximate team speed as the minimum of member speeds (last skater across line).
    var team_min_speed = Math.min.apply(null, speeds);
    return team_min_speed;
  };

  // Team race time over fixed distance (seconds; smaller = better)
  var team_race_time = function({team, race}) {
    var team_speed = team_effective_speed_in_race({team: team, race: race});
    var base_factor = 1000; // same scale as individual
    var deterministic_time = base_factor / team_speed;

    // Small team-level variability (coordination, drafting, pacing strategy), in seconds.
    return deterministic_time + gaussian(0, 0.1);
  };

  // Win margin between two teams in a race (seconds)
  // Positive value means Team 1 finished that many seconds ahead of Team 2.
  var win_margin = function({team1, team2, race}) {
    var time1 = team_race_time({team: team1, race: race});
    var time2 = team_race_time({team: team2, race: race});
    // time2 - time1 > 0 => team1 faster by (time2 - time1) seconds.
    return time2 - time1;
  };

  // Team1 beats Team2 in a race if its time is lower (faster).
  var beat = function({team1, team2, race}) {
    var time1 = team_race_time({team: team1, race: race});
    var time2 = team_race_time({team: team2, race: race});
    return time1 < time2;
  };

  // ---------- Ranking intrinsic strength ----------

  // Rank of a skater's intrinsic strength out of N skaters.
  // Returns: expected number of random skaters they are stronger than (0..N-1).
  var intrinsic_strength_rank = function({skater, out_of_n_skaters}) {
    // Generate out_of_n_skaters - 1 random "other" skater IDs
    var random_skater_ids = mapN(function(x) { return uniform(0, 1000); },
                                 out_of_n_skaters - 1);

    // Count how many of these others this skater is stronger than.
    return sum(map(function(random_id) {
      return intrinsic_strength({skater: skater}) >
             intrinsic_strength({skater: random_id});
    }, random_skater_ids));
  };

  // ---------- Predictive query: who would win and by how much ----------

  // We approximate "who would win and by how much" as the probability (0–1)
  // that Team 2 wins in a fresh race later this same day, integrating over
  // possible efforts, fatigue, and performance noise.
  var who_would_win_by_how_much = function({team1, team2, race}) {
    // Simulate many possible future races with new race IDs so that
    // race-specific randomness (effort, fatigue, etc.) is not memoized
    // with any already-observed races.
    var num_future_races_to_simulate = 100;
    var random_future_race_ids = mapN(function(x) {
      return uniform(race + 1, 1000);
    }, num_future_races_to_simulate);

    // Count how many simulated races Team 2 wins (i.e., has lower time).
    var simulated_races_won_by_team2 = sum(map(function(random_future_race_id) {
      // Use win_margin: negative => Team 2 is faster (wins).
      var margin = win_margin({
        team1: team1,
        team2: team2,
        race: random_future_race_id
      });
      return margin < 0;
    }, random_future_race_ids));

    // Return probability (0–1) that Team 2 would win.
    return simulated_races_won_by_team2 / num_future_races_to_simulate;
  };

  // ---------- CONDITIONS (observed race outcomes) ----------

  // In the first race, Jae beat Mila.
  condition(beat({team1: ['jae'], team2: ['mila'], race: 1}));

  // In the second race, Mila and Noor beat Jae and Erik.
  condition(beat({team1: ['mila', 'noor'], team2: ['jae', 'erik'], race: 2}));

  // In the third race, Jae, Mila, and Erik beat Noor, Sora, and Lina.
  condition(beat({team1: ['jae', 'mila', 'erik'], team2: ['noor', 'sora', 'lina'], race: 3}));

  // In the fourth race, Noor beat Erik.
  condition(beat({team1: ['noor'], team2: ['erik'], race: 4}));

  // ---------- QUERIES ----------
  // Query 1: Out of 100 random speed skaters, where do you think Jae ranks in terms of intrinsic strength?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Mila put into the third race?
  // Query 3: In a new race later this same day between Jae and Noor (Team 1) and Mila and Erik (Team 2), who would win and by how much?
  // Query 4: In a new team pursuit later this same day between Jae, Noor, and Mila (Team 1) and Erik, Sora, and Lina (Team 2), who would win and by how much?

  return {
    query1: intrinsic_strength_rank({skater: 'jae', out_of_n_skaters: 100}),
    query2: effort_percentage_in_race({skater: 'mila', race: 3}),
    query3: who_would_win_by_how_much({team1: ['jae', 'noor'], team2: ['mila', 'erik'], race: 5}),
    query4: who_would_win_by_how_much({team1: ['jae', 'noor', 'mila'], team2: ['erik', 'sora', 'lina'], race: 6})
  };
};

// Run the model and collect an approximate posterior over the queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-23.json', posterior);