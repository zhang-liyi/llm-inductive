var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Athletes have stable intrinsic traits (strength, speed, tactical awareness) for the whole day.
  // These traits are on an arbitrary "football ability" scale centered around 100 units.
  // Higher values mean better performance-relevant ability.

  // Intrinsic strength / power (units: arbitrary strength rating, ~0–200).
  var intrinsic_strength = mem(function({athlete}) {
    // Bucket athletes into low / average / high strength.
    var parameter_low_strength_prior = 0.3;
    var parameter_average_strength_prior = 0.4;
    var parameter_high_strength_prior = 0.3;

    var low_strength_mean = 80;
    var average_strength_mean = 100;
    var high_strength_mean = 125;

    var parameter_intrinsic_strength_variance = 10;

    var this_player_strength_average = categorical({
      ps: [parameter_low_strength_prior,
           parameter_average_strength_prior,
           parameter_high_strength_prior],
      vs: [low_strength_mean,
           average_strength_mean,
           high_strength_mean]
    });

    // Strength cannot be negative.
    return Math.max(gaussian(this_player_strength_average,
                             parameter_intrinsic_strength_variance), 0);
  });

  // Intrinsic speed (units: arbitrary speed/agility rating, ~0–200).
  var intrinsic_speed = mem(function({athlete}) {
    var speed_mean = 100;
    var speed_sd = 15;
    return Math.max(gaussian(speed_mean, speed_sd), 0);
  });

  // Intrinsic tactical awareness (units: arbitrary tactical IQ rating, ~0–200).
  var intrinsic_tactical_awareness = mem(function({athlete}) {
    var awareness_mean = 100;
    var awareness_sd = 15;
    return Math.max(gaussian(awareness_mean, awareness_sd), 0);
  });

  // Rank an athlete by intrinsic strength among N random American football athletes.
  // Returns: count of others this athlete is stronger than, out of out_of_n_athletes.
  var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
    // Generate out_of_n_athletes - 1 other random athlete IDs.
    var random_athlete_ids =
        mapN(function(x) { return uniform(0, 1000); }, out_of_n_athletes - 1);

    // Number of random other athletes this athlete is stronger than.
    return sum(map(function(random_athlete_id) {
      return intrinsic_strength({athlete: athlete}) >
             intrinsic_strength({athlete: random_athlete_id});
    }, random_athlete_ids));
  };

  // Game-specific effort (units: percentage, 0–100%).
  // Depends weakly on intrinsic traits: stronger / faster / more tactically aware
  // players tend to put in slightly more consistent effort on average.
  var effort_in_game = mem(function({athlete, game}) {
    var strength = intrinsic_strength({athlete: athlete});
    var speed = intrinsic_speed({athlete: athlete});
    var awareness = intrinsic_tactical_awareness({athlete: athlete});

    // Baseline average effort around 60%, shifted by traits.
    var base_effort_mean = 60;
    var strength_effect = 0.05 * (strength - 100);
    var speed_effect = 0.03 * (speed - 100);
    var awareness_effect = 0.07 * (awareness - 100);

    var this_athlete_effort_mean =
        base_effort_mean + strength_effect + speed_effect + awareness_effect;

    // Actual effort fluctuates around this mean due to motivation, fatigue, etc.
    var effort = gaussian(this_athlete_effort_mean, 15);

    // Clamp to [0, 100].
    return Math.min(Math.max(effort, 0), 100);
  });

  // Effort as a percentage scale from 0 to 100%.
  var effort_percentage_in_game = function({athlete, game}) {
    return effort_in_game({athlete: athlete, game: game});
  };

  // Individual game contribution (units: arbitrary performance units for that game).
  // Depends on intrinsic traits and game-specific effort.
  var individual_game_contribution = function({athlete, game}) {
    var strength = intrinsic_strength({athlete: athlete});
    var speed = intrinsic_speed({athlete: athlete});
    var awareness = intrinsic_tactical_awareness({athlete: athlete});
    var effort = effort_in_game({athlete: athlete, game: game}); // 0–100%

    // Combine intrinsic traits into a potential impact score.
    // Weights reflect importance in small-sided American football.
    var potential =
        0.4 * strength +
        0.3 * speed +
        0.3 * awareness;  // units: performance potential

    // Scale by effort fraction.
    var base_contribution = potential * (effort / 100);

    // Add game noise (luck, small errors, bounces, etc.).
    var noisy_contribution = gaussian(base_contribution, 10);

    return Math.max(noisy_contribution, 0);
  };

  // Team game performance aggregates contributions of all players on the team.
  // Units: arbitrary team performance units (e.g., underlying yards/points potential).
  var team_game_performance = mem(function({team, game}) {
    var contributions = map(function(athlete) {
      return individual_game_contribution({athlete: athlete, game: game});
    }, team);

    // Sum of contributions: larger teams can generate more total performance.
    return sum(contributions);
  });

  // Game point margin (Team1 score - Team2 score), in scoreboard points.
  // Positive margin means Team1 wins; negative means Team2 wins.
  var game_point_margin = function({team1, team2, game}) {
    var perf1 = team_game_performance({team: team1, game: game});
    var perf2 = team_game_performance({team: team2, game: game});
    var perf_diff = perf1 - perf2; // performance units

    // Assume 10 performance units ≈ 1 scoreboard point, with additional noise.
    return gaussian(perf_diff / 10, 3);
  };

  // Team1 beats Team2 in a game if its team performance is higher.
  var beat = function({team1, team2, game}) {
    return team_game_performance({team: team1, game: game}) >
           team_game_performance({team: team2, game: game});
  };

  // Team1 loses to Team2 if it does not beat them.
  var lost = function({team1, team2, game}) {
    return !beat({team1: team1, team2: team2, game: game});
  };

  // "Who would win and by how much" is represented as:
  // 0.0  => Team1 would definitely win
  // 1.0  => Team2 would definitely win
  // We approximate this by simulating many hypothetical future games and
  // returning the fraction of simulations where Team2 wins.
  var who_would_win_by_how_much = function({team1, team2, game}) {
    var num_future_games_to_simulate = 100;

    // Simulate future games using fresh game IDs beyond the given game index.
    var random_future_game_ids =
        mapN(function(x) { return uniform(game + 1, 1000); },
             num_future_games_to_simulate);

    var simulated_games_won_by_team2 =
        sum(map(function(random_future_game_id) {
          return lost({team1: team1,
                       team2: team2,
                       game: random_future_game_id});
        }, random_future_game_ids));

    return simulated_games_won_by_team2 / num_future_games_to_simulate;
  };

  // CONDITIONS
  // In the first game, Jordan beat Blake.
  condition(beat({team1: ['jordan'], team2: ['blake'], game: 1}))

  // In the second game, Jordan and Mia beat Blake and Chris.
  condition(beat({team1: ['jordan', 'mia'], team2: ['blake', 'chris'], game: 2}))

  // In the third game, Blake and Noah beat Mia and Chris.
  condition(beat({team1: ['blake', 'noah'], team2: ['mia', 'chris'], game: 3}))

  // In the fourth game, Noah beat Jordan.
  condition(beat({team1: ['noah'], team2: ['jordan'], game: 4}))

  // QUERIES
  // Query 1: Out of 100 random American football athletes, where do you think Jordan ranks in terms of intrinsic strength?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Blake put into the third game?
  // Query 3: In a new game later this same day between Jordan and Mia (Team 1) and Noah and Chris (Team 2), who would win and by how much?
  // Query 4: In a new game later this same day between Blake and Taylor (Team 1) and Jordan and Mia (Team 2), who would win and by how much?
  return {
    query1: intrinsic_strength_rank({athlete: 'jordan', out_of_n_athletes: 100}),
    query2: effort_percentage_in_game({athlete: 'blake', game: 3}),
    query3: who_would_win_by_how_much({team1: ['jordan', 'mia'], team2: ['noah', 'chris'], game: 5}),
    query4: who_would_win_by_how_much({team1: ['blake', 'taylor'], team2: ['jordan', 'mia'], game: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-11.json', posterior);