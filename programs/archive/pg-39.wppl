var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Each athlete has a stable intrinsic speed and kicking skill for the whole day.
  // Units: arbitrary "skill points" where ~100 is typical competitive level.
  var intrinsic_speed_and_kicking_skill = mem(function({athlete}) {
    var low_prior = 0.3;
    var mid_prior = 0.4;
    var high_prior = 0.3;

    var low_mean = 80;   // below-average competitor
    var mid_mean = 100;  // typical competitive athlete
    var high_mean = 130; // particularly strong athlete
    var skill_sd = 15;

    var mean_skill = categorical({
      ps: [low_prior, mid_prior, high_prior],
      vs: [low_mean, mid_mean, high_mean]
    });

    // Truncate at 0 to avoid negative skill.
    return Math.max(gaussian(mean_skill, skill_sd), 0);
  });

  // Athletes differ in their typical intensity across matches (baseline effort).
  // Units: percent effort from 0–100%.
  var athlete_effort_baseline = mem(function({athlete}) {
    var skill = intrinsic_speed_and_kicking_skill({athlete: athlete});

    // Map skill (capped at 140) to a baseline between about 60% and 90% effort.
    var capped_skill = Math.min(skill, 140);
    return 60 + (capped_skill / 140) * 30;
  });

  // Effort for a specific athlete in a specific match.
  // Depends on the athlete's baseline, with some match-to-match variability.
  // Units: percent effort from 0–100%.
  var effort_in_match = mem(function({athlete, match}) {
    var baseline = athlete_effort_baseline({athlete: athlete});
    var effort_sd = 10;

    // Truncate to [0, 100].
    return Math.max(Math.min(gaussian(baseline, effort_sd), 100), 0);
  });

  // Individual performance in a given match, combining intrinsic skill and effort.
  // Units: performance points on the same rough scale as intrinsic skill.
  var individual_match_performance = function({athlete, match}) {
    var skill = intrinsic_speed_and_kicking_skill({athlete: athlete});
    var effort = effort_in_match({athlete: athlete, match: match}); // 0–100%

    // Effort scales how much of the intrinsic skill is realized.
    // Factor ranges from 0.5 (very low effort) to ~1.0 (very high effort).
    var realization_factor = 0.5 + effort / 200;

    var performance_mean = skill * realization_factor;
    var performance_sd = 10; // noise from timing, luck, etc.

    return gaussian(performance_mean, performance_sd);
  };

  // Team performance is the mean of individual performances for team members.
  var team_performance_in_match = function({team, match}) {
    return listMean(map(function(athlete) {
      return individual_match_performance({athlete: athlete, match: match});
    }, team));
  };

  // Margin of victory: positive if team1 does better, negative if team2 does better.
  // Units: performance points difference.
  var margin_of_victory = function({team1, team2, match}) {
    return team_performance_in_match({team: team1, match: match}) -
           team_performance_in_match({team: team2, match: match});
  };

  // Team1 beats Team2 in a match if their team performance margin is positive.
  var beat = function({team1, team2, match}) {
    return margin_of_victory({team1: team1, team2: team2, match: match}) > 0;
  };

  // Convenience: team1 loses if they do not beat team2.
  var lost = function({team1, team2, match}) {
    return !beat({team1: team1, team2: team2, match: match});
  };

  // Rank an athlete's intrinsic speed and kicking skill among N random athletes.
  // Returns how many of the (N-1) random athletes they are better than.
  var intrinsic_speed_and_kicking_skill_rank = function({athlete, out_of_n_athletes}) {
    var random_athlete_ids = mapN(function(x) { return uniform(0, 1000); },
                                  out_of_n_athletes - 1);

    var target_skill = intrinsic_speed_and_kicking_skill({athlete: athlete});

    return sum(map(function(random_athlete_id) {
      return target_skill >
             intrinsic_speed_and_kicking_skill({athlete: random_athlete_id});
    }, random_athlete_ids));
  };

  // Return effort percentage in a given match for a given athlete.
  // Units: percent from 0–100%.
  var effort_percentage_in_match = function({athlete, match}) {
    return effort_in_match({athlete: athlete, match: match});
  };

  // For a hypothetical future match: estimate how likely Team 2 is to win.
  // Return value between 0 and 1:
  //   0   -> Team 1 would almost certainly win
  //   1   -> Team 2 would almost certainly win
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;
    var random_future_match_ids = mapN(function(x) {
      // Use match indices beyond the given one to avoid overlap with observed matches.
      return uniform(match + 1, 1000);
    }, num_future_matches_to_simulate);

    var simulated_rounds_won_by_team2 = sum(map(function(random_match_id) {
      return lost({team1: team1, team2: team2, match: random_match_id});
    }, random_future_match_ids));

    return simulated_rounds_won_by_team2 / num_future_matches_to_simulate;
  };

  // CONDITIONS
  // In the first match, Min beat Jae.  
  condition(beat({team1: ['min'], team2: ['jae'], match: 1}));

  // In the second match, Lina beat Min.  
  condition(beat({team1: ['lina'], team2: ['min'], match: 2}));

  // In the third match, Min and Arun beat Jae and Nia.  
  condition(beat({team1: ['min', 'arun'], team2: ['jae', 'nia'], match: 3}));

  // In the fourth match, Jae and Lina beat Arun and Nia.
  condition(beat({team1: ['jae', 'lina'], team2: ['arun', 'nia'], match: 4}));

  // QUERIES
  // Query 1: Out of 100 random taekwondo athletes, where do you think Min ranks in terms of intrinsic speed and kicking skill?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Lina put into the second match?  
  // Query 3: In a new match later this same day between Min and Lina (Team 1) and Jae and Arun (Team 2), who would win and by how much?  
  // Query 4: In a new match later this same day between Nia (Team 1) and Min (Team 2), who would win and by how much?
  return {
    query1: intrinsic_speed_and_kicking_skill_rank({athlete: 'min', out_of_n_athletes: 100}),
    query2: effort_percentage_in_match({athlete: 'lina', match: 2}),
    query3: who_would_win_by_how_much({team1: ['min', 'lina'], team2: ['jae', 'arun'], match: 5}),
    query4: who_would_win_by_how_much({team1: ['nia'], team2: ['min'], match: 6})
  };
};

// Run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-39.json', posterior);