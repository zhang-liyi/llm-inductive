var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic vertical jump ability, ball control, and stamina contribute to intrinsic strength.
    var intrinsic_vertical_jump_ability = mem(function({athlete}) {
        return gaussian(50, 10); // Arbitrary scale
    });

    var ball_control = mem(function({athlete}) {
        return gaussian(50, 10); // Arbitrary scale
    });

    var stamina = mem(function({athlete}) {
        return gaussian(50, 10); // Arbitrary scale
    });

    var intrinsic_strength = mem(function({athlete}) {
        return intrinsic_vertical_jump_ability({athlete}) + ball_control({athlete}) + stamina({athlete});
    });

    // Intrinsic strength ranking out of n athletes
    var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
        var random_athlete_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_athletes - 1);
        return sum(map(
            function(random_athlete_id) {
                return intrinsic_strength({athlete: athlete}) > intrinsic_strength({athlete: random_athlete_id});
            }, random_athlete_ids));
    };

    // Tactical effort can vary from match to match
    var tactical_effort = mem(function({athlete, match}) {
        return gaussian(50, 20); // Percentage scale
    });

    var effort_percentage_in_match = function({athlete, match}) {
        return tactical_effort({athlete, match});
    };

    // Overall team performance
    var overall_team_performance = function({team, match}) {
        var team_strength = listMean(map(function(athlete) { return intrinsic_strength({athlete: athlete}) }, team));
        var team_effort = listMean(map(function(athlete) { return tactical_effort({athlete, match}) }, team));
        return team_strength + team_effort;
    };

    // A team beats another team if their overall performance is higher
    var beat = function({team1, team2, match}) {
        return overall_team_performance({team: team1, match: match}) > overall_team_performance({team: team2, match: match});
    };

    // A team narrowly loses if their performance is slightly lower
    var narrowly_lost = function({team1, team2, match}) {
        var performance_diff = overall_team_performance({team: team2, match: match}) - overall_team_performance({team: team1, match: match});
        return performance_diff > 0 && performance_diff < 5; // Arbitrary narrow margin
    };

    // Calculate who would win and by how much
    var who_would_win_by_how_much = function({team1, team2, match}) {
        var num_future_matches_to_simulate = 100;
        var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);
        var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
                return beat({team1: team2, team2: team1, match: random_future_match_id});
            }, random_future_match_ids));
        return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    };

    // CONDITIONS
    // In the first match, Team Sun (Lila and Harper) beat Team Wave (Beck and Nora).
    condition(beat({team1:['lila', 'harper'], team2:['beck', 'nora'], match: 1}));
    // In the second match, Team Sun narrowly lost to Team Coast (Nora and Eli).
    condition(narrowly_lost({team1:['lila', 'harper'], team2:['nora', 'eli'], match: 2}));
    // In the third match, Team Wave beat Team Coast.
    condition(beat({team1:['beck', 'nora'], team2:['nora', 'eli'], match: 3}));

    // QUERIES
    return {
        query1: intrinsic_strength_rank({athlete: 'lila', out_of_n_athletes: 100}),
        query2: effort_percentage_in_match({athlete: 'beck', match: 3}),
        query3: who_would_win_by_how_much({team1:['lila', 'harper'], team2:['beck', 'nora'], match: 4}),
        query4: who_would_win_by_how_much({team1:['nora', 'eli'], team2:['beck', 'nora'], match: 5})
    };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10000-2-2.json', posterior);