var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic soccer ability is an attribute of a given player that varies widely from player to player.
    var intrinsic_soccer_ability = mem(function ({player}) {
      var low_skill_prior = 0.33;
      var average_skill_prior = 0.33;
      var high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var skill_variance = 10;

      var player_skill_average = categorical({ps: [low_skill_prior, average_skill_prior, high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(player_skill_average, skill_variance), 0);
    })

    // A player's intrinsic soccer ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_soccer_ability_rank = function({player, out_of_n_players}) {
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        return sum(map(
            function(random_player_id) {
              return intrinsic_soccer_ability({player: player}) > intrinsic_soccer_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a match is influenced by the player's intrinsic ability.
    var effort_in_match = mem(function({player, match}) {
      var base_effort = 50; // Base effort level
      var effort_variance = 20;
      
      return Math.min(Math.max(gaussian(base_effort + intrinsic_soccer_ability({player: player}) / 10, effort_variance), 0), 100);
    })

    // Effort percentage in a match
    var effort_percentage_in_match = function({player, match}) {
      return effort_in_match({player: player, match: match});
    }

    // Team performance in a match is a combination of intrinsic abilities and efforts of all its players.
    var team_performance_in_match = function({team, match}) {
      var intrinsic_ability_sum = sum(map(function(player) { return intrinsic_soccer_ability({player: player}) }, team));
      var effort_sum = sum(map(function(player) { return effort_in_match({player: player, match: match}) }, team));
      
      return intrinsic_ability_sum + effort_sum;
    }

    // A team beats another team in a match if their performance is greater.
    var beat = function({team1, team2, match}){
      return team_performance_in_match({team: team1, match: match}) > team_performance_in_match({team: team2, match: match});
    }

    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another.
    var who_would_win_by_how_much = function({team1, team2, match}) {
      var num_future_matches_to_simulate = 100;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      var simulated_matches_won_by_team_2 = sum(map(
            function(random_future_match_id) {
              return !beat({team1: team1, team2: team2, match: random_future_match_id})}, random_future_match_ids))

      return simulated_matches_won_by_team_2 / num_future_matches_to_simulate;
    }

  // CONDITIONS
  // In the first match, Team A (captained by Leo) beat Team B (captained by Sam).
  condition(beat({team1:['team_a'], team2:['team_b'], captain1: 'leo', captain2: 'sam', match: 1}))
  // In the second match, Leo and Jamie joined Team B, and Team B beat Team C (captained by Omar).
  condition(beat({team1:['team_b'], team2:['team_c'], added_players:['leo', 'jamie'], captain2: 'omar', match: 2}))
  // In the third match, Sam and Omar played together on Team D and beat Leo’s new team, Team E.
  condition(beat({team1:['team_d'], team2:['team_e'], players1:['sam', 'omar'], captain2: 'leo', match: 3}))

  // QUERIES
  // Query 1: Out of 100 random soccer players, where do you think Leo ranks in terms of intrinsic soccer ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Sam put into the third match?
  // Query 3: In a new match later this same day between Leo, Jamie, and four randomly selected players (Team 1) and Sam, Omar, and four randomly selected players of similar overall level (Team 2), who would win and by how much?
  // Query 4: In a new match later this same day between Leo, Sam, and five randomly selected players (Team 1) and Jamie, Omar, and five randomly selected players (Team 2), who would win and by how much?
  return {
    query1: intrinsic_soccer_ability_rank({player: 'leo', out_of_n_players: 100}),
    query2: effort_percentage_in_match({player: 'sam', match: 3}),
    query3: who_would_win_by_how_much({team1:['leo', 'jamie', 'random4'], team2:['sam', 'omar', 'random4'], match: 4}),
    query4: who_would_win_by_how_much({team1:['leo', 'sam', 'random5'], team2:['jamie', 'omar', 'random5'], match: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10000-gpt-5p1-1.json', posterior);