var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // This is a sprint track meet (100m–400m). Performance in each race depends on:
  // - Intrinsic sprinting ability (stable over the evening)
  // - Derived physical parameters: max speed, acceleration, sprint endurance
  // - Race distance (meters)
  // - Race-specific effort (0–100%) and accumulated fatigue from earlier races
  // - Small random noise in race times
  //
  // Units:
  // - Distance: meters (m)
  // - Time: seconds (s)
  // - Speed: meters per second (m/s)
  // - Acceleration: meters per second squared (m/s^2)
  // - Effort: percentage from 0 to 100 (%)
  // - Fatigue: dimensionless (higher = more fatigued)

  // Intrinsic sprinting ability: a stable latent trait per sprinter.
  // Higher = better sprinter across 100–400m.
  var intrinsic_sprinting_ability = mem(function({sprinter}) {
    var p_low = 0.3;
    var p_mid = 0.4;
    var p_high = 0.3;

    // Ability scale centered around 100 (dimensionless)
    var low_mean = 80;
    var mid_mean = 100;
    var high_mean = 120;
    var ability_sd = 10;

    var ability_mean = categorical({
      ps: [p_low, p_mid, p_high],
      vs: [low_mean, mid_mean, high_mean]
    });

    return Math.max(gaussian(ability_mean, ability_sd), 0);
  });

  // Intrinsic maximum sprinting speed (m/s).
  // Better sprinters tend to have higher max speed.
  var intrinsic_max_speed = mem(function({sprinter}) {
    var ability = intrinsic_sprinting_ability({sprinter: sprinter});
    // Map ability roughly into 8–10.5 m/s range.
    var speed = 8 + 0.03 * (ability - 100);
    return Math.max(speed, 5); // ensure reasonable minimum
  });

  // Intrinsic acceleration capability (m/s^2).
  // Better sprinters tend to accelerate faster off the blocks.
  var intrinsic_acceleration = mem(function({sprinter}) {
    var ability = intrinsic_sprinting_ability({sprinter: sprinter});
    // Typical sprint acceleration around 3–6 m/s^2
    var accel = 3 + 0.05 * (ability - 100);
    return Math.max(accel, 1);
  });

  // Intrinsic sprint endurance (dimensionless).
  // How well the sprinter maintains a high fraction of max speed over 200–400m.
  var intrinsic_sprint_endurance = mem(function({sprinter}) {
    var ability = intrinsic_sprinting_ability({sprinter: sprinter});
    // Map ability into roughly 0.8–1.1
    var endurance = 0.8 + 0.0035 * (ability - 80);
    return Math.max(endurance, 0.5);
  });

  // Baseline fatigue resistance (dimensionless): higher endurance -> more resistance to fatigue.
  var baseline_fatigue_resistance = mem(function({sprinter}) {
    var endurance = intrinsic_sprint_endurance({sprinter: sprinter});
    // Simple monotonic mapping
    return 0.8 + 0.5 * endurance; // typical range ≈ 1.1–1.3
  });

  // Which races each sprinter participates in this evening (race IDs).
  // Based on scenario:
  // Race 1: Liam vs Noah (100m)
  // Race 2: Noah vs Emma (200m)
  // Race 3: Emma vs Liam (400m)
  // Race 4: Emma vs Noah (100m)
  // Race 5 (hypothetical): Emma vs Liam (200m)
  // Race 6 (hypothetical): Noah vs Emma (100m)
  var races_for_sprinter = function(sprinter) {
    return sprinter === 'emma' ? [2, 3, 4, 5, 6] :
           sprinter === 'liam' ? [1, 3, 5] :
           sprinter === 'noah' ? [1, 2, 4, 6] :
           [];
  };

  // Previous races for a given sprinter before a particular race (by race ID).
  var prior_races_for_sprinter = function({sprinter, race}) {
    return filter(
      function(r_prev) { return r_prev < race; },
      races_for_sprinter(sprinter)
    );
  };

  // Deterministic mapping from race ID to distance (meters).
  var race_distance_m = function({race}) {
    return race === 1 ? 100 :
           race === 2 ? 200 :
           race === 3 ? 400 :
           race === 4 ? 100 :
           race === 5 ? 200 :
           race === 6 ? 100 :
           200; // default if needed
  };

  // Fatigue level before a given race for a sprinter.
  // Depends on prior races, their distances, and effective effort in those.
  // Higher cumulative distance * effort => higher fatigue; mitigated by fatigue resistance.
  var fatigue_level_before_race = mem(function({sprinter, race}) {
    var baseline_resistance = baseline_fatigue_resistance({sprinter: sprinter});
    var previous_races = prior_races_for_sprinter({sprinter: sprinter, race: race});

    var contributions = map(function(r_prev) {
      var dist_prev = race_distance_m({race: r_prev}); // meters
      var eff_prev = effective_effort_in_race({
        sprinter: sprinter,
        race: r_prev,
        distance_m: dist_prev
      }); // %
      // Fatigue contribution scaled by distance (relative to 400m) and fraction of effort.
      return (dist_prev / 400) * (eff_prev / 100);
    }, previous_races);

    var raw_fatigue = sum(contributions) / baseline_resistance;
    // Cap fatigue so it doesn't explode.
    return Math.min(raw_fatigue, 3);
  });

  // Intended (chosen) effort level in a specific race, before accounting for physical fatigue limit.
  // 0–100%, depends on distance and (indirectly) on how many races they've already run (via fatigue).
  var intended_effort_in_race = mem(function({sprinter, race, distance_m}) {
    // Baseline target effort as fraction (0–1) depending on distance:
    // Shorter races are often closer to "all-out"; 400m has more pacing.
    var base_fraction =
      distance_m <= 120 ? 0.95 :      // 100m
      distance_m <= 260 ? 0.92 :      // 200m
                           0.88;      // 400m

    // Higher pre-race fatigue slightly reduces *intended* effort.
    var pre_fatigue = fatigue_level_before_race({sprinter: sprinter, race: race});
    var adjusted_fraction = base_fraction - 0.10 * pre_fatigue; // up to ~10–30% lower if very fatigued

    // Add some randomness, then convert to percentage and clamp to [30, 100].
    var noisy_fraction = gaussian(adjusted_fraction, 0.05);
    var intended_pct = Math.min(Math.max(noisy_fraction * 100, 30), 100);
    return intended_pct;
  });

  // Effective effort in race (0–100%), what the runner is actually able to deliver,
  // given intended effort and pre-race fatigue.
  var effective_effort_in_race = mem(function({sprinter, race, distance_m}) {
    var intended = intended_effort_in_race({sprinter: sprinter, race: race, distance_m: distance_m}); // %
    var fatigue = fatigue_level_before_race({sprinter: sprinter, race: race});
    var baseline_resistance = baseline_fatigue_resistance({sprinter: sprinter});

    // Fractional reduction in effort capacity due to fatigue, scaled by resistance.
    var reduction_frac = 0.3 * (fatigue / (baseline_resistance + 0.1)); // typical range: 0–~0.5
    var capacity_factor = Math.max(0.3, 1 - reduction_frac); // maintain at least 30% capacity

    var raw_effective = intended * capacity_factor;

    // Small noise to reflect variability; clamp to [0, 100].
    var noisy_effective = gaussian(raw_effective, 5);
    return Math.min(Math.max(noisy_effective, 0), 100);
  });

  // Race time for a sprinter in a specific race and distance, in seconds.
  // Depends on intrinsic parameters (max speed, acceleration, endurance),
  // distance, and effective effort in that race.
  var race_time_for_sprinter = mem(function({sprinter, race, distance_m}) {
    var max_speed = intrinsic_max_speed({sprinter: sprinter});           // m/s
    var accel = intrinsic_acceleration({sprinter: sprinter});           // m/s^2
    var endurance = intrinsic_sprint_endurance({sprinter: sprinter});   // dimensionless
    var eff_pct = effective_effort_in_race({sprinter: sprinter, race: race, distance_m: distance_m});
    var eff_frac = eff_pct / 100;

    // Weight acceleration more for 100m, endurance more for 400m.
    var accel_weight = distance_m <= 120 ? 0.25 :
                       distance_m <= 260 ? 0.15 :
                                           0.05;
    var endurance_weight = distance_m <= 150 ? 0.05 :
                           distance_m <= 300 ? 0.15 :
                                               0.30;

    // Baseline acceleration ~4 m/s^2, baseline endurance ~1.0
    var accel_factor = 1 + accel_weight * (accel - 4) / 4;
    var endurance_factor = 1 + endurance_weight * (endurance - 1);

    // Effective average speed during the race (m/s).
    var effective_speed = max_speed * eff_frac * accel_factor * endurance_factor;
    effective_speed = Math.max(effective_speed, 0.1); // avoid division by near-zero

    var base_time = distance_m / effective_speed; // seconds
    var time_noise_sd = 0.03 * base_time; // ~3% noise

    var noisy_time = gaussian(base_time, time_noise_sd);
    return Math.max(noisy_time, 0.5); // ensure positive, reasonable lower bound
  });

  // A runner beats another runner in a race if their race time is lower (faster).
  var beat = function({runner1, runner2, race, distance_m}) {
    return race_time_for_sprinter({sprinter: runner1, race: race, distance_m: distance_m}) <
           race_time_for_sprinter({sprinter: runner2, race: race, distance_m: distance_m});
  };

  // Intrinsic sprinting ability rank: out of N random sprinters,
  // how many would this sprinter be better than (in terms of intrinsic sprinting ability)?
  var intrinsic_sprinting_ability_rank = function({sprinter, out_of_n_sprinters}) {
    // Generate out_of_n_sprinters - 1 random sprinter IDs
    var random_ids = mapN(function(i) { return uniform(0, 100000); }, out_of_n_sprinters - 1);

    return sum(map(function(random_id) {
      return intrinsic_sprinting_ability({sprinter: sprinter}) >
             intrinsic_sprinting_ability({sprinter: random_id});
    }, random_ids));
  };

  // Effort percentage in a given race (0–100%).
  var effort_percentage_in_race = function({sprinter, race, distance_m}) {
    return effective_effort_in_race({sprinter: sprinter, race: race, distance_m: distance_m});
  };

  // Given two runners in a specified race and distance,
  // return which side is more likely to win and "by how much" as a probability.
  // 0 means runner1 definitely wins, 1 means runner2 definitely wins.
  // (The posterior expectation of this value is the inferred win probability for runner2.)
  var who_would_win_by_how_much = function({runner1, runner2, race, distance_m}) {
    return beat({runner1: runner1, runner2: runner2, race: race, distance_m: distance_m}) ? 0 : 1;
  };

  // CONDITIONS
  // In the first race, a 100m dash, Liam beat Noah.
  condition(beat({runner1: 'liam', runner2: 'noah', race: 1, distance_m: 100}))

  // In the second race, a 200m sprint, Noah beat Emma.
  condition(beat({runner1: 'noah', runner2: 'emma', race: 2, distance_m: 200}))

  // In the third race, a 400m race, Emma beat Liam.
  condition(beat({runner1: 'emma', runner2: 'liam', race: 3, distance_m: 400}))

  // In the fourth race, a 100m dash, Emma beat Noah.
  condition(beat({runner1: 'emma', runner2: 'noah', race: 4, distance_m: 100}))

  // QUERIES
  // Query 1: Out of 100 random sprinters, where do you think Emma ranks in terms of intrinsic sprinting ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Liam put into the third race?
  // Query 3: In a new 200m sprint later this same evening between Emma and Liam, who would win and by how much?
  // Query 4: In a new 100m dash later this same evening between Noah and Emma, who would win and by how much?
  return {
    query1: intrinsic_sprinting_ability_rank({sprinter: 'emma', out_of_n_sprinters: 100}),
    query2: effort_percentage_in_race({sprinter: 'liam', race: 3, distance_m: 400}),
    query3: who_would_win_by_how_much({runner1: 'emma', runner2: 'liam', race: 5, distance_m: 200}),
    query4: who_would_win_by_how_much({runner1: 'noah', runner2: 'emma', race: 6, distance_m: 100})
  };
};

// Run the model and collect an approximate posterior.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-18.json', posterior);