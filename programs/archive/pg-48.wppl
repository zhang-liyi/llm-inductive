var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  ////////////////////////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////////////////////////////////////////////////

  // Helper: mean of a list of numbers
  var listMean = function(xs) {
    return sum(xs) / xs.length;
  };

  // Intrinsic climbing ability is a stable trait for each climber on this day.
  // Units: arbitrary "climbing ability units" where ~100 is a good competition climber.
  var intrinsic_climbing_ability = mem(function({climber}) {
    // Three rough buckets: low / average / high
    var low_mean = 70;
    var avg_mean = 100;
    var high_mean = 135;
    var sd_within_bucket = 12;

    var ps;
    var vs = [low_mean, avg_mean, high_mean];

    // Strong substitute is drawn from a higher-ability-biased prior.
    if (climber === 'strong_substitute') {
      ps = [0.05, 0.20, 0.75];
    } else {
      // Generic competitive climber prior
      ps = [0.25, 0.45, 0.30];
    }

    var bucket_mean = categorical({ps: ps, vs: vs});
    // Truncate at 0 to avoid negative ability
    return Math.max(gaussian(bucket_mean, sd_within_bucket), 0);
  });

  // Each route has a difficulty, shared by both sides in that matchup.
  // Units: 0–100, where higher is harder.
  var route_difficulty_on_route = mem(function({route}) {
    // Competition routes tend to be moderately hard, centered near 60.
    var mean_difficulty = 60;
    var sd_difficulty = 15;
    return Math.min(Math.max(gaussian(mean_difficulty, sd_difficulty), 0), 100);
  });

  // Effort a climber gives on a particular route.
  // Units: percentage 0–100 (% of their maximum for that attempt).
  var effort_on_route = mem(function({climber, route}) {
    var ability = intrinsic_climbing_ability({climber: climber});
    var difficulty = route_difficulty_on_route({route: route});

    // Base high effort in competition, adjusted slightly by difficulty and ability.
    var base_mean = 80;

    // Harder routes -> somewhat higher effort; scale difficulty around 60.
    var difficulty_adjust = 8 * ((difficulty - 60) / 40); // roughly ±8

    // Higher ability climbers can sustain or choose higher effective effort.
    var ability_adjust = 6 * ((ability - 100) / 60); // roughly ±6 for common range

    var mean_effort = base_mean + difficulty_adjust + ability_adjust;
    var sd_effort = 10;

    var raw = gaussian(mean_effort, sd_effort);
    return Math.min(Math.max(raw, 0), 100);
  });

  // Individual climb performance on a given route.
  // Conceptually combines how high they get and how fast; higher is better.
  // Units: arbitrary "performance score units".
  var individual_climb_performance_on_route = function({climber, route}) {
    var ability = intrinsic_climbing_ability({climber: climber});
    var difficulty = route_difficulty_on_route({route: route});
    var effort_pct = effort_on_route({climber: climber, route: route}); // 0–100
    var effort_frac = effort_pct / 100;

    // Simple performance model:
    // - proportional to ability * effort
    // - penalized by route difficulty
    // - plus noise
    var base = ability * effort_frac - 0.5 * difficulty;
    var noise = gaussian(0, 15);

    return Math.max(base + noise, 0);
  };

  // Team performance on a route is based on the sum of individual performances
  // of both climbers, plus a small synergy/noise term.
  var team_climb_performance_on_route = function({team, route}) {
    // team is a list of climber IDs
    var indiv_perfs = map(function(c) {
      return individual_climb_performance_on_route({climber: c, route: route});
    }, team);

    var base_team_perf = sum(indiv_perfs);
    var synergy_noise = gaussian(0, 10); // small extra variability for teamwork etc.

    return Math.max(base_team_perf + synergy_noise, 0);
  };

  // Overall performance on a route for either a single climber or a team.
  var overall_climber_performance_on_route = function({climber, route}) {
    return individual_climb_performance_on_route({climber: climber, route: route});
  };

  var overall_team_performance_on_route = function({team, route}) {
    return team_climb_performance_on_route({team: team, route: route});
  };

  // beat relation handles both individual and team matchups.
  // For individuals: beat({climber1, climber2, route})
  // For teams:       beat({team1, team2, route})
  var beat = function(args) {
    if (args.climber1 != undefined) {
      var perf1 = overall_climber_performance_on_route({climber: args.climber1, route: args.route});
      var perf2 = overall_climber_performance_on_route({climber: args.climber2, route: args.route});
      return perf1 > perf2;
    } else {
      var perfT1 = overall_team_performance_on_route({team: args.team1, route: args.route});
      var perfT2 = overall_team_performance_on_route({team: args.team2, route: args.route});
      return perfT1 > perfT2;
    }
  };

  // Losing is simply not beating in that matchup.
  var lost = function(args) {
    return !beat(args);
  };

  // Intrinsic climbing ability ranking out of N climbers:
  // number of random other climbers whose ability is below this climber's.
  var intrinsic_climbing_ability_rank = function({climber, out_of_n_climbers}) {
    // Generate out_of_n_climbers - 1 random "other climber" IDs
    var random_ids = mapN(function(i) { return uniform(0, 100000); }, out_of_n_climbers - 1);

    return sum(map(function(other_id) {
      return intrinsic_climbing_ability({climber: climber}) >
             intrinsic_climbing_ability({climber: other_id});
    }, random_ids));
  };

  // Effort percentage on a particular route (0–100%).
  var effort_percentage_on_route = function({climber, route}) {
    return effort_on_route({climber: climber, route: route});
  };

  // Predict, for a new route, how likely Team 2 is to win.
  // Returns a number between 0 and 1: fraction of simulated future routes
  // in which Team 2 wins (1 = Team 2 almost surely wins, 0 = Team 1 almost surely wins).
  var who_would_win_by_how_much = function({team1, team2, route}) {
    var num_future_routes_to_simulate = 100;
    // Simulate future routes with new route IDs, independent of earlier ones.
    var random_future_route_ids = mapN(function(i) {
      return uniform(route + 1, 1000);
    }, num_future_routes_to_simulate);

    // Count how many simulated routes Team 2 wins (i.e., Team 1 loses).
    var wins_team2 = sum(map(function(rid) {
      return lost({team1: team1, team2: team2, route: rid});
    }, random_future_route_ids));

    return wins_team2 / num_future_routes_to_simulate;
  };

  ////////////////////////////////////////////////////////////////////////////
  // CONDITIONS (OBSERVED MATCH RESULTS)
  ////////////////////////////////////////////////////////////////////////////

  // On the first route, Maya beat Leo.  
  condition(beat({climber1: 'maya', climber2: 'leo', route: 1}))

  // On the second route, Nina beat Maya.  
  condition(beat({climber1: 'nina', climber2: 'maya', route: 2}))

  // On the third route, Leo and Owen together beat Nina and Zara.  
  condition(beat({team1: ['leo', 'owen'], team2: ['nina', 'zara'], route: 3}))

  // On the fourth route, Zara beat Owen.
  condition(beat({climber1: 'zara', climber2: 'owen', route: 4}))

  ////////////////////////////////////////////////////////////////////////////
  // QUERIES
  ////////////////////////////////////////////////////////////////////////////

  // Query 1: Out of 100 random sport climbers, where do you think Maya ranks
  //          in terms of intrinsic climbing ability?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you
  //          think Leo put into the third route?  
  // Query 3: On a new route later this same day between Maya and Zara
  //          (Team 1) and Leo and Nina (Team 2), who would win and by how much?  
  // Query 4: On a new route later this same day between Owen and a strong
  //          substitute (Team 1) and Nina and Zara (Team 2), who would win
  //          and by how much?

  return {
    query1: intrinsic_climbing_ability_rank({climber: 'maya', out_of_n_climbers: 100}),
    query2: effort_percentage_on_route({climber: 'leo', route: 3}),
    query3: who_would_win_by_how_much({team1: ['maya', 'zara'], team2: ['leo', 'nina'], route: 5}),
    query4: who_would_win_by_how_much({team1: ['owen', 'strong_substitute'], team2: ['nina', 'zara'], route: 6})
  };
};

// Run the model and collect an estimate of the posterior over the queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-48.json', posterior);