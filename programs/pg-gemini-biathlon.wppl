var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND
    // In this event, teams of players are competing in rounds of a biathalon.
    // The sport combines cross-country skiing and rifle shooting.
    
    // Helper function to calculate the mean of a list
    var listMean = function(l) {
        return sum(l) / l.length;
    }

    // Intrinsic strength is a latent attribute of an athlete that determines their skiing speed.
    // We assume athletes fall into different skill categories (e.g., average, strong, elite).
    var intrinsic_strength = mem(function ({athlete}) {
        var p_low = 0.33;
        var p_avg = 0.33;
        var p_high = 0.34;

        // Strength on an arbitrary scale (e.g., centered around 100)
        var mean_low = 80;
        var mean_avg = 100;
        var mean_high = 120;
        
        var strength_category_mean = categorical({ps: [p_low, p_avg, p_high], vs: [mean_low, mean_avg, mean_high]});
        
        // Intrinsic strength is stable for the athlete throughout the day.
        return gaussian(strength_category_mean, 10);
    })

    // Skiing speed in a round depends on intrinsic strength.
    // While strength is stable, the actual speed in a round might vary slightly (noise), but is primarily based on strength.
    var skiing_speed_in_round = function({athlete, round}) {
        // Speed is a noisy realization of intrinsic strength.
        return gaussian(intrinsic_strength({athlete: athlete}), 5);
    }

    // Shooting accuracy in a particular round.
    // This is a percentage from 0 to 100%.
    // The scenario states this is "each team member's shooting accuracy in that particular round", implying it varies per round.
    var shooting_accuracy_in_round = mem(function({athlete, round}) {
        // We model this as a draw from a distribution of typical shooting accuracies.
        // Most athletes are reasonably accurate, centered around 80%, with some variance.
        var accuracy = gaussian(80, 15);
        return Math.min(Math.max(accuracy, 0), 100);
    })

    // Team score depends on the average speed and each team member's shooting accuracy.
    // We combine these metrics to determine the winner.
    var team_score = function({team, round}) {
        var speeds = map(function(a) { return skiing_speed_in_round({athlete: a, round: round}) }, team);
        var accuracies = map(function(a) { return shooting_accuracy_in_round({athlete: a, round: round}) }, team);
        
        // We sum the average speed and average accuracy to get a total score.
        // Higher is better.
        return listMean(speeds) + listMean(accuracies);
    }

    // A team beats another if their score is higher.
    var beat = function({team1, team2, round}) {
        return team_score({team: team1, round: round}) > team_score({team: team2, round: round});
    }

    // A team loses if they do not beat the other team.
    var lost = function({team1, team2, round}) {
        return !beat({team1: team1, team2: team2, round: round});
    }

    // Query Helper: Intrinsic Strength Rank
    // Estimates where an athlete ranks compared to 100 random athletes.
    var intrinsic_strength_rank = function({athlete, out_of_n_athletes}) {
        var random_athlete_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_athletes - 1);
        return sum(map(function(other) {
            return intrinsic_strength({athlete: athlete}) > intrinsic_strength({athlete: other})
        }, random_athlete_ids));
    }

    // Query Helper: Shooting Accuracy Percentage
    // Returns the inferred accuracy for a specific round.
    var shooting_accuracy_percentage_in_round = function({athlete, round}) {
        return shooting_accuracy_in_round({athlete: athlete, round: round});
    }

    // Query Helper: Who would win by how much
    // Returns the probability that Team 2 wins.
    var who_would_win_by_how_much = function({team1, team2, round}) {
        var num_sims = 100;
        // Simulate future rounds with random IDs to avoid caching collisions with history
        var future_rounds = mapN(function(x) { return uniform(round + 1, 2000) }, num_sims);
        
        var team2_wins = sum(map(function(r) {
            return lost({team1: team1, team2: team2, round: r})
        }, future_rounds));
        
        return team2_wins / num_sims;
    }

    // CONDITIONS
    // In the first round, Billy and Emery beat Alice and Sam.
    condition(beat({team1:['billy', 'emery'], team2:['alice', 'sam'], round: 1}))
    // In the second round, Billy and Drew beat Alice and Lou.
    condition(beat({team1:['billy', 'drew'], team2:['alice', 'lou'], round: 2}))
    // In the third round, Billy and Ness beat Alice and Casey.
    condition(beat({team1:['billy', 'ness'], team2:['alice', 'casey'], round: 3}))
    // In the fourth round, Billy and Emery lost to Alice and Sam.
    condition(lost({team1:['billy', 'emery'], team2:['alice', 'sam'], round: 4}))

    // QUERIES
    return {
        query1: intrinsic_strength_rank({athlete: 'billy', out_of_n_athletes: 100}),
        query2: intrinsic_strength_rank({athlete: 'emery', out_of_n_athletes: 100}),
        query3: intrinsic_strength_rank({athlete: 'alice', out_of_n_athletes: 100}),
        query4: shooting_accuracy_percentage_in_round({athlete: 'billy', round: 4}),
        query5: shooting_accuracy_percentage_in_round({athlete: 'emery', round: 4}),
        query6: shooting_accuracy_percentage_in_round({athlete: 'alice', round: 4}),
        query7: who_would_win_by_how_much({team1:['billy', 'emery'], team2:['drew', 'casey'], round: 5}),
        query8: who_would_win_by_how_much({team1:['billy', 'alice'], team2:['emery', 'sam'], round: 6})
    }
}
var posterior = Infer({model: model, method: "rejection", samples: 10000});