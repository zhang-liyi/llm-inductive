var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // Intrinsic softball skill is a stable attribute of an athlete across all games on this day.
  // Units: "softball ability points" on an approximate 0–100+ scale (higher = better overall pitching/hitting/fielding/running).
  var intrinsic_skill = mem(function({athlete}) {
    var parameter_low_skill_prior = 0.3;
    var parameter_average_skill_prior = 0.4;
    var parameter_high_skill_prior = 0.3;

    var low_skill_mean = 40;
    var average_skill_mean = 60;
    var high_skill_mean = 80;
    var parameter_intrinsic_skill_variance = 10;

    var mean_skill_for_bucket = categorical({
      ps: [parameter_low_skill_prior, parameter_average_skill_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    // Keep skills non-negative.
    return Math.max(gaussian(mean_skill_for_bucket, parameter_intrinsic_skill_variance), 0);
  });

  // Offensive ability (hitting + base running) as a noisy reflection of intrinsic skill.
  // Units: same "ability points" scale as intrinsic_skill.
  var offensive_ability = mem(function({athlete}) {
    var base_skill = intrinsic_skill({athlete: athlete});
    var offensive_variance = 5;
    return Math.max(gaussian(base_skill, offensive_variance), 0);
  });

  // Defensive ability (pitching + fielding) as another noisy reflection of intrinsic skill.
  // Units: same "ability points" scale.
  var defensive_ability = mem(function({athlete}) {
    var base_skill = intrinsic_skill({athlete: athlete});
    var defensive_variance = 5;
    return Math.max(gaussian(base_skill, defensive_variance), 0);
  });

  // Effort in a particular game.
  // Units: proportion of maximum effort in [0, 1].
  // Depends (weakly) on intrinsic skill: stronger players are a bit more likely to put in high effort.
  var effort_in_game = mem(function({athlete, game}) {
    var skill = intrinsic_skill({athlete: athlete});

    var parameter_low_effort_prior =
      skill > 75 ? 0.15 :
      skill < 50 ? 0.4  :
                   0.25;

    var parameter_medium_effort_prior =
      skill > 75 ? 0.4  :
      skill < 50 ? 0.4  :
                   0.5;

    var parameter_high_effort_prior =
      skill > 75 ? 0.45 :
      skill < 50 ? 0.2  :
                   0.25;

    // Representative means for effort levels (0–1).
    var low_effort_mean = 0.3;
    var medium_effort_mean = 0.6;
    var high_effort_mean = 0.9;
    var effort_variance = 0.05;

    var mean_effort_level = categorical({
      ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior],
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]
    });

    // Clamp to [0,1].
    return Math.min(Math.max(gaussian(mean_effort_level, effort_variance), 0), 1);
  });

  // Effort percentage in a game: convert effort proportion to 0–100%.
  var effort_percentage_in_game = function({athlete, game}) {
    return 100 * effort_in_game({athlete: athlete, game: game});
  };

  // Offensive performance in a specific game.
  // Units: "offensive performance points" ~ offensive_ability * effort.
  var offensive_performance_in_game = function({athlete, game}) {
    var base_offense = offensive_ability({athlete: athlete});
    var effort = effort_in_game({athlete: athlete, game: game});
    return base_offense * effort;
  };

  // Defensive performance in a specific game.
  // Units: "defensive performance points" ~ defensive_ability * effort.
  var defensive_performance_in_game = function({athlete, game}) {
    var base_defense = defensive_ability({athlete: athlete});
    var effort = effort_in_game({athlete: athlete, game: game});
    return base_defense * effort;
  };

  // Team-level offense in a game: average offensive performance of team members.
  // Units: "team offensive performance points".
  var team_offense_in_game = function({team, game}) {
    return listMean(map(
      function(athlete) {
        return offensive_performance_in_game({athlete: athlete, game: game});
      },
      team));
  };

  // Team-level defense in a game: average defensive performance of team members.
  // Units: "team defensive performance points".
  var team_defense_in_game = function({team, game}) {
    return listMean(map(
      function(athlete) {
        return defensive_performance_in_game({athlete: athlete, game: game});
      },
      team));
  };

  // Expected runs scored for a team (offense vs opponent defense).
  // Units: expected runs per game (typical range ~0–10).
  var expected_runs_scored = function({team_offense, opponent_team_defense}) {
    var base_runs = 3;      // baseline scrimmage runs for evenly matched teams
    var scaling = 0.03;     // how strongly offense-defense difference changes runs
    var mean_runs = base_runs + scaling * (team_offense - opponent_team_defense);
    return Math.max(0.5, mean_runs);  // ensure positive expected runs
  };

  // Actual runs scored in a game, given expected runs.
  // Modeled as Poisson around the expected runs.
  var actual_runs_scored = function({expected_runs_scored}) {
    return poisson({mu: expected_runs_scored});
  };

  // Game result: scores for both teams in a particular game.
  // Units: runs (non-negative integers).
  var game_result = mem(function({team1, team2, game}) {
    var team1_offense = team_offense_in_game({team: team1, game: game});
    var team1_defense = team_defense_in_game({team: team1, game: game});
    var team2_offense = team_offense_in_game({team: team2, game: game});
    var team2_defense = team_defense_in_game({team: team2, game: game});

    var team1_expected = expected_runs_scored({
      team_offense: team1_offense,
      opponent_team_defense: team2_defense
    });

    var team2_expected = expected_runs_scored({
      team_offense: team2_offense,
      opponent_team_defense: team1_defense
    });

    var team1_runs = actual_runs_scored({expected_runs_scored: team1_expected});
    var team2_runs = actual_runs_scored({expected_runs_scored: team2_expected});

    return {team1_runs: team1_runs, team2_runs: team2_runs};
  });

  // Overall team score in a game is just the runs scored.
  // which = 1 or 2 indicates which team in the (team1, team2) pairing.
  var overall_team_score_in_game = function({team1, team2, game, which}) {
    var result = game_result({team1: team1, team2: team2, game: game});
    return (which === 1) ? result.team1_runs : result.team2_runs;
  };

  // Run differential: team1_runs - team2_runs.
  // Units: runs (can be negative if team2 scores more).
  var run_differential = function({team1, team2, game}) {
    var result = game_result({team1: team1, team2: team2, game: game});
    return result.team1_runs - result.team2_runs;
  };

  // A team beats another team in a game if it scores strictly more runs.
  var beat = function({team1, team2, game}) {
    return overall_team_score_in_game({team1: team1, team2: team2, game: game, which: 1}) >
           overall_team_score_in_game({team1: team1, team2: team2, game: game, which: 2});
  };

  // A team loses if it does not beat the other team (ties are effectively treated as not-a-win for team1).
  var lost = function({team1, team2, game}) {
    return !beat({team1: team1, team2: team2, game: game});
  };

  // Intrinsic skill ranking out of N athletes: how many random athletes this player is more skilled than.
  var intrinsic_skill_rank = function({athlete, out_of_n_athletes}) {
    var self_skill = intrinsic_skill({athlete: athlete});
    var random_athlete_ids = mapN(function(x) { return uniform(0, 1000); }, out_of_n_athletes - 1);

    return sum(map(
      function(random_athlete_id) {
        return self_skill > intrinsic_skill({athlete: random_athlete_id});
      },
      random_athlete_ids));
  };

  // Predict who would win and by how much (operationalized as probability that Team 2 wins).
  // Returns a number in [0,1], where:
  //   0   = Team 1 would definitely win,
  //   1   = Team 2 would definitely win.
  var who_would_win_by_how_much = function({team1, team2, game}) {
    var num_future_games_to_simulate = 100;
    var random_future_game_ids = mapN(
      function(x) { return uniform(game + 1, 1000); },
      num_future_games_to_simulate
    );

    var simulated_games_won_by_team_2 = sum(map(
      function(random_future_game_id) {
        return lost({team1: team1, team2: team2, game: random_future_game_id});
      },
      random_future_game_ids));

    return simulated_games_won_by_team_2 / num_future_games_to_simulate;
  };

  // CONDITIONS
  // In the first game, Priya, Kara, and Liam beat Morgan, Haley, and Zoe.
  condition(beat({team1:['priya', 'kara', 'liam'], team2:['morgan', 'haley', 'zoe'], game: 1}));

  // In the second game, Jade and Morgan beat Priya and Haley.
  condition(beat({team1:['jade', 'morgan'], team2:['priya', 'haley'], game: 2}));

  // In the third game, Kara and Zoe beat Jade and Liam.
  condition(beat({team1:['kara', 'zoe'], team2:['jade', 'liam'], game: 3}));

  // In the fourth game, Priya and Zoe lost to Morgan and Liam.
  condition(lost({team1:['priya', 'zoe'], team2:['morgan', 'liam'], game: 4}));

  // QUERIES
  // Query 1: Out of 100 random softball players, where do you think Priya ranks in terms of intrinsic softball skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Zoe put into the fourth game?
  // Query 3: In a new game later this same day between Priya, Kara, and Jade (Team 1) and Morgan, Haley, and Liam (Team 2), who would win and by how much?
  // Query 4: In a new game later this same day between Zoe and Jade (Team 1) and Priya and Morgan (Team 2), who would win and by how much?
  return {
    query1: intrinsic_skill_rank({athlete: 'priya', out_of_n_athletes: 100}),
    query2: effort_percentage_in_game({athlete: 'zoe', game: 4}),
    query3: who_would_win_by_how_much({team1:['priya', 'kara', 'jade'], team2:['morgan', 'haley', 'liam'], game: 5}),
    query4: who_would_win_by_how_much({team1:['zoe', 'jade'], team2:['priya', 'morgan'], game: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-8.json', posterior);