var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  // =========================
  // BACKGROUND KNOWLEDGE
  // =========================

  // Intrinsic playing ability is a stable attribute of each player across all games on this day.
  // Units: arbitrary "ability points", typical range ~60–140, higher = better.
  var intrinsic_playing_ability = mem(function({player}) {
    var parameter_low_ability_prior = 0.3;
    var parameter_average_ability_prior = 0.4;
    var parameter_high_ability_prior = 0.3;

    var low_ability_mean = 70;
    var average_ability_mean = 100;
    var high_ability_mean = 130;
    var intrinsic_ability_sd = 10;

    var ability_bucket_mean = categorical({
      ps: [parameter_low_ability_prior,
           parameter_average_ability_prior,
           parameter_high_ability_prior],
      vs: [low_ability_mean,
           average_ability_mean,
           high_ability_mean]
    });

    // Ability is non‑negative.
    return Math.max(gaussian(ability_bucket_mean, intrinsic_ability_sd), 0);
  });

  // Each player has a typical effort tendency that can depend weakly on their intrinsic ability.
  // Effort is a proportion in [0,1], later reported as 0–100%.
  var player_effort_tendency = mem(function({player}) {
    var ability = intrinsic_playing_ability({player: player});

    // More able players might maintain slightly higher effective effort.
    var base_mean_effort = 0.6 + 0.002 * (ability - 100);
    var mean_effort = Math.min(Math.max(base_mean_effort, 0.3), 0.95);

    // Convert mean + concentration into Beta parameters.
    var concentration = 10;
    var alpha = mean_effort * concentration;
    var beta_param = (1 - mean_effort) * concentration;

    return {alpha: alpha, beta: beta_param};
  });

  // Effort a player actually puts into a specific game (varies by game).
  // Units: proportion between 0 and 1.
  var player_effort_in_game = mem(function({player, game}) {
    var tendency = player_effort_tendency({player: player});
    return beta(tendency.alpha, tendency.beta);
  });

  // In‑game skill components, all on a 0–200 scale (higher = better).
  // Each depends positively on intrinsic ability and game‑specific effort.

  var throwing_accuracy_in_game = function({player, game}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = player_effort_in_game({player: player, game: game});
    var mean = 0.7 * ability + 40 * effort; // focus & mechanics
    var sd = 10;
    return Math.max(gaussian(mean, sd), 0);
  };

  var speed_in_game = function({player, game}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = player_effort_in_game({player: player, game: game});
    var mean = 0.6 * ability + 50 * effort; // sprinting & cuts
    var sd = 10;
    return Math.max(gaussian(mean, sd), 0);
  };

  var endurance_in_game = function({player, game}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = player_effort_in_game({player: player, game: game});
    var mean = 0.6 * ability + 45 * effort; // sustained running
    var sd = 10;
    return Math.max(gaussian(mean, sd), 0);
  };

  var field_awareness_in_game = function({player, game}) {
    var ability = intrinsic_playing_ability({player: player});
    var effort = player_effort_in_game({player: player, game: game});
    var mean = 0.8 * ability + 35 * effort; // decision‑making, positioning
    var sd = 10;
    return Math.max(gaussian(mean, sd), 0);
  };

  // Overall contribution of a player in a specific game.
  // Units: "game performance points", roughly 0–200.
  var player_effective_game_skill = function({player, game}) {
    var ta = throwing_accuracy_in_game({player: player, game: game});
    var sp = speed_in_game({player: player, game: game});
    var en = endurance_in_game({player: player, game: game});
    var fa = field_awareness_in_game({player: player, game: game});
    return (ta + sp + en + fa) / 4;
  };

  // Team effective game skill: average of players' effective skills.
  // Units: "team skill points", roughly 0–200.
  var team_effective_game_skill = function({team, game}) {
    var skills = map(function(player) {
      return player_effective_game_skill({player: player, game: game});
    }, team);
    return listMean(skills);
  };

  // Team game performance score adds random game‑level noise to team skill.
  // Units: "performance points".
  var team_game_performance_score = mem(function({team, game}) {
    var base_skill = team_effective_game_skill({team: team, game: game});
    var game_noise_sd = 15; // match‑ups, luck, wind, etc.
    return gaussian(base_skill, game_noise_sd);
  });

  // Margin of victory (positive if team2 outperforms team1).
  // Units: performance points.
  var margin_of_victory = function({team1, team2, game}) {
    var score1 = team_game_performance_score({team: team1, game: game});
    var score2 = team_game_performance_score({team: team2, game: game});
    return score2 - score1;
  };

  // A team beats another if its game performance score is higher.
  var beat = function({team1, team2, game}) {
    return team_game_performance_score({team: team1, game: game}) >
           team_game_performance_score({team: team2, game: game});
  };

  // Intrinsic playing ability ranking out of N random players:
  // number of random players that this player is better than.
  var intrinsic_playing_ability_rank = function({player, out_of_n_players}) {
    var num_others = out_of_n_players - 1;
    var random_ids = mapN(function(i) { return uniform(0, 1000); }, num_others);
    var ability_player = intrinsic_playing_ability({player: player});

    return sum(map(function(other_id) {
      return ability_player >
             intrinsic_playing_ability({player: other_id}) ? 1 : 0;
    }, random_ids));
  };

  // Effort percentage in a game (0–100%).
  var effort_percentage_in_game = function({player, game}) {
    return 100 * player_effort_in_game({player: player, game: game});
  };

  // Hypothetical matchup: who would win and by how much?
  // Return:
  //   probTeam2Wins: probability (0–1) Team 2 would beat Team 1
  //   expectedMarginIfTeam2Wins: expected margin (performance points) conditional on Team 2 winning
  var who_would_win_by_how_much = function({team1, team2, game}) {
    var num_future_games_to_simulate = 100;

    // Use random future game IDs so that each simulated game has its own efforts/noise.
    var random_future_game_ids = mapN(function(i) {
      return uniform(game + 1, 1000);
    }, num_future_games_to_simulate);

    var outcomes = map(function(gid) {
      // For probability, check if Team 2 beats Team 1 in that simulated game.
      var team2_beats_team1 = beat({team1: team2, team2: team1, game: gid});

      // Margin is defined as Team 2 score minus Team 1 score.
      var margin = margin_of_victory({team1: team1, team2: team2, game: gid});

      return {
        team2Win: team2_beats_team1 ? 1 : 0,
        marginIfTeam2: team2_beats_team1 ? margin : 0
      };
    }, random_future_game_ids);

    var totalWinsTeam2 = sum(map(function(o) { return o.team2Win; }, outcomes));
    var totalMarginIfTeam2Wins = sum(map(function(o) { return o.marginIfTeam2; }, outcomes));

    var probTeam2Wins = totalWinsTeam2 / num_future_games_to_simulate;
    var avgMarginIfTeam2Wins = (totalWinsTeam2 == 0) ?
                               0 :
                               totalMarginIfTeam2Wins / totalWinsTeam2;

    return {
      probTeam2Wins: probTeam2Wins,
      expectedMarginIfTeam2Wins: avgMarginIfTeam2Wins
    };
  };

  // =========================
  // CONDITIONS
  // =========================

  // In the first game, Jordan’s team (Jordan, Riley, Sam, Taylor, Quinn) beat Casey’s team (Casey, Morgan, Alex, Drew, Jamie).
  condition(beat({team1: ['jordan', 'riley', 'sam', 'taylor', 'quinn'],
                  team2: ['casey', 'morgan', 'alex', 'drew', 'jamie'],
                  game: 1}))

  // In the second game, Jordan, Riley, and Casey teamed up with two substitutes and beat a mixed team including Sam and Alex.
  condition(beat({team1: ['jordan', 'riley', 'casey', 'sub1', 'sub2'],
                  team2: ['sam', 'alex', 'sub3', 'sub4', 'sub5'],
                  game: 2}))

  // In the third game, Casey, Sam, Taylor, and two substitutes beat Jordan, Morgan, Drew, and two substitutes.
  condition(beat({team1: ['casey', 'sam', 'taylor', 'sub6', 'sub7'],
                  team2: ['jordan', 'morgan', 'drew', 'sub8', 'sub9'],
                  game: 3}))

  // In the fourth game, a team led by Casey and Alex beat a team led by Riley and Quinn.
  condition(beat({team1: ['casey', 'alex', 'sub10', 'sub11', 'sub12'],
                  team2: ['riley', 'quinn', 'sub13', 'sub14', 'sub15'],
                  game: 4}))

  // =========================
  // QUERIES
  // =========================

  // Query 1: Out of 100 random Ultimate players, where do you think Jordan ranks in terms of intrinsic playing ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Casey put into the third game?
  // Query 3: In a new game later this same day between Jordan, Riley, and three substitutes (Team 1) and Casey, Sam, and three substitutes (Team 2), who would win and by how much?
  // Query 4: In a new game later this same day between Alex, Morgan, Drew, Quinn, and a substitute (Team 1) and Taylor, Jamie, and three substitutes (Team 2), who would win and by how much?
  return {
    query1: intrinsic_playing_ability_rank({player: 'jordan', out_of_n_players: 100}),
    query2: effort_percentage_in_game({player: 'casey', game: 3}),
    query3: who_would_win_by_how_much({team1: ['jordan', 'riley', 'sub16', 'sub17', 'sub18'],
                                       team2: ['casey', 'sam', 'sub19', 'sub20', 'sub21'],
                                       game: 5}),
    query4: who_would_win_by_how_much({team1: ['alex', 'morgan', 'drew', 'quinn', 'sub22'],
                                       team2: ['taylor', 'jamie', 'sub23', 'sub24', 'sub25'],
                                       game: 6})
  };
};

// Run inference to approximate the posterior over query answers.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-45.json', posterior);