var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic tennis ability is an attribute of a given player that varies widely from player to player.
    var intrinsic_tennis_ability = mem(function ({player}) {
      var low_skill_prior = 0.33;
      var average_skill_prior = 0.33;
      var high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var skill_variance = 10;

      var player_skill_average = categorical({ps: [low_skill_prior, average_skill_prior, high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(player_skill_average, skill_variance), 0);
    })

    // A player's intrinsic tennis ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_tennis_ability_rank = function({player, out_of_n_players}) {
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        return sum(map(
            function(random_player_id) {
              return intrinsic_tennis_ability({player: player}) > intrinsic_tennis_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a match can vary and is modeled as a percentage from 0 to 100.
    var effort_in_match = mem(function({player, match}) {
      return Math.min(Math.max(gaussian(50, 20), 0), 100);
    })

    var effort_percentage_in_match = function({player, match}) {
      return effort_in_match({player, match});
    }

    // Player performance in a match depends on intrinsic ability and effort.
    var player_performance_in_match = function({player, match}) {
      return intrinsic_tennis_ability({player: player}) * (effort_in_match({player, match}) / 100);
    }

    // Team performance in a match is the average performance of the team members.
    var team_performance_in_match = function({team, match}) {
      return listMean(map(function(player) { return player_performance_in_match({player: player, match: match}) }, team));
    }

    // A player or team beats another if their performance is greater.
    var beat = function({player1, player2, team1, team2, match}){
      if (player1 && player2) {
        return player_performance_in_match({player: player1, match: match}) > player_performance_in_match({player: player2, match: match});
      } else {
        return team_performance_in_match({team: team1, match: match}) > team_performance_in_match({team: team2, match: match});
      }
    }

    // Calculate who would win and by how much.
    var who_would_win_by_how_much = function({player1, player2, team1, team2, match}) {
      var num_future_matches_to_simulate = 100;
      var random_future_match_ids = mapN(function(x) {return uniform(match+1, 1000)}, num_future_matches_to_simulate);

      var simulated_matches_won_by_team2 = sum(map(
            function(random_future_match_id) {
              return beat({player1: player2, player2: player1, team1: team2, team2: team1, match: random_future_match_id})}, random_future_match_ids))

      return simulated_matches_won_by_team2 / num_future_matches_to_simulate;
    }

  // CONDITIONS
  // In the first match, Serena beat Nora.
  condition(beat({player1: 'serena', player2: 'nora', match: 1}))
  // In the second match, Serena and Alex beat Nora and Liam.
  condition(beat({team1: ['serena', 'alex'], team2: ['nora', 'liam'], match: 2}))
  // In the third match, Liam beat Alex.
  condition(beat({player1: 'liam', player2: 'alex', match: 3}))

  // QUERIES
  // Query 1: Out of 100 random tennis players, where do you think Serena ranks in terms of intrinsic tennis ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Liam put into the third match?
  // Query 3: In a new doubles match later this same day between Serena and Liam (Team 1) and Nora and Alex (Team 2), who would win and by how much?
  // Query 4: In a new singles match later this same day between Alex and Nora, who would win and by how much?
  return {
    query1: intrinsic_tennis_ability_rank({player: 'serena', out_of_n_players: 100}),
    query2: effort_percentage_in_match({player: 'liam', match: 3}),
    query3: who_would_win_by_how_much({team1: ['serena', 'liam'], team2: ['nora', 'alex'], match: 4}),
    query4: who_would_win_by_how_much({player1: 'alex', player2: 'nora', match: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", kernel: "HMC", samples: 12000, burn: 2000});
json.write('inference_results/result-10000-gpt-5p1-2.json', posterior);