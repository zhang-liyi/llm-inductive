var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  /////////////////////////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE
  /////////////////////////////////////////////////////////////////////////////

  // Intrinsic shooting accuracy is a stable property of each archer.
  // Think of it as a "precision skill score" on an arbitrary 0–200 scale,
  // where higher values mean the archer can place arrows closer to the center
  // under standard conditions. Units: abstract skill points.
  var intrinsic_shooting_accuracy = mem(function({archer}) {
    var parameter_low_skill_prior = 0.3;
    var parameter_average_prior = 0.5;
    var parameter_high_skill_prior = 0.2;

    var low_skill_mean = 70;   // weak competitive archer
    var average_skill_mean = 100; // solid club / regional level
    var high_skill_mean = 130; // very strong / elite
    var parameter_intrinsic_accuracy_sd = 15;

    var this_archer_skill_mean = categorical({
      ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    return Math.max(gaussian(this_archer_skill_mean, parameter_intrinsic_accuracy_sd), 0);
  });

  // Intrinsic steadiness is also a stable property; it is positively related
  // to intrinsic shooting accuracy. Higher = more stable, on a 0–100 scale.
  // Units: abstract steadiness points.
  var intrinsic_steadiness = mem(function({archer}) {
    var acc = intrinsic_shooting_accuracy({archer: archer});

    // Map accuracy (0–200) roughly into a 0–100 baseline for steadiness.
    var baseline_steadiness_mean = acc / 2; // better accuracy → higher steadiness
    var intrinsic_steadiness_sd = 10;

    var raw_steadiness = gaussian(baseline_steadiness_mean, intrinsic_steadiness_sd);
    return Math.min(Math.max(raw_steadiness, 0), 100);
  });

  // Effort in a specific round: how much mental/physical effort the archer
  // invests in that round, 0–100%. Depends on their intrinsic traits.
  var effort_in_round = mem(function({archer, round}) {
    var acc = intrinsic_shooting_accuracy({archer: archer});
    var stead = intrinsic_steadiness({archer: archer});

    // Combine intrinsic traits into a 0–100 scale
    var trait_level = (acc / 2 + stead) / 2;

    // Better, steadier archers are more likely to put in consistently high effort.
    var parameter_low_effort_prior =
      trait_level < 40 ? 0.6 :
      trait_level > 70 ? 0.1 :
      0.3;

    var parameter_medium_effort_prior =
      trait_level < 40 ? 0.3 :
      trait_level > 70 ? 0.3 :
      0.5;

    var parameter_high_effort_prior =
      1 - parameter_low_effort_prior - parameter_medium_effort_prior;

    var low_effort_mean = 30;   // 30%
    var medium_effort_mean = 60; // 60%
    var high_effort_mean = 85;  // 85%
    var effort_sd = 15;

    var effort_mean = categorical({
      ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior],
      vs: [low_effort_mean, medium_effort_mean, high_effort_mean]
    });

    var raw_effort = gaussian(effort_mean, effort_sd);
    return Math.min(Math.max(raw_effort, 0), 100);
  });

  // Concentration in a round: how well the archer maintains focus during that
  // round, 0–100%. Depends on their effort and intrinsic traits.
  var concentration_in_round = mem(function({archer, round}) {
    var eff = effort_in_round({archer: archer, round: round});
    var acc = intrinsic_shooting_accuracy({archer: archer});
    var stead = intrinsic_steadiness({archer: archer});

    var trait_focus = (acc / 2 + stead) / 2; // 0–100
    var mean_concentration = 0.6 * eff + 0.4 * trait_focus;
    var concentration_sd = 10;

    var raw_conc = gaussian(mean_concentration, concentration_sd);
    return Math.min(Math.max(raw_conc, 0), 100);
  });

  // Effective precision in a round combines intrinsic traits and round-specific
  // effort and concentration into a single performance factor.
  // Units: same 0–200 precision skill scale (higher = better).
  var archer_effective_precision_in_round = function({archer, round}) {
    var acc = intrinsic_shooting_accuracy({archer: archer});
    var stead = intrinsic_steadiness({archer: archer});
    var eff = effort_in_round({archer: archer, round: round});
    var conc = concentration_in_round({archer: archer, round: round});

    var weighted_precision_mean =
      0.4 * acc +   // base aiming skill
      0.2 * stead + // stability
      0.2 * eff +   // how hard they try
      0.2 * conc;   // how focused they are

    var precision_sd = 10;
    var raw_precision = gaussian(weighted_precision_mean, precision_sd);
    return Math.max(raw_precision, 0);
  };

  // Archer's mean distance from center in a given round (0–100 units, where
  // 0 = perfect center, 100 = very poor). Lower is better.
  var archer_mean_distance_from_center_in_round = mem(function({archer, round}) {
    var precision = archer_effective_precision_in_round({archer: archer, round: round});

    // Map high precision to low distance.
    var base_distance_mean = 100 - precision; // can be <0 for very high precision
    var distance_sd = 5;

    var raw_distance = gaussian(base_distance_mean, distance_sd);
    return Math.min(Math.max(raw_distance, 0), 100);
  });

  // Team mean distance from center in a round is the average of members'
  // mean distances. Lower is better.
  var team_mean_distance_from_center_in_round = function({team, round}) {
    return listMean(map(function(archer) {
      return archer_mean_distance_from_center_in_round({archer: archer, round: round});
    }, team));
  };

  // A team beats another team in a round if their team mean distance from
  // center is smaller (closer to the center).
  var beat = function({team1, team2, round}) {
    return team_mean_distance_from_center_in_round({team: team1, round: round}) <
           team_mean_distance_from_center_in_round({team: team2, round: round});
  };

  // Intrinsic shooting accuracy ranking: how many out of N random archers
  // this archer would be *better than* in intrinsic shooting accuracy.
  var intrinsic_shooting_accuracy_rank = function({archer, out_of_n_archers}) {
    // Generate out_of_n_archers - 1 other random archer IDs
    var random_archer_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_archers - 1
    );

    var this_accuracy = intrinsic_shooting_accuracy({archer: archer});

    // Count how many random archers this archer is intrinsically more accurate than.
    var better_than_count = sum(map(function(random_archer_id) {
      return this_accuracy > intrinsic_shooting_accuracy({archer: random_archer_id});
    }, random_archer_ids));

    return better_than_count;
  };

  // Effort percentage in a specific round: just expose the latent effort_in_round.
  var effort_percentage_in_round = function({archer, round}) {
    return effort_in_round({archer: archer, round: round});
  };

  // Predict who would win and by how much between two teams in a (future) round.
  // We approximate "by how much" as the probability that Team 2 would win:
  // 0.0 = Team 1 would almost certainly win
  // 1.0 = Team 2 would almost certainly win
  var who_would_win_by_how_much = function({team1, team2, round}) {
    var num_future_rounds_to_simulate = 100;

    // Simulate using new, unused round IDs so that each simulation draws new
    // effort/concentration etc., while keeping intrinsic traits fixed.
    var random_future_round_ids = mapN(
      function(x) { return uniform(round + 1, 1000); },
      num_future_rounds_to_simulate
    );

    // Count how many simulated rounds Team 2 beats Team 1.
    var simulated_rounds_won_by_team_2 = sum(map(function(random_future_round_id) {
      // Team 2 beats Team 1 in that simulated round if swapping roles yields beat=true.
      return beat({team1: team2, team2: team1, round: random_future_round_id});
    }, random_future_round_ids));

    return simulated_rounds_won_by_team_2 / num_future_rounds_to_simulate;
  };

  /////////////////////////////////////////////////////////////////////////////
  // CONDITIONS
  /////////////////////////////////////////////////////////////////////////////

  // In the first round, Ava beat Daniel.
  condition(beat({team1:['ava'], team2:['daniel'], round: 1}))
  // In the second round, Ava, Emma, and Felix beat Daniel, Hugo, and Iris.
  condition(beat({team1:['ava', 'emma', 'felix'], team2:['daniel', 'hugo', 'iris'], round: 2}))
  // In the third round, Daniel, Emma, and Iris beat Ava, Felix, and Hugo.
  condition(beat({team1:['daniel', 'emma', 'iris'], team2:['ava', 'felix', 'hugo'], round: 3}))
  // In the fourth round, Felix beat Hugo.
  condition(beat({team1:['felix'], team2:['hugo'], round: 4}))

  /////////////////////////////////////////////////////////////////////////////
  // QUERIES
  /////////////////////////////////////////////////////////////////////////////

  // Query 1: Out of 100 random archers, where do you think Ava ranks in terms of intrinsic shooting accuracy?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Daniel put into the third round?
  // Query 3: In a new team round later this same day between Ava, Emma, and Felix (Team 1)
  //          and Daniel, Hugo, and Iris (Team 2), who would win and by how much?
  // Query 4: In a new team round later this same day between Ava and Daniel (Team 1)
  //          and Felix and Hugo (Team 2), who would win and by how much?
  return {
    query1: intrinsic_shooting_accuracy_rank({archer: 'ava', out_of_n_archers: 100}),
    query2: effort_percentage_in_round({archer: 'daniel', round: 3}),
    query3: who_would_win_by_how_much({team1:['ava', 'emma', 'felix'], team2:['daniel', 'hugo', 'iris'], round: 5}),
    query4: who_would_win_by_how_much({team1:['ava', 'daniel'], team2:['felix', 'hugo'], round: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-41.json', posterior);