var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  // ============================
  // BACKGROUND KNOWLEDGE
  // ============================

  // Players have stable underlying "core" baseball skill for the day.
  // Scale: arbitrary, centered around 100; low ~80, average ~100, high ~120.
  var core_skill = mem(function({athlete}) {
    var low_mean = 80;
    var avg_mean = 100;
    var high_mean = 120;
    var core_sd = 10;

    var bucket_mean = categorical({
      ps: [0.3, 0.4, 0.3], 
      vs: [low_mean, avg_mean, high_mean]
    });

    return Math.max(gaussian(bucket_mean, core_sd), 0);
  });

  // Intrinsic component skills (all on same arbitrary scale as core_skill).
  var intrinsic_hitting_skill = mem(function({athlete}) {
    var base = core_skill({athlete: athlete});
    return Math.max(gaussian(base, 5), 0);
  });

  var intrinsic_pitching_skill = mem(function({athlete}) {
    var base = core_skill({athlete: athlete});
    return Math.max(gaussian(base, 5), 0);
  });

  var intrinsic_fielding_skill = mem(function({athlete}) {
    var base = core_skill({athlete: athlete});
    return Math.max(gaussian(base, 5), 0);
  });

  var intrinsic_baserunning_skill = mem(function({athlete}) {
    var base = core_skill({athlete: athlete});
    return Math.max(gaussian(base, 5), 0);
  });

  // Overall intrinsic baseball skill as a weighted combination of components.
  // Units: arbitrary "overall skill" points, comparable across players.
  var intrinsic_skill = mem(function({athlete}) {
    var hit = intrinsic_hitting_skill({athlete: athlete});
    var pitch = intrinsic_pitching_skill({athlete: athlete});
    var field = intrinsic_fielding_skill({athlete: athlete});
    var run = intrinsic_baserunning_skill({athlete: athlete});

    // Hitting and pitching matter slightly more for short scrimmages.
    return 0.4 * hit + 0.3 * pitch + 0.2 * field + 0.1 * run;
  });

  // Intrinsic skill rank out of N random players.
  var intrinsic_skill_rank = function({athlete, out_of_n_athletes}) {
    var random_ids = mapN(
      function(i) { return uniform(0, 1000); },
      out_of_n_athletes - 1
    );

    return sum(map(
      function(other_id) {
        return intrinsic_skill({athlete: athlete}) >
               intrinsic_skill({athlete: other_id});
      },
      random_ids
    ));
  };

  // Effort modeling.
  // Baseline effort tendency per athlete (0–1).
  var baseline_effort = mem(function({athlete}) {
    // Beta(4,2): mean ~0.67 (67%).
    return beta({a: 4, b: 2});
  });

  // Effort in a specific scrimmage (0–1).
  var effort_in_scrimmage = mem(function({athlete, scrimmage}) {
    var base = baseline_effort({athlete: athlete});
    // Concentrate around baseline with some variability.
    var a = 2 + 6 * base;
    var b = 2 + 6 * (1 - base);
    return beta({a: a, b: b});
  });

  // Effort percentage (0–100%).
  var effort_percentage_in_scrimmage = function({athlete, scrimmage}) {
    return 100 * effort_in_scrimmage({athlete: athlete, scrimmage: scrimmage});
  };

  // Whether a scrimmage was shortened.
  var shortened_game = mem(function({scrimmage}) {
    // Prior: most games are normal length, shortened games are somewhat rare.
    return flip(0.1);
  });

  // Game length factor.
  // Units: fraction of a normal short scrimmage (1.0 = normal length).
  var game_length_factor_in_scrimmage = function({scrimmage}) {
    return shortened_game({scrimmage: scrimmage}) ? 0.5 : 1.0;
  };

  // Individual offensive contribution in a scrimmage.
  // Units: approximate runs contributed per game (continuous).
  var offensive_contribution_in_scrimmage = function({athlete, scrimmage}) {
    var hit = intrinsic_hitting_skill({athlete: athlete});
    var run = intrinsic_baserunning_skill({athlete: athlete});
    var eff = effort_in_scrimmage({athlete: athlete, scrimmage: scrimmage});

    // Normalize skills from ~[80,120] to a per-game run scale.
    var base_offense = (0.7 * hit + 0.3 * run) / 100; // around 1–2
    var mean_contrib = eff * base_offense;
    return Math.max(gaussian(mean_contrib, 0.2), 0);
  };

  // Individual defensive/pitching contribution in a scrimmage.
  // Units: approximate runs prevented per game (continuous).
  var defensive_contribution_in_scrimmage = function({athlete, scrimmage}) {
    var pitch = intrinsic_pitching_skill({athlete: athlete});
    var field = intrinsic_fielding_skill({athlete: athlete});
    var eff = effort_in_scrimmage({athlete: athlete, scrimmage: scrimmage});

    var base_defense = (0.6 * pitch + 0.4 * field) / 100; // around 1–2
    var mean_contrib = eff * base_defense;
    return Math.max(gaussian(mean_contrib, 0.2), 0);
  };

  // Optional: combined individual game performance object.
  var individual_game_performance_in_scrimmage = function({athlete, scrimmage}) {
    return {
      offense: offensive_contribution_in_scrimmage({athlete: athlete, scrimmage: scrimmage}),
      defense: defensive_contribution_in_scrimmage({athlete: athlete, scrimmage: scrimmage})
    };
  };

  // Team-level offense and defense.
  var team_offense_in_scrimmage = function({team, scrimmage}) {
    // Sum of offensive contributions of all team members.
    return sum(map(
      function(player) {
        return offensive_contribution_in_scrimmage({athlete: player, scrimmage: scrimmage});
      },
      team
    ));
  };

  var team_defense_in_scrimmage = function({team, scrimmage}) {
    // Sum of defensive contributions of all team members.
    return sum(map(
      function(player) {
        return defensive_contribution_in_scrimmage({athlete: player, scrimmage: scrimmage});
      },
      team
    ));
  };

  // Team runs scored.
  // Units: runs (continuous approximation, typically 0–15).
  var team_runs_scored_in_scrimmage = mem(function({team, opponent, scrimmage}) {
    var offense = team_offense_in_scrimmage({team: team, scrimmage: scrimmage});
    var opp_defense = team_defense_in_scrimmage({team: opponent, scrimmage: scrimmage});
    var length_factor = game_length_factor_in_scrimmage({scrimmage: scrimmage});

    var base_runs = 3.0; // expected runs for evenly matched teams in a normal short scrimmage
    var mean_runs = base_runs + 0.7 * (offense - opp_defense);

    mean_runs = length_factor * Math.max(0.2, mean_runs);

    return Math.max(gaussian(mean_runs, 1.5), 0);
  });

  // Team runs allowed is opponent's runs scored.
  var team_runs_allowed_in_scrimmage = function({team, opponent, scrimmage}) {
    return team_runs_scored_in_scrimmage({team: opponent, opponent: team, scrimmage: scrimmage});
  };

  // Team run differential in a scrimmage.
  // Units: runs (continuous; positive means team1 scored more).
  var team_run_differential_in_scrimmage = function({team1, team2, scrimmage}) {
    var runs1 = team_runs_scored_in_scrimmage({team: team1, opponent: team2, scrimmage: scrimmage});
    var runs2 = team_runs_scored_in_scrimmage({team: team2, opponent: team1, scrimmage: scrimmage});
    return runs1 - runs2;
  };

  // Team1 beats Team2 if its run differential > 0.
  var beat = function({team1, team2, scrimmage}) {
    return team_run_differential_in_scrimmage({team1: team1, team2: team2, scrimmage: scrimmage}) > 0;
  };

  // Team1 loses to Team2 if it does not beat Team2.
  var lost = function({team1, team2, scrimmage}) {
    return !beat({team1: team1, team2: team2, scrimmage: scrimmage});
  };

  // For hypothetical future scrimmages: who would win and by how much?
  // We return the probability (0–1) that Team 2 would win (higher = more likely Team 2).
  var who_would_win_by_how_much = function({team1, team2, scrimmage}) {
    var num_future_scrimmages_to_simulate = 100;
    var future_ids = mapN(
      function(i) { return uniform(scrimmage + 1, 1000); },
      num_future_scrimmages_to_simulate
    );

    var wins_team2 = sum(map(
      function(future_id) {
        return lost({team1: team1, team2: team2, scrimmage: future_id});
      },
      future_ids
    ));

    return wins_team2 / num_future_scrimmages_to_simulate;
  };

  // ============================
  // CONDITIONS
  // ============================

  // In the first scrimmage, Diego, Marco, Luis, and Owen beat Caleb, Jonah, Eric, and Finn.
  condition(beat({team1:['diego', 'marco', 'luis', 'owen'], team2:['caleb', 'jonah', 'eric', 'finn'], scrimmage: 1}))

  // In the second scrimmage, Diego, Caleb, and Eric beat Marco, Jonah, and Finn.
  condition(beat({team1:['diego', 'caleb', 'eric'], team2:['marco', 'jonah', 'finn'], scrimmage: 2}))

  // In the third scrimmage, Luis and Owen lost to Caleb and Marco in a shortened game.
  condition(lost({team1:['luis', 'owen'], team2:['caleb', 'marco'], scrimmage: 3}) && shortened_game({scrimmage: 3}))

  // In the fourth scrimmage, Jonah and Finn beat Diego and Luis.
  condition(beat({team1:['jonah', 'finn'], team2:['diego', 'luis'], scrimmage: 4}))

  // ============================
  // QUERIES
  // ============================

  // Query 1: Out of 100 random baseball players, where do you think Diego ranks in terms of intrinsic baseball skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Marco put into the third scrimmage?
  // Query 3: In a new game later this same day between Diego, Luis, and Jonah (Team 1) and Caleb, Eric, and Finn (Team 2), who would win and by how much?
  // Query 4: In a new game later this same day between Marco and Owen (Team 1) and Diego and Caleb (Team 2), who would win and by how much?
  return {
    query1: intrinsic_skill_rank({athlete: 'diego', out_of_n_athletes: 100}),
    query2: effort_percentage_in_scrimmage({athlete: 'marco', scrimmage: 3}),
    query3: who_would_win_by_how_much({team1:['diego', 'luis', 'jonah'], team2:['caleb', 'eric', 'finn'], scrimmage: 5}),
    query4: who_would_win_by_how_much({team1:['marco', 'owen'], team2:['diego', 'caleb'], scrimmage: 6})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-7.json', posterior);