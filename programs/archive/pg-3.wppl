var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  ////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////

  // Intrinsic table tennis ability:
  // - Stable across all matches in this one‑day event.
  // - Units: arbitrary "skill points", centered around ~100 for an average player.
  // - Captures spin control, reflexes, placement, anticipation, consistency.
  var intrinsic_table_tennis_ability = mem(function({player}) {
    var low_skill_prior = 0.3;
    var average_skill_prior = 0.4;
    var high_skill_prior = 0.3;

    var low_skill_mean = 80;   // skill points
    var average_skill_mean = 100;
    var high_skill_mean = 120;
    var ability_variance = 15; // standard deviation in skill points

    var ability_bucket_mean = categorical({
      ps: [low_skill_prior, average_skill_prior, high_skill_prior],
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]
    });

    // Truncate to non‑negative skill.
    return Math.max(gaussian(ability_bucket_mean, ability_variance), 0);
  });

  // Player effort in a specific match:
  // - Varies by match.
  // - Units: fraction from 0.0 to 1.0 (0%–100% effort).
  // - Slightly influenced by intrinsic ability (better players tend to invest
  //   a bit more focused effort on average).
  var player_effort_in_match = mem(function({player, match}) {
    var ability = intrinsic_table_tennis_ability({player: player});

    // Base mean effort ~70%, adjusted a bit by ability.
    var base_mean_effort = 0.7;
    // Scale ability (center 100) to a small adjustment.
    var adjusted_mean_effort = base_mean_effort + 0.002 * (ability - 100);

    // Keep mean in [0.3, 0.95] so it stays reasonable.
    var mean_effort = Math.min(0.95, Math.max(0.3, adjusted_mean_effort));

    // Beta prior with moderate concentration around the mean.
    var concentration = 10;
    var alpha = mean_effort * concentration;
    var betaParam = (1 - mean_effort) * concentration;

    return beta({a: alpha, b: betaParam}); // draws in [0,1]
  });

  // Team intrinsic ability in a match:
  // - For singles, just that player's intrinsic ability.
  // - For doubles, the mean intrinsic ability over the players on the team.
  // - Units: same "skill points" as intrinsic_table_tennis_ability.
  var team_intrinsic_ability_in_match = function({team, match}) {
    var abilities = map(function(player) {
      return intrinsic_table_tennis_ability({player: player});
    }, team);
    return listMean(abilities);
  };

  // Team effort in a match:
  // - Mean of member efforts.
  // - Units: fraction 0–1 (0%–100%).
  var team_effort_in_match = function({team, match}) {
    var efforts = map(function(player) {
      return player_effort_in_match({player: player, match: match});
    }, team);
    return listMean(efforts);
  };

  // Overall team performance in a match:
  // - Depends on team intrinsic ability, team effort, and random luck.
  // - Units: abstract "performance units" (higher = better).
  // - Mem'd so the same (team,match) performance is reused wherever referenced.
  var team_performance_in_match = mem(function({team, match}) {
    var ability = team_intrinsic_ability_in_match({team: team, match: match}); // skill points
    var effort = team_effort_in_match({team: team, match: match});             // 0–1

    // Weight intrinsic ability and effort into a single performance score.
    // Here both contribute substantially; noise captures luck.
    var ability_weight = 1.0;      // performance units per skill point
    var effort_weight = 30.0;      // performance units per unit effort (0–1)
    var noise_sd = 10.0;           // performance units

    var base_performance =
      ability_weight * ability + effort_weight * effort;

    return gaussian(base_performance, noise_sd);
  });

  // A team beats another in a match if its performance is higher.
  var beat = function({team1, team2, match}) {
    return team_performance_in_match({team: team1, match: match}) >
           team_performance_in_match({team: team2, match: match});
  };

  // Margin of victory in a match:
  // - Absolute difference in team performance between winner and loser.
  // - Units: performance units.
  var margin_of_victory_in_match = function({team1, team2, match}) {
    var perf1 = team_performance_in_match({team: team1, match: match});
    var perf2 = team_performance_in_match({team: team2, match: match});
    return Math.abs(perf1 - perf2);
  };

  // Intrinsic ability rank:
  // - Out of N players sampled from the same population.
  // - Returns: expected number of players this player is better than (0..N-1).
  var intrinsic_table_tennis_ability_rank = function({player, out_of_n_players}) {
    // Generate out_of_n_players - 1 other random player IDs.
    var random_player_ids = mapN(function(x) {
      return uniform(0, 10000);
    }, out_of_n_players - 1);

    var this_player_ability = intrinsic_table_tennis_ability({player: player});

    return sum(map(function(random_id) {
      return this_player_ability >
             intrinsic_table_tennis_ability({player: random_id});
    }, random_player_ids));
  };

  // Effort percentage in a match:
  // - Converts effort fraction (0–1) to percentage (0–100%).
  var effort_percentage_in_match = function({player, match}) {
    return 100 * player_effort_in_match({player: player, match: match});
  };

  // Who would win and by how much (for a future match):
  // - Simulates many hypothetical future matches between team1 and team2.
  // - Returns an object summarizing:
  //    * probTeam2Wins: probability (0–1) that Team 2 wins.
  //    * expected_signed_margin: expected signed margin in performance units
  //      (positive if Team 2 tends to win by that margin, negative if Team 1).
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;

    // Use random future match IDs so effort/performance draws are independent
    // from the observed matches, while still using the same player abilities.
    var random_future_match_ids = mapN(function(x) {
      return uniform(match + 1, 10000);
    }, num_future_matches_to_simulate);

    var simulation_results = map(function(random_match_id) {
      var team1BeatsTeam2 = beat({
        team1: team1,
        team2: team2,
        match: random_match_id
      });

      var margin = margin_of_victory_in_match({
        team1: team1,
        team2: team2,
        match: random_match_id
      });

      var team2Wins = !team1BeatsTeam2;
      var signedMargin = (team2Wins ? 1 : -1) * margin;

      return {
        team2Wins: team2Wins ? 1 : 0,
        signedMargin: signedMargin
      };
    }, random_future_match_ids);

    var winsByTeam2 = sum(map(function(res) { return res.team2Wins; },
                              simulation_results));

    var totalSignedMargin = sum(map(function(res) { return res.signedMargin; },
                                    simulation_results));

    return {
      probTeam2Wins: winsByTeam2 / num_future_matches_to_simulate,
      expected_signed_margin: totalSignedMargin / num_future_matches_to_simulate
    };
  };

  ////////////////////////////////
  // CONDITIONS (OBSERVED MATCHES)
  ////////////////////////////////

  // In the first match, Chen beat Priya.  
  condition(beat({team1: ['chen'], team2: ['priya'], match: 1}))

  // In the second match, Chen and Luis beat Priya and Mei.  
  condition(beat({team1: ['chen', 'luis'], team2: ['priya', 'mei'], match: 2}))

  // In the third match, Priya and Luis beat Chen and Arjun.  
  condition(beat({team1: ['priya', 'luis'], team2: ['chen', 'arjun'], match: 3}))

  ////////////////////////////////
  // QUERIES
  ////////////////////////////////

  // Query 1: Out of 100 random table tennis players, where do you think Chen ranks in terms of intrinsic table tennis ability?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Luis put into the third match?  
  // Query 3: In a new match later this same day between Chen and Priya (Team 1) and Luis and Mei (Team 2), who would win and by how much?  
  // Query 4: In a new match later this same day between Chen and Mei (Team 1) and Priya and Arjun (Team 2), who would win and by how much?  
  return {
    query1: intrinsic_table_tennis_ability_rank({player: 'chen', out_of_n_players: 100}),
    query2: effort_percentage_in_match({player: 'luis', match: 3}),
    query3: who_would_win_by_how_much({team1: ['chen', 'priya'], team2: ['luis', 'mei'], match: 4}),
    query4: who_would_win_by_how_much({team1: ['chen', 'mei'], team2: ['priya', 'arjun'], match: 5})
  };
};

// Run the model and collect an estimate of the posterior over the queries.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-3.json', posterior);