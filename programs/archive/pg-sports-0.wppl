var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic basketball ability is an attribute of a given player that varies widely. Players generally fall into unskilled, skilled, or particularly skilled categories.
    var intrinsic_basketball_ability = mem(function ({player}) {
      var parameter_low_skill_prior = 0.33;
      var parameter_average_prior = 0.33;
      var parameter_high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var parameter_intrinsic_skill_variance = 10;

      var this_player_skill_average = categorical({ps: [parameter_low_skill_prior, parameter_average_prior, parameter_high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(this_player_skill_average ,  parameter_intrinsic_skill_variance), 0);
    })

    // A player's intrinsic basketball ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_basketball_ability_rank = function({player, out_of_n_players}) {
        // Generate out_of_n_players - 1 other random player IDs
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        // Total number of random other players this player is more skilled than.
        return sum(map(
            function(random_player_id) {
              return intrinsic_basketball_ability({player: player}) > intrinsic_basketball_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a game varies and can depend on the player's intrinsic ability. More skilled players might exert less effort to achieve the same performance.
    var effort_in_game = mem(function({player, game}) {
      var player_skill = intrinsic_basketball_ability({player: player})

      // Prior for low, medium, or high effort based on skill.
      var parameter_low_effort_prior = 
          player_skill > 120 ? 0.6 : // Skilled players often exert low effort.
               player_skill < 80 ?  0.1 : // Less skilled players rarely exert low effort.
                                                     0.3;  // Otherwise, sometimes exert low effort.
      var parameter_medium_effort_prior = player_skill > 120 ? 0.3 : // Skilled players sometimes exert medium effort.
               player_skill < 80 ?  0.3 : // Less skilled players sometimes exert medium effort.
                                                        0.5; // Medium players often exert medium effort.
      var parameter_high_effort_prior = player_skill > 120 ? 0.1 :  // Skilled players rarely exert high effort.
               player_skill < 80 ?  0.6 : // Less skilled players often exert high effort.
                                                        0.2; // Otherwise, sometimes exert high effort.

      // Effort on a 0-100 scale.
      var low_effort_average = 30; 
      var medium_effort_average = 60;
      var high_effort_average = 90;
      var effort_variance = 10;
      
      // Effort level for this player in this game.
      var this_player_effort_average = categorical({ps: [parameter_low_effort_prior, parameter_medium_effort_prior, parameter_high_effort_prior], 
      vs: [low_effort_average, medium_effort_average, high_effort_average]});

      return Math.min(Math.max(gaussian(this_player_effort_average, effort_variance), 0), 100)
    })

    // Overall performance in a game is a combination of intrinsic ability and effort.
    var overall_performance = function({team, game}) {
      return listMean(map(function(player) { 
        return intrinsic_basketball_ability({player: player}) + effort_in_game({player: player, game: game}) 
      }, team))
    }

    // A team beats another team in a game if their overall performance is greater.
    var beat = function({team1, team2, game}){
      return overall_performance({team: team1, game: game}) > overall_performance({team: team2, game: game})
    }
    
    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another.
    var who_would_win_by_how_much = function({team1, team2, game}) {
      var num_future_games_to_simulate = 100;
      var random_future_game_ids = mapN(function(x) {return uniform(game+1, 1000)}, num_future_games_to_simulate);

      var simulated_games_won_by_team_2 = sum(map(
            function(random_future_game_id) {
              return !beat({team1: team1, team2: team2, game: random_future_game_id})}, random_future_game_ids))

      return simulated_games_won_by_team_2 / num_future_games_to_simulate;
    }

  // CONDITIONS
  // In the first game, Jordan, Riley, and Sam beat Taylor, Casey, and Devon.
  condition(beat({team1:['jordan', 'riley', 'sam'], team2:['taylor', 'casey', 'devon'], game: 1}))
  // In the second game, Jordan, Taylor, and Riley beat Sam, Casey, and Devon.
  condition(beat({team1:['jordan', 'taylor', 'riley'], team2:['sam', 'casey', 'devon'], game: 2}))
  // In the third game, Devon beat Riley.
  condition(beat({team1:['devon'], team2:['riley'], game: 3}))

  // QUERIES
  // Query 1: Out of 100 random basketball players, where do you think Jordan ranks in terms of intrinsic basketball ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Taylor put into the second game?
  // Query 3: In a new game later this same day between Jordan, Sam, and Casey (Team 1) and Taylor, Riley, and Devon (Team 2), who would win and by how much?
  // Query 4: In a new 1-on-1 game later this same day between Jordan (Player 1) and Devon (Player 2), who would win and by how much?
  return {
    query1: intrinsic_basketball_ability_rank({player: 'jordan', out_of_n_players: 100}),
    query2: effort_in_game({player: 'taylor', game: 2}),
    query3: who_would_win_by_how_much({team1:['jordan', 'sam', 'casey'], team2:['taylor', 'riley', 'devon'], game: 4}),
    query4: who_would_win_by_how_much({team1:['jordan'], team2:['devon'], game: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-sports-0.json', posterior);