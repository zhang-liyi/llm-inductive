var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {

  ////////////////////////////////////////////////////////
  // Helper functions
  ////////////////////////////////////////////////////////

  // Clamp a value between low and high.
  var clamp = function(x, low, high) {
    return Math.min(Math.max(x, low), high);
  };

  // Mean of a list (WebPPL has listMean, but we may use it explicitly if needed).
  // (We will mostly use listMean from the standard library as in the example.)
  

  ////////////////////////////////////////////////////////
  // BACKGROUND KNOWLEDGE
  ////////////////////////////////////////////////////////

  // Intrinsic technical skill (throwing, gripping, balance, timing, in aggregate).
  // Units: abstract "technical skill points" on a 0–100 scale, higher = better.
  var intrinsic_technical_skill = mem(function({athlete}) {
    // Three broad skill buckets in the general judo population.
    var low_mean = 40;    // relatively weak competitors
    var mid_mean = 60;    // typical competitors
    var high_mean = 80;   // strong competitors
    var skill_spread = 10; // standard deviation of skill within bucket (points)

    var bucket_mean = categorical({
      ps: [0.3, 0.4, 0.3],
      vs: [low_mean, mid_mean, high_mean]
    });

    return Math.max(gaussian(bucket_mean, skill_spread), 0);
  });

  // Subskills, each centered on intrinsic technical skill but with some variation.
  // Units: same 0–100 "technical skill points".
  var throwing_technique_skill = mem(function({athlete}) {
    var base = intrinsic_technical_skill({athlete: athlete});
    var spread = 5;
    return clamp(gaussian(base, spread), 0, 100);
  });

  var gripping_skill = mem(function({athlete}) {
    var base = intrinsic_technical_skill({athlete: athlete});
    var spread = 5;
    return clamp(gaussian(base, spread), 0, 100);
  });

  var balance_skill = mem(function({athlete}) {
    var base = intrinsic_technical_skill({athlete: athlete});
    var spread = 5;
    return clamp(gaussian(base, spread), 0, 100);
  });

  var timing_skill = mem(function({athlete}) {
    var base = intrinsic_technical_skill({athlete: athlete});
    var spread = 5;
    return clamp(gaussian(base, spread), 0, 100);
  });

  // Effort in a given match for a given athlete.
  // Units: percentage effort on a 0–100% scale.
  // Depends weakly on intrinsic skill (more skilled athletes are a bit less likely to exert very low effort).
  var effort_in_match = mem(function({athlete, match}) {
    var skill = intrinsic_technical_skill({athlete: athlete}); // 0–100

    // Base mean effort for a competitive match.
    var baseMean = 0.75; // 75%

    // Skill effect: more skilled athletes tend to avoid very low effort,
    // but effect is modest. Normalize skill around 60.
    var skillEffect = (skill - 60) / 40 * 0.1; // roughly in [-0.25, 0.25] before clamp

    var meanEffort = clamp(baseMean + skillEffect, 0.4, 0.98);

    // Convert mean + concentration into Beta parameters.
    var concentration = 20; // higher = less variable effort
    var a = meanEffort * concentration;
    var b = (1 - meanEffort) * concentration;

    // Sample effort fraction from Beta, then convert to 0–100%.
    return clamp(beta(a, b) * 100, 0, 100);
  });

  // Direct query wrapper: effort percentage in a specific match.
  var effort_percentage_in_match = function({athlete, match}) {
    return effort_in_match({athlete: athlete, match: match});
  };

  // Athlete's performance in a specific match.
  // Units: arbitrary "performance units" (higher = better).
  // Determined by subskills, intrinsic technical skill, effort, and noise.
  var athlete_match_performance = function({athlete, match}) {
    var intrinsic = intrinsic_technical_skill({athlete: athlete});

    var throwSkill = throwing_technique_skill({athlete: athlete});
    var gripSkill = gripping_skill({athlete: athlete});
    var balSkill = balance_skill({athlete: athlete});
    var timeSkill = timing_skill({athlete: athlete});

    var avgSubskills = listMean([throwSkill, gripSkill, balSkill, timeSkill]);

    // Combine intrinsic and subskills.
    var combinedSkill = 0.5 * intrinsic + 0.5 * avgSubskills;

    // Effort fraction in [0,1].
    var effortFrac = effort_in_match({athlete: athlete, match: match}) / 100;

    // Performance mean scales with both skill and effort.
    var performanceMean = combinedSkill * effortFrac;

    // Random situational noise (referees, luck, minor injuries, etc.).
    var situational_noise_sd = 10;
    var noise = gaussian(0, situational_noise_sd);

    return performanceMean + noise;
  };

  // Team match performance: aggregate of member performances (mean over members).
  // Units: same "performance units".
  var team_match_performance = function({team, match}) {
    var performances = map(
      function(athlete) {
        return athlete_match_performance({athlete: athlete, match: match});
      },
      team
    );
    return listMean(performances);
  };

  // Margin of victory in a match: team1 performance minus team2 performance.
  // Units: performance units; positive = team1 better.
  var margin_of_victory_in_match = function({team1, team2, match}) {
    var perf1 = team_match_performance({team: team1, match: match});
    var perf2 = team_match_performance({team: team2, match: match});
    return perf1 - perf2;
  };

  // A team beats another if its margin of victory is > 0.
  var beat = function({team1, team2, match}) {
    return margin_of_victory_in_match({team1: team1, team2: team2, match: match}) > 0;
  };

  // Convenience: team1 loses if it does not beat team2.
  var lost = function({team1, team2, match}) {
    return !beat({team1: team1, team2: team2, match: match});
  };

  // Intrinsic technical skill rank: how many out of N random athletes this athlete is better than.
  var intrinsic_technical_skill_rank = function({athlete, out_of_n_athletes}) {
    // Generate out_of_n_athletes - 1 random "other athlete" IDs.
    var random_athlete_ids = mapN(
      function(x) { return uniform(0, 1000); },
      out_of_n_athletes - 1
    );

    var this_skill = intrinsic_technical_skill({athlete: athlete});

    // Count how many random athletes have lower intrinsic technical skill.
    return sum(map(
      function(random_id) {
        return this_skill > intrinsic_technical_skill({athlete: random_id});
      },
      random_athlete_ids
    ));
  };

  // Who would win and by how much, expressed as probability that Team 2 would win.
  // 0.0 = Team 1 almost surely wins; 1.0 = Team 2 almost surely wins.
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;

    // Simulate independent future matches using random match IDs > current match.
    var random_future_match_ids = mapN(
      function(x) { return uniform(match + 1, 1000); },
      num_future_matches_to_simulate
    );

    // Count in how many simulations team1 loses (i.e., team2 wins).
    var simulated_wins_by_team2 = sum(map(
      function(future_match_id) {
        return lost({team1: team1, team2: team2, match: future_match_id});
      },
      random_future_match_ids
    ));

    return simulated_wins_by_team2 / num_future_matches_to_simulate;
  };

  ////////////////////////////////////////////////////////
  // CONDITIONS (observed matches)
  ////////////////////////////////////////////////////////

  // In the first match, Sora beat Hana.
  condition(beat({team1: ['sora'], team2: ['hana'], match: 1}));

  // In the second match, Sora and Ken beat Hana and Riku.
  condition(beat({team1: ['sora', 'ken'], team2: ['hana', 'riku'], match: 2}));

  // In the third match, Ken, Riku, and Mei beat Sora, Hana, and Taro.
  condition(beat({team1: ['ken', 'riku', 'mei'], team2: ['sora', 'hana', 'taro'], match: 3}));

  ////////////////////////////////////////////////////////
  // QUERIES
  ////////////////////////////////////////////////////////

  // Query 1: Out of 100 random judo athletes, where do you think Sora ranks in terms of intrinsic technical skill?  
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Ken put into the third match?  
  // Query 3: In a new match later this same day between Sora, Ken, and Mei (Team 1) and Hana, Riku, and Taro (Team 2), who would win and by how much?  
  // Query 4: In a new match later this same day between Mei (Team 1) and Riku (Team 2), who would win and by how much?

  return {
    query1: intrinsic_technical_skill_rank({athlete: 'sora', out_of_n_athletes: 100}),
    query2: effort_percentage_in_match({athlete: 'ken', match: 3}),
    query3: who_would_win_by_how_much({team1: ['sora', 'ken', 'mei'], team2: ['hana', 'riku', 'taro'], match: 4}),
    query4: who_would_win_by_how_much({team1: ['mei'], team2: ['riku'], match: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-38.json', posterior);