var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic basketball ability is an attribute of a given player that varies widely from player to player.
    var intrinsic_basketball_ability = mem(function ({player}) {
      var low_skill_prior = 0.33;
      var average_skill_prior = 0.33;
      var high_skill_prior = 0.34;

      // On an arbitrary scale centered around 100.
      var low_skill_mean = 80; 
      var average_skill_mean = 100;
      var high_skill_mean = 140;
      var skill_variance = 10;

      var player_skill_average = categorical({ps: [low_skill_prior, average_skill_prior, high_skill_prior], 
      vs: [low_skill_mean, average_skill_mean, high_skill_mean]});

      return Math.max(gaussian(player_skill_average, skill_variance), 0);
    })

    // A player's intrinsic basketball ability ranking out of n other players is the number of other players we might expect them to be more skilled than out of N total random players.
    var intrinsic_basketball_ability_rank = function({player, out_of_n_players}) {
        var random_player_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_players - 1)
        
        return sum(map(
            function(random_player_id) {
              return intrinsic_basketball_ability({player: player}) > intrinsic_basketball_ability({player: random_player_id})}, random_player_ids))
    }
    
    // Effort in a game can vary and is influenced by the player's intrinsic ability.
    var effort_in_game = mem(function({player, game}) {
      var base_effort = 50; // Base effort level on a 0-100 scale.
      var effort_variance = 20;
      
      return Math.min(Math.max(gaussian(base_effort, effort_variance), 0), 100);
    })

    // A team's performance in a game is determined by the combined intrinsic abilities and efforts of its players.
    var team_performance_in_game = function({team, game}) {
      var total_ability = sum(map(function(player) { return intrinsic_basketball_ability({player: player}) }, team))
      var total_effort = sum(map(function(player) { return effort_in_game({player: player, game: game}) }, team))

      return total_ability + total_effort;
    }
    
    // A team beats another team in a game if their overall performance is greater.
    var beat = function({team1, team2, game}){
      return team_performance_in_game({team: team1, game: game}) > team_performance_in_game({team: team2, game: game})
    }

    // To calculate who would win and by how much, we will calculate the likelihood that a team would win over another.
    var who_would_win_by_how_much = function({team1, team2, game}) {
      var num_future_games_to_simulate = 100;
      var random_future_game_ids = mapN(function(x) {return uniform(game+1, 1000)}, num_future_games_to_simulate);

      var simulated_games_won_by_team_2 = sum(map(
            function(random_future_game_id) {
              return !beat({team1: team1, team2: team2, game: random_future_game_id})}, random_future_game_ids))

      return simulated_games_won_by_team_2 / num_future_games_to_simulate;
    }

  // CONDITIONS
  // In the first game, Jordan beat Riley.
  condition(beat({team1:['jordan'], team2:['riley'], game: 1}))
  // In the second game, Jordan and Kai beat Riley and Devon.
  condition(beat({team1:['jordan', 'kai'], team2:['riley', 'devon'], game: 2}))
  // In the third game, Devon and Riley beat Jordan and Kai.
  condition(beat({team1:['devon', 'riley'], team2:['jordan', 'kai'], game: 3}))

  // QUERIES
  // Query 1: Out of 100 random basketball players, where do you think Jordan ranks in terms of intrinsic basketball ability?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Devon put into the third game?
  // Query 3: In a new game later this same day between Jordan and Riley (Team 1) and Kai and Taylor (Team 2), who would win and by how much?
  // Query 4: In a new game later this same day between Devon, Kai, and Taylor (Team 1) and Jordan, Riley, and Morgan (Team 2), who would win and by how much?
  return {
    query1: intrinsic_basketball_ability_rank({player: 'jordan', out_of_n_players: 100}),
    query2: effort_in_game({player: 'devon', game: 3}),
    query3: who_would_win_by_how_much({team1:['jordan', 'riley'], team2:['kai', 'taylor'], game: 4}),
    query4: who_would_win_by_how_much({team1:['devon', 'kai', 'taylor'], team2:['jordan', 'riley', 'morgan'], game: 5})
  }
}
// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10000-gpt-5p1-0.json', posterior);