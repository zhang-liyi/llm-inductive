var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
  // BACKGROUND KNOWLEDGE
  // We model small-sided handball matches played on a single afternoon.
  // Each athlete has a stable intrinsic strength-and-skill level across all matches that afternoon.
  // In each specific match, athletes exert some effort, which interacts with intrinsic ability to produce realized performance.
  // Team performance in a match is a combination of individual contributions and team coordination in that match.
  // The team with higher effective score in a match is considered to have won that match.

  // Helper: logistic / sigmoid function
  var sigmoid = function(x) {
    return 1 / (1 + Math.exp(-x));
  };

  // Intrinsic strength and skill (stable across matches for an athlete).
  // Units: abstract "ability points" on a ~0–200 scale (higher = more powerful, accurate, faster, better game sense).
  var intrinsic_strength_and_skill = mem(function({athlete}) {
    // Prior over low / medium / high tiers in the population
    var p_low = 0.33;
    var p_mid = 0.34;
    var p_high = 0.33;

    // Means for each tier
    var low_mean = 70;   // clearly below-average recreational/competitive player
    var mid_mean = 100;  // average strong player
    var high_mean = 135; // particularly strong & skilled

    var tier_mean = categorical({
      ps: [p_low, p_mid, p_high],
      vs: [low_mean, mid_mean, high_mean]
    });

    // Some spread within a tier
    var ability = gaussian(tier_mean, 12); // SD = 12 ability points
    return Math.max(ability, 0);
  });

  // Intrinsic rank out of N random players: how many of N-1 random players this athlete tends to be stronger than.
  var intrinsic_strength_and_skill_rank = function({athlete, out_of_n_players}) {
    // Generate out_of_n_players - 1 random "other" athlete IDs
    var other_ids = mapN(function(i) { return uniform(0, 10000); }, out_of_n_players - 1);

    var this_skill = intrinsic_strength_and_skill({athlete: athlete});

    // Count how many random others this athlete is more skilled than
    var num_outperformed = sum(map(function(other_id) {
      return this_skill > intrinsic_strength_and_skill({athlete: other_id}) ? 1 : 0;
    }, other_ids));

    // Return the number of players (out of out_of_n_players) they are better than
    return num_outperformed;
  };

  // Baseline effort tendency (stable trait for an athlete).
  // Units: fraction in [0,1], interpreted as "usual effort level" as a proportion of maximum possible effort.
  var baseline_effort_tendency = mem(function({athlete}) {
    // Most recreational-competitive players usually try pretty hard, but some are more relaxed.
    return beta({a: 4, b: 2}); // mean ~ 0.67
  });

  // Effort in a specific match for a specific athlete.
  // Units: fraction in [0,1], where 1 = maximal effort, 0 = no effort.
  var effort_in_match = mem(function({athlete, match}) {
    var skill = intrinsic_strength_and_skill({athlete: athlete});
    var baseline = baseline_effort_tendency({athlete: athlete});

    // More skilled athletes might on average sustain slightly higher effective effort.
    var skill_center = 100.0;
    var skill_effect = 0.2 * (skill - skill_center) / 40.0; // typically between about -0.2 and +0.2

    var raw_mean_effort = baseline + skill_effect;
    var noisy_effort = gaussian(raw_mean_effort, 0.15); // SD ~ 0.15 across matches

    return Math.min(Math.max(noisy_effort, 0), 1);
  });

  // Effort percentage in a given match for an athlete (0–100%).
  var effort_percentage_in_match = function({athlete, match}) {
    return 100 * effort_in_match({athlete: athlete, match: match});
  };

  // Per-match realized throwing power.
  // Units: "power points" on approximately the same scale as intrinsic ability (0–~150).
  var per_match_throwing_power = function({athlete, match}) {
    var skill = intrinsic_strength_and_skill({athlete: athlete});
    var effort = effort_in_match({athlete: athlete, match: match});

    // Effort scales how much of their intrinsic power they realize.
    var mean_power = skill * (0.3 + 0.7 * effort); // between ~0.3*skill and ~1.0*skill
    var power = gaussian(mean_power, 8); // SD ~ 8
    return Math.max(power, 0);
  };

  // Per-match realized throwing accuracy.
  // Units: "accuracy points" on a similar scale (0–~150).
  var per_match_accuracy = function({athlete, match}) {
    var skill = intrinsic_strength_and_skill({athlete: athlete});
    var effort = effort_in_match({athlete: athlete, match: match});

    // Both skill and effort help accuracy; high effort helps slightly more than for power.
    var mean_acc = skill * (0.3 + 0.6 * effort);
    var acc = gaussian(mean_acc, 8);
    return Math.max(acc, 0);
  };

  // Per-match realized speed and agility.
  // Units: "speed points" on a similar scale (0–~150).
  var per_match_speed_and_agility = function({athlete, match}) {
    var skill = intrinsic_strength_and_skill({athlete: athlete});
    var effort = effort_in_match({athlete: athlete, match: match});

    var mean_speed = skill * (0.3 + 0.7 * effort);
    var spd = gaussian(mean_speed, 8);
    return Math.max(spd, 0);
  };

  // Offensive contribution in a match.
  // Units: "offense contribution points".
  var player_offensive_contribution_in_match = function({athlete, match}) {
    var power = per_match_throwing_power({athlete: athlete, match: match});
    var acc = per_match_accuracy({athlete: athlete, match: match});
    var spd = per_match_speed_and_agility({athlete: athlete, match: match});

    // Weighted combination: power & accuracy more central to scoring.
    return 0.5 * power + 0.3 * acc + 0.2 * spd;
  };

  // Defensive contribution in a match.
  // Units: "defense contribution points".
  var player_defensive_contribution_in_match = function({athlete, match}) {
    var acc = per_match_accuracy({athlete: athlete, match: match});
    var spd = per_match_speed_and_agility({athlete: athlete, match: match});

    // Speed and positioning (proxied by speed) matter slightly more than pure accuracy.
    return 0.6 * spd + 0.4 * acc;
  };

  // Overall individual contribution in a match (offense + defense).
  // Units: "overall performance points".
  var player_overall_contribution_in_match = function({athlete, match}) {
    var off = player_offensive_contribution_in_match({athlete: athlete, match: match});
    var def = player_defensive_contribution_in_match({athlete: athlete, match: match});

    var mean_total = 0.6 * off + 0.4 * def;
    var total = gaussian(mean_total, 10); // add some match-level randomness
    return Math.max(total, 0);
  };

  // Team coordination in a match.
  // Units: "coordination bonus points" added to the sum of individual contributions.
  var team_coordination_in_match = function({team, match}) {
    var skills = map(function(a) {
      return intrinsic_strength_and_skill({athlete: a});
    }, team);

    var efforts = map(function(a) {
      return effort_in_match({athlete: a, match: match});
    }, team);

    var avg_skill = listMean(skills);
    var avg_effort = listMean(efforts);

    // Stronger, higher-effort teams generally coordinate better.
    var mean_coord = -20 + 0.15 * avg_skill + 40 * (avg_effort - 0.5);
    var coord = gaussian(mean_coord, 6); // SD ~ 6
    // Coordination can be mildly negative (poor coordination) but mostly near 0–50.
    return coord;
  };

  // Team overall performance in a match.
  // Units: "performance points".
  var team_overall_performance_in_match = function({team, match}) {
    var indiv_sum = sum(map(function(a) {
      return player_overall_contribution_in_match({athlete: a, match: match});
    }, team));

    var coord = team_coordination_in_match({team: team, match: match});

    var perf = indiv_sum + coord + gaussian(0, 12); // additional luck/noise term
    return perf;
  };

  // Latent team score in a match (derived from performance).
  // Units: abstract "score units" roughly proportional to goals; higher = more likely to win.
  var team_score_in_match = mem(function({team, match}) {
    var perf = team_overall_performance_in_match({team: team, match: match});
    // Symmetric scoring noise around performance
    var score = perf + gaussian(0, 20);
    return score;
  });

  // Score difference in a match.
  // Units: "score units", defined as team1_score - team2_score.
  var score_difference_in_match = function({team1, team2, match}) {
    var s1 = team_score_in_match({team: team1, match: match});
    var s2 = team_score_in_match({team: team2, match: match});
    return s1 - s2;
  };

  // Team1 beats Team2 in a match if its score is higher.
  var beat = function({team1, team2, match}) {
    return score_difference_in_match({team1: team1, team2: team2, match: match}) > 0;
  };

  // Predict who would win and by how much in a hypothetical future match between Team1 and Team2.
  // Returns:
  //  - probTeam1Wins: estimated probability that Team 1 wins
  //  - probTeam2Wins: estimated probability that Team 2 wins
  //  - expected_score_difference_team1_minus_team2: average (Team1Score - Team2Score) over simulated matches
  var who_would_win_by_how_much = function({team1, team2, match}) {
    var num_future_matches_to_simulate = 100;
    // Use future match IDs not overlapping with observed ones
    var random_future_match_ids = mapN(function(i) {
      return uniform(match + 1, 2000);
    }, num_future_matches_to_simulate);

    // Fraction of simulations where Team 2 beats Team 1
    var team2_wins_count = sum(map(function(mid) {
      // Team 2 beating Team 1 is beat({team1: team2, team2: team1, ...})
      return beat({team1: team2, team2: team1, match: mid}) ? 1 : 0;
    }, random_future_match_ids));

    var probTeam2Wins = team2_wins_count / num_future_matches_to_simulate;
    var probTeam1Wins = 1 - probTeam2Wins;

    // Average score difference (Team1 - Team2) over the simulated matches
    var diffs = map(function(mid) {
      return score_difference_in_match({team1: team1, team2: team2, match: mid});
    }, random_future_match_ids);

    var expectedDiff = listMean(diffs);

    return {
      probTeam1Wins: probTeam1Wins,
      probTeam2Wins: probTeam2Wins,
      expected_score_difference_team1_minus_team2: expectedDiff
    };
  };

  // CONDITIONS
  // In the first match, Jordan beat Leo.
  condition(beat({team1:['jordan'], team2:['leo'], match: 1}))
  // In the second match, Jordan and Mia beat Leo and Sam.
  condition(beat({team1:['jordan', 'mia'], team2:['leo', 'sam'], match: 2}))
  // In the third match, Leo and Nora beat Jordan and Sam.
  condition(beat({team1:['leo', 'nora'], team2:['jordan', 'sam'], match: 3}))

  // QUERIES
  // Query 1: Out of 100 random handball players, where do you think Jordan ranks in terms of intrinsic strength and skill?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Leo put into the first match?
  // Query 3: In a new 3-on-3 match later this same afternoon between Jordan, Mia, and Nora (Team 1) and Leo, Sam, and Riley (Team 2), who would win and by how much?
  // Query 4: In a new 2-on-2 match later this same afternoon between Jordan and Sam (Team 1) and Leo and Mia (Team 2), who would win and by how much?
  return {
    query1: intrinsic_strength_and_skill_rank({athlete: 'jordan', out_of_n_players: 100}),
    query2: effort_percentage_in_match({athlete: 'leo', match: 1}),
    query3: who_would_win_by_how_much({team1:['jordan', 'mia', 'nora'], team2:['leo', 'sam', 'riley'], match: 4}),
    query4: who_would_win_by_how_much({team1:['jordan', 'sam'], team2:['leo', 'mia'], match: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-15.json', posterior);