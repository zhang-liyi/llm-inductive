var identity = function(x) {
  return x;
};

var argMax = function(ar) {
  return maxWith(identity, ar)[0];
};

var argmax = argMax;

var mean = listMean;

var model = function() {
    // BACKGROUND KNOWLEDGE
    // Intrinsic sprint speed is an attribute of a given athlete that varies widely from athlete to athlete.
    var intrinsic_sprint_speed = mem(function ({athlete}) {
      var low_speed_mean = 8; 
      var average_speed_mean = 10;
      var high_speed_mean = 12;
      var speed_variance = 1;

      var speed_category = categorical({ps: [0.33, 0.33, 0.34], vs: [low_speed_mean, average_speed_mean, high_speed_mean]});
      return Math.max(gaussian(speed_category, speed_variance), 0);
    });

    // An athlete's intrinsic sprinting strength ranking out of n other athletes.
    var intrinsic_sprinting_strength_rank = function({athlete, out_of_n_athletes}) {
        var random_athlete_ids = mapN(function(x) {return uniform(0, 1000)}, out_of_n_athletes - 1);
        return sum(map(
            function(random_athlete_id) {
              return intrinsic_sprint_speed({athlete: athlete}) > intrinsic_sprint_speed({athlete: random_athlete_id});
            }, random_athlete_ids));
    };

    // Handoff precision in a relay depends on the average sprint speed of the team.
    var handoff_precision_in_relay = function({team, relay}) {
      var average_team_speed = listMean(map(function(athlete) { return intrinsic_sprint_speed({athlete: athlete}) }, team));
      return Math.min(Math.max(gaussian(average_team_speed, 2), 0), 100);
    };

    // Effort level in a relay can vary and is influenced by intrinsic sprint speed.
    var effort_level_in_relay = function({athlete, relay}) {
      var base_effort = 50;
      return Math.min(Math.max(gaussian(base_effort + intrinsic_sprint_speed({athlete: athlete}), 10), 0), 100);
    };

    // Overall team performance is determined by sprint speed, handoff precision, and effort level.
    var overall_team_performance = function({team, relay}) {
      var speed_score = listMean(map(function(athlete) { return intrinsic_sprint_speed({athlete: athlete}) }, team));
      var handoff_score = handoff_precision_in_relay({team: team, relay: relay});
      var effort_score = listMean(map(function(athlete) { return effort_level_in_relay({athlete: athlete, relay: relay}) }, team));
      return speed_score + handoff_score + effort_score;
    };

    // A team beats another team in a relay if their overall performance is greater.
    var beat = function({team1, team2, relay}){
      return overall_team_performance({team: team1, relay: relay}) > overall_team_performance({team: team2, relay: relay});
    };

    // A team loses to another team in a given relay if they did not beat the team.
    var lost = function({team1, team2, relay}){ 
      return !beat({team1: team1, team2: team2, relay: relay});
    };

    // Calculate who would win and by how much.
    var who_would_win_by_how_much = function({team1, team2, relay}) {
      var num_future_relays_to_simulate = 100;
      var random_future_relay_ids = mapN(function(x) {return uniform(relay+1, 1000)}, num_future_relays_to_simulate);
      var simulated_relays_won_by_team_2 = sum(map(
            function(random_future_relay_id) {
              return lost({team1: team1, team2: team2, relay: random_future_relay_id});
            }, random_future_relay_ids));
      return simulated_relays_won_by_team_2 / num_future_relays_to_simulate;
    };

  // CONDITIONS
  // In the first relay, Team Red (Ava, Leo, Mira, Sam) beat Team Blue (Jon, Riley, Tessa, Cole).
  condition(beat({team1:['ava', 'leo', 'mira', 'sam'], team2:['jon', 'riley', 'tessa', 'cole'], relay: 1}));
  // In the second relay, Mira and Sam joined Team Yellow and beat Team Blue.
  condition(beat({team1:['mira', 'sam', 'team_yellow'], team2:['team_blue'], relay: 2}));
  // In the third relay, Team Red lost to Team Yellow (Mira, Sam, Noel, Kai).
  condition(lost({team1:['team_red'], team2:['mira', 'sam', 'noel', 'kai'], relay: 3}));

  // QUERIES
  // Query 1: Out of 100 random athletes, where do you think Mira ranks in terms of intrinsic sprinting strength?
  // Query 2: On a percentage scale from 0 to 100%, how much effort do you think Sam put into the third relay?
  // Query 3: In a new relay later this same day between Team Red (Ava, Leo, Mira, Sam) and Team Blue (Jon, Riley, Tessa, Cole), who would win and by how much?
  // Query 4: In a new relay later this same day between Team Yellow (Mira, Sam, Noel, Kai) and Team Blue, who would win and by how much?
  return {
    query1: intrinsic_sprinting_strength_rank({athlete: 'mira', out_of_n_athletes: 100}),
    query2: effort_level_in_relay({athlete: 'sam', relay: 3}),
    query3: who_would_win_by_how_much({team1:['ava', 'leo', 'mira', 'sam'], team2:['jon', 'riley', 'tessa', 'cole'], relay: 4}),
    query4: who_would_win_by_how_much({team1:['mira', 'sam', 'noel', 'kai'], team2:['team_blue'], relay: 5})
  };
};

// Now we run the model and collect an estimate.
var posterior = Infer({model: model, method: "MCMC", samples: 10000});
json.write('inference_results/result-10000-2-1.json', posterior);